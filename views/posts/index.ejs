<div class="page-header">
  <div class="container">
    <div class="page-header-row">
      <div>
        <h1>Discussions</h1>
        <p>Join conversations with the Diskas community</p>
      </div>
      <% if (currentUser) { %>
        <a href="/discussions/new" class="btn btn-primary">
          <i class="fa-solid fa-plus fa-sm"></i> New Discussion
        </a>
      <% } else { %>
        <a href="/auth/register" class="btn btn-primary">
          <i class="fa-solid fa-user-plus fa-sm"></i> Join to Participate
        </a>
      <% } %>
    </div>
  </div>
</div>

<div class="container main-layout">
  <aside class="sidebar">
    <div class="card">
      <h4 style="font-weight:700;margin-bottom:.5rem">Filter by Type</h4>
      <nav class="filter-nav" aria-label="Discussion type filter">
        <a href="/discussions"                      class="filter-item <%= currentType === 'all'          ? 'active' : '' %>"><i class="fa-solid fa-comments fa-sm"></i> All</a>
        <a href="/discussions?type=discussion"       class="filter-item <%= currentType === 'discussion'   ? 'active' : '' %>"><i class="fa-solid fa-message fa-sm"></i> Discussions</a>
        <a href="/discussions?type=question"         class="filter-item <%= currentType === 'question'     ? 'active' : '' %>"><i class="fa-solid fa-circle-question fa-sm"></i> Q&amp;A</a>
        <a href="/discussions?type=announcement"     class="filter-item <%= currentType === 'announcement' ? 'active' : '' %>"><i class="fa-solid fa-bullhorn fa-sm"></i> Announcements</a>
      </nav>
    </div>
    <div class="card mt-3">
      <h4 style="font-weight:700;margin-bottom:.5rem">Categories</h4>
      <nav class="filter-nav" aria-label="Category filter">
        <a href="/discussions" class="filter-item <%= !currentCategory ? 'active' : '' %>">All Categories</a>
        <% categories.forEach(cat => { %>
          <a href="/discussions?category=<%= cat.slug %>"
             class="filter-item <%= currentCategory === cat.slug ? 'active' : '' %>">
            <span class="cat-dot" style="background:<%= cat.color %>"></span>
            <%= cat.name %>
          </a>
        <% }) %>
      </nav>
    </div>
  </aside>

  <div class="content-area">
    <% if (posts.length === 0) { %>
      <div class="empty-state card">
        <i class="fa-solid fa-comments" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
        <h3>No discussions found</h3>
        <p>Be the first to start a discussion!</p>
        <% if (currentUser) { %>
          <a href="/discussions/new" class="btn btn-primary" style="margin-top:1rem">
            <i class="fa-solid fa-plus fa-sm"></i> New Discussion
          </a>
        <% } %>
      </div>
    <% } else { %>
      <div class="posts-list">
        <% posts.forEach(post => { %>
          <article class="post-card" itemscope itemtype="https://schema.org/DiscussionForumPosting">
            <div class="post-votes">
              <span class="vote-count"><%= post.vote_count || 0 %></span>
              <span class="vote-label">votes</span>
            </div>
            <div class="post-meta-left">
              <% if (post.author_avatar) { %>
                <img src="<%= post.author_avatar %>" alt="<%= post.author_name %>" class="avatar-sm" loading="lazy" />
              <% } else { %>
                <div class="avatar-placeholder-sm" aria-hidden="true"><%= (post.author_name || 'U').charAt(0) %></div>
              <% } %>
            </div>
            <div class="post-body">
              <div class="post-badges">
                <% if (post.status === 'pinned') { %><span class="badge badge-pinned">📌 Pinned</span><% } %>
                <% if (post.type === 'question') { %>
                  <span class="badge badge-question"><%= post.is_answered ? '✅ Answered' : '❓ Question' %></span>
                <% } %>
                <% if (post.type === 'announcement') { %><span class="badge badge-announcement">📢 Announcement</span><% } %>
                <% if (post.category_name) { %>
                  <span class="badge" style="background:<%= post.category_color %>22;color:<%= post.category_color %>"><%= post.category_name %></span>
                <% } %>
              </div>
              <a href="/discussions/<%= post.slug %>" class="post-title" itemprop="headline"><%= post.title %></a>
              <div class="post-info">
                <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                  <i class="fa-solid fa-user fa-xs"></i>
                  <a href="/users/<%= post.user_id %>" itemprop="name" style="color:inherit"><%= post.author_name %></a>
                </span>
                <span><i class="fa-regular fa-clock fa-xs"></i>
                  <time itemprop="datePublished" datetime="<%= post.created_at %>"><%= post.timeAgo %></time>
                </span>
                <span><i class="fa-regular fa-eye fa-xs"></i> <%= post.views %></span>
                <span><i class="fa-regular fa-comment fa-xs"></i> <%= post.reply_count || 0 %> replies</span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>

      <% if (pagination.totalPages > 1) { %>
        <nav class="pagination" aria-label="Page navigation">
          <% if (pagination.hasPrev) { %>
            <a href="?page=<%= pagination.page - 1 %><%= currentType !== 'all' ? '&type=' + currentType : '' %><%= currentCategory ? '&category=' + currentCategory : '' %>" class="page-btn">‹ Prev</a>
          <% } %>
          <span class="page-info">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
          <% if (pagination.hasNext) { %>
            <a href="?page=<%= pagination.page + 1 %><%= currentType !== 'all' ? '&type=' + currentType : '' %><%= currentCategory ? '&category=' + currentCategory : '' %>" class="page-btn">Next ›</a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </div>
</div>
