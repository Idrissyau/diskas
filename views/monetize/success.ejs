<div class="container" style="max-width:520px;padding:3rem 1.25rem;text-align:center">
  <div style="width:72px;height:72px;border-radius:50%;background:#F0FDF4;border:3px solid #86EFAC;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:2rem;color:#16A34A">
    <i class="fa-solid fa-clock"></i>
  </div>

  <h1 style="font-size:1.6rem;font-weight:800;margin-bottom:.5rem">Payment Submitted!</h1>
  <p style="color:var(--text-muted);font-size:.95rem;line-height:1.7;margin-bottom:1.75rem">
    Your payment request has been submitted and is awaiting review.
    You'll receive access once it's approved — usually within 24 hours.
  </p>

  <div class="card" style="padding:1.5rem;text-align:left;margin-bottom:1.5rem">
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.88rem">
      <span style="color:var(--text-muted)">Reference</span>
      <code style="font-weight:600"><%= payment.payment_ref %></code>
    </div>
    <% if (payment.plan_name) { %>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.88rem">
      <span style="color:var(--text-muted)">Plan</span>
      <span style="font-weight:600"><%= payment.plan_name %></span>
    </div>
    <% } %>
    <% if (payment.community_name) { %>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.88rem">
      <span style="color:var(--text-muted)">Community</span>
      <span style="font-weight:600"><%= payment.community_name %></span>
    </div>
    <% } %>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.88rem">
      <span style="color:var(--text-muted)">Amount</span>
      <span style="font-weight:700;color:var(--primary)"><%= formatUSD(payment.amount) %></span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;font-size:.88rem">
      <span style="color:var(--text-muted)">Status</span>
      <span class="badge" style="background:#FFF7ED;color:#C2410C">Pending Review</span>
    </div>
  </div>

  <div style="display:flex;flex-direction:column;gap:.75rem">
    <% if (payment.community_slug) { %>
      <a href="/communities/<%= payment.community_slug %>" class="btn btn-outline">View Community</a>
    <% } %>
    <a href="/payments/history" class="btn btn-outline btn-sm">View All Payments</a>
  </div>
</div>
