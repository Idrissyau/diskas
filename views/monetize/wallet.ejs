<div class="container" style="max-width:960px;padding:2rem 1.25rem">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem">
    <div>
      <h1 style="font-size:1.6rem;font-weight:800">Creator Wallet</h1>
      <p style="color:var(--text-muted);font-size:.88rem">Your earnings, balance, and payout requests</p>
    </div>
    <div style="display:flex;gap:.5rem">
      <a href="/payments/history" class="btn btn-outline btn-sm"><i class="fa-solid fa-receipt"></i> Payment History</a>
      <button class="btn btn-primary btn-sm" onclick="openPayoutModal()"><i class="fa-solid fa-money-bill-transfer"></i> Request Payout</button>
    </div>
  </div>

  <!-- Balance Cards -->
  <div class="stats-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:2rem">
    <div class="card" style="padding:1.25rem;text-align:center">
      <div style="font-size:.78rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.4rem">Total Earned</div>
      <div style="font-size:1.75rem;font-weight:800;color:var(--navy)"><%= formatUSD(wallet.total_earned) %></div>
    </div>
    <div class="card" style="padding:1.25rem;text-align:center;border:2px solid #86EFAC">
      <div style="font-size:.78rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.4rem">Available</div>
      <div style="font-size:1.75rem;font-weight:800;color:#16A34A"><%= formatUSD(wallet.available_balance) %></div>
    </div>
    <div class="card" style="padding:1.25rem;text-align:center">
      <div style="font-size:.78rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.4rem">Pending</div>
      <div style="font-size:1.75rem;font-weight:800;color:var(--warning)"><%= formatUSD(wallet.pending_balance) %></div>
    </div>
    <div class="card" style="padding:1.25rem;text-align:center">
      <div style="font-size:.78rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.4rem">Withdrawn</div>
      <div style="font-size:1.75rem;font-weight:800;color:var(--primary)"><%= formatUSD(wallet.withdrawn_balance) %></div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start" class="wallet-grid">

    <!-- Transactions -->
    <div>
      <div class="card" style="padding:0;overflow:hidden">
        <div style="padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
          <h2 style="font-size:1rem;font-weight:700">Recent Transactions</h2>
        </div>
        <% if (transactions.length === 0) { %>
          <div style="padding:2.5rem;text-align:center;color:var(--text-muted)">
            <i class="fa-solid fa-coins" style="font-size:2rem;margin-bottom:.5rem;display:block;color:#CBD5E1"></i>
            No transactions yet. Start earning by setting up paid plans!
          </div>
        <% } else { %>
          <div>
            <% transactions.forEach(tx => { %>
              <div style="display:flex;align-items:center;justify-content:space-between;padding:.85rem 1.5rem;border-bottom:1px solid var(--border)">
                <div style="display:flex;align-items:center;gap:.75rem">
                  <div style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;
                    background:<%= tx.type==='credit' ? '#F0FDF4' : '#FEF2F2' %>;
                    color:<%= tx.type==='credit' ? '#16A34A' : '#DC2626' %>;font-size:.9rem;flex-shrink:0">
                    <i class="fa-solid fa-<%= tx.type==='credit' ? 'arrow-down-long' : 'arrow-up-long' %>"></i>
                  </div>
                  <div>
                    <div style="font-size:.88rem;font-weight:600"><%= tx.description %></div>
                    <div style="font-size:.75rem;color:var(--text-muted)"><%= new Date(tx.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></div>
                  </div>
                </div>
                <span style="font-weight:700;color:<%= tx.type==='credit' ? '#16A34A' : '#DC2626' %>">
                  <%= tx.type==='credit' ? '+' : '-' %><%= formatUSD(tx.amount) %>
                </span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Sidebar: community revenue + payout history -->
    <div style="display:flex;flex-direction:column;gap:1rem">
      <!-- Community Revenue -->
      <% if (communityRevenue.length > 0) { %>
        <div class="card" style="padding:1.25rem">
          <h3 style="font-size:.9rem;font-weight:700;margin-bottom:1rem">Revenue by Community</h3>
          <% communityRevenue.forEach(cr => { %>
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem">
              <% if (cr.avatar) { %><img src="<%= cr.avatar %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover" />
              <% } else { %><div style="width:28px;height:28px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700"><%= cr.name.charAt(0) %></div><% } %>
              <div style="flex:1;min-width:0">
                <div style="font-size:.83rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= cr.name %></div>
                <div style="font-size:.72rem;color:var(--text-muted)"><%= cr.transactions %> sale<%= cr.transactions!==1?'s':'' %></div>
              </div>
              <span style="font-weight:700;font-size:.9rem;color:var(--success)"><%= formatUSD(cr.revenue) %></span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Payout History -->
      <div class="card" style="padding:1.25rem">
        <h3 style="font-size:.9rem;font-weight:700;margin-bottom:.75rem">Payout Requests</h3>
        <% if (payouts.length === 0) { %>
          <p style="font-size:.82rem;color:var(--text-muted)">No payout requests yet.</p>
        <% } else { %>
          <% payouts.forEach(p => { %>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.83rem">
              <div>
                <div style="font-weight:600"><%= formatUSD(p.amount) %></div>
                <div style="color:var(--text-muted);font-size:.72rem"><%= new Date(p.requested_at).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></div>
              </div>
              <span class="badge" style="
                background:<%= p.status==='approved'||p.status==='paid' ? '#DCFCE7' : p.status==='rejected' ? '#FEE2E2' : '#FFF7ED' %>;
                color:<%= p.status==='approved'||p.status==='paid' ? '#16A34A' : p.status==='rejected' ? '#DC2626' : '#C2410C' %>">
                <%= p.status.charAt(0).toUpperCase()+p.status.slice(1) %>
              </span>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Payout Modal -->
<div class="modal-overlay" id="payoutModal">
  <div class="modal-box" style="max-width:500px">
    <div class="modal-head">
      <h2 class="modal-title">Request Payout</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('payoutModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form action="/wallet/payout" method="POST" style="display:flex;flex-direction:column;gap:1rem">
      <div style="background:#F0FDF4;border-radius:8px;padding:.85rem 1rem;font-size:.85rem;color:#166534">
        <strong>Available Balance:</strong> <%= formatUSD(wallet.available_balance) %> &nbsp;|&nbsp; <strong>Min Payout:</strong> $50.00
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Amount (USD) *</label>
        <div style="position:relative">
          <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600">$</span>
          <input type="number" name="amount" class="form-input" placeholder="50.00" min="50" max="<%= wallet.available_balance %>" step="0.01" style="padding-left:1.75rem" required />
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Payout Method *</label>
        <select name="payout_method" class="form-input">
          <option value="bank_transfer">Bank Transfer</option>
          <option value="paypal">PayPal</option>
          <option value="wise">Wise</option>
          <option value="crypto">Cryptocurrency</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Account Name *</label>
        <input type="text" name="account_name" class="form-input" placeholder="Name on account" required />
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Account Email</label>
        <input type="email" name="account_email" class="form-input" placeholder="PayPal / Wise email" />
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Account Details</label>
        <textarea name="account_details" class="form-input" rows="3" placeholder="Bank name, account number, routing number, or any other details"></textarea>
      </div>
      <div class="modal-footer-btns">
        <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('payoutModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-paper-plane"></i> Submit Request</button>
      </div>
    </form>
  </div>
</div>

<script>
function openPayoutModal() { document.getElementById('payoutModal').classList.add('open'); }
document.getElementById('payoutModal').addEventListener('click', e => {
  if (e.target === document.getElementById('payoutModal')) document.getElementById('payoutModal').classList.remove('open');
});
</script>
