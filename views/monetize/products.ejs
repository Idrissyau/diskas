<div class="container" style="max-width:960px;padding:2rem 1.25rem">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem">
    <div>
      <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.25rem">
        <a href="/communities/<%= community.slug %>" style="color:var(--text-muted)"><i class="fa-solid fa-arrow-left"></i></a>
        <h1 style="font-size:1.4rem;font-weight:800">Digital Products</h1>
      </div>
      <p style="color:var(--text-muted);font-size:.88rem;padding-left:1.75rem"><%= community.name %></p>
    </div>
    <% if (isOwner) { %>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('createProductModal').classList.add('open')">
        <i class="fa-solid fa-plus"></i> New Product
      </button>
    <% } %>
  </div>

  <% if (products.length === 0) { %>
    <div class="card" style="padding:3rem;text-align:center">
      <i class="fa-solid fa-box-open" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
      <h3 style="font-size:1rem;color:var(--text-muted);font-weight:500">No products yet</h3>
      <% if (isOwner) { %>
        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.35rem">Upload PDFs, templates, ebooks, or any digital download to sell here.</p>
        <button class="btn btn-primary btn-sm" style="margin-top:1rem" onclick="document.getElementById('createProductModal').classList.add('open')">Add Product</button>
      <% } %>
    </div>
  <% } else { %>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem">
      <% products.forEach(prod => { %>
        <div class="card" style="padding:0;overflow:hidden;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,.1)'" onmouseout="this.style.boxShadow=''">
          <% if (prod.preview_image) { %>
            <img src="<%= prod.preview_image %>" alt="<%= prod.title %>" style="width:100%;height:150px;object-fit:cover" />
          <% } else { %>
            <div style="height:100px;background:linear-gradient(135deg,#0F172A,#1E3A5F);display:flex;align-items:center;justify-content:center">
              <i class="fa-solid fa-file-arrow-down" style="font-size:2rem;color:rgba(255,255,255,.6)"></i>
            </div>
          <% } %>
          <div style="padding:1.25rem">
            <h3 style="font-size:.95rem;font-weight:700;margin-bottom:.25rem"><%= prod.title %></h3>
            <% if (prod.description) { %><p style="font-size:.8rem;color:var(--text-muted);margin-bottom:.75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= prod.description %></p><% } %>
            <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;flex-wrap:wrap">
              <span style="font-weight:800;font-size:1.1rem;color:<%= prod.price>0?'var(--primary)':'var(--success)' %>">
                <%= prod.price > 0 ? formatUSD(prod.price) : 'Free' %>
              </span>
              <div style="display:flex;gap:.4rem">
                <% if (isOwner) { %>
                  <form action="/communities/<%= community.slug %>/products/<%= prod.id %>/delete" method="POST"
                        onsubmit="return confirm('Delete this product?')">
                    <button class="btn btn-sm" style="background:#FEE2E2;color:#DC2626;border:1px solid #FECACA;font-size:.75rem"><i class="fa-solid fa-trash"></i></button>
                  </form>
                  <% if (prod.file_url) { %>
                    <a href="/products/<%= prod.id %>/download" class="btn btn-outline btn-sm" style="font-size:.78rem"><i class="fa-solid fa-download"></i></a>
                  <% } %>
                <% } else if (prod.isPurchased || prod.price == 0) { %>
                  <% if (prod.file_url) { %>
                    <a href="/products/<%= prod.id %>/download" class="btn btn-sm" style="background:var(--success);color:#fff;font-size:.78rem"><i class="fa-solid fa-download"></i> Download</a>
                  <% } %>
                <% } else { %>
                  <form action="/checkout/product/<%= prod.id %>" method="POST">
                    <button class="btn btn-primary btn-sm" style="font-size:.78rem"><i class="fa-solid fa-shopping-cart"></i> Buy</button>
                  </form>
                <% } %>
              </div>
            </div>
            <% if (prod.access_type !== 'anyone') { %>
              <div style="margin-top:.5rem;font-size:.72rem;color:var(--text-muted)">
                <i class="fa-solid fa-lock"></i>
                <%= prod.access_type==='members_only' ? 'Members only' : 'Specific plan only' %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Create Product Modal -->
<% if (isOwner) { %>
<div class="modal-overlay" id="createProductModal">
  <div class="modal-box" style="max-width:540px">
    <div class="modal-head">
      <h2 class="modal-title">Add Digital Product</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('createProductModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form action="/communities/<%= community.slug %>/products" method="POST" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:1rem">
      <div class="form-group" style="margin:0">
        <label class="form-label">Product Title *</label>
        <input type="text" name="title" class="form-input" placeholder="e.g. Marketing Checklist PDF" required />
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-input" rows="3" placeholder="What's included in this product?"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Price (USD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600">$</span>
            <input type="number" name="price" class="form-input" placeholder="0.00" min="0" step="0.01" style="padding-left:1.75rem" />
          </div>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Who Can Buy</label>
          <select name="access_type" class="form-input">
            <option value="anyone">Anyone</option>
            <option value="members_only">Members Only</option>
            <option value="plan_only">Specific Plan Only</option>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Product File (PDF, ZIP, etc.)</label>
        <input type="file" name="product_file" class="form-input" style="font-size:.85rem" />
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Preview Image (optional)</label>
        <input type="file" name="preview_image" class="form-input" accept="image/*" style="font-size:.85rem" />
      </div>
      <div class="modal-footer-btns">
        <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('createProductModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add Product</button>
      </div>
    </form>
  </div>
</div>
<script>
document.getElementById('createProductModal').addEventListener('click', e => {
  if (e.target === document.getElementById('createProductModal')) document.getElementById('createProductModal').classList.remove('open');
});
</script>
<% } %>
