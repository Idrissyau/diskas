<script>
/* ─────────────── Shared helpers ─────────────── */
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function stripHtml(s){ return String(s||'').replace(/<[^>]+>/g,' ').replace(/\s+/g,' ').trim(); }
function fmtPrice(p){ return p>0 ? '$'+parseFloat(p).toFixed(2) : 'Free'; }
function discountPct(orig, sale){ return orig>sale && orig>0 ? Math.round((1-sale/orig)*100) : 0; }

function showFileInfo(input, infoId) {
  const f = input.files[0]; if (!f) return;
  const ext = f.name.split('.').pop().toLowerCase();
  const blocked = ['mp4','mov','avi','mkv','webm','wmv','flv','m4v','3gp','ts'];
  const warn = input.closest('div').querySelector('.file-block-warn');
  const info = document.getElementById(infoId);
  if (blocked.includes(ext)) {
    input.value = '';
    if (warn) warn.style.display = 'block';
    if (info) info.style.display = 'none';
    return;
  }
  if (warn) warn.style.display = 'none';
  if (info) {
    info.style.display = 'block';
    info.innerHTML = `<i class="fa-solid fa-check"></i> ${esc(f.name)} (${(f.size/1024/1024).toFixed(2)} MB)`;
  }
}

function previewCover(input, imgId, wrapId) {
  const f = input.files[0]; if (!f) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img  = document.getElementById(imgId);
    const wrap = document.getElementById(wrapId);
    if (img)  { img.src = e.target.result; img.style.display = 'block'; }
    if (wrap) { wrap.querySelector('.placeholder-inner') && (wrap.querySelector('.placeholder-inner').style.display = 'none'); }
  };
  reader.readAsDataURL(f);
}

/* ─────────────── Owner: Create ─────────────── */
function openCreate() {
  document.getElementById('createProductModal').classList.add('open');
  // Init RTE on description textarea inside modal
  const ta = document.getElementById('createDescTA');
  if (ta && !ta.dataset.rteInit && window.initRTE) initRTE(ta);
}
function closeCreate() { document.getElementById('createProductModal').classList.remove('open'); }
document.getElementById('createProductModal')?.addEventListener('click', e => { if(e.target===document.getElementById('createProductModal')) closeCreate(); });

/* ─────────────── Owner: Edit ─────────────── */
