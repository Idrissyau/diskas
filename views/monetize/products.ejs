<style>
/* ── Product card ── */
.prod-card { display:flex;flex-direction:column;border-radius:14px;overflow:hidden;border:1.5px solid var(--border);background:var(--card);transition:box-shadow .18s,transform .18s;position:relative }
.prod-card:hover { box-shadow:0 8px 32px rgba(0,0,0,.1);transform:translateY(-2px) }
.prod-img { width:100%;aspect-ratio:16/9;object-fit:cover;display:block }
.prod-img-placeholder { aspect-ratio:16/9;width:100%;display:flex;align-items:center;justify-content:center;font-size:2.5rem }
.prod-body { padding:1.1rem 1.1rem .85rem;flex:1;display:flex;flex-direction:column;gap:.35rem }
.prod-foot { padding:.75rem 1.1rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:.5rem;flex-wrap:wrap }
.file-badge { display:inline-flex;align-items:center;gap:.3rem;font-size:.68rem;font-weight:700;padding:.2rem .55rem;border-radius:5px;letter-spacing:.04em }
.prod-tag { font-size:.7rem;padding:.15rem .55rem;border-radius:20px;background:#F1F5F9;color:var(--text-muted);border:1px solid var(--border) }
/* ── Owner table ── */
.owner-table { width:100%;border-collapse:collapse }
.owner-table th { font-size:.72rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;padding:.6rem 1rem;border-bottom:2px solid var(--border);text-align:left;background:#F8FAFC }
.owner-table td { padding:.85rem 1rem;border-bottom:1px solid var(--border);vertical-align:middle;font-size:.85rem }
.owner-table tr:last-child td { border-bottom:none }
.owner-table tr:hover td { background:#FAFBFF }
/* ── Status badge ── */
.status-dot { display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:.35rem }
/* ── Price fields ── */
.price-grid { display:grid;grid-template-columns:1fr 1fr;gap:1rem }
</style>

<div class="container" style="max-width:1040px;padding:2rem 1.25rem">

  <!-- ── Page header ── -->
  <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem">
    <div>
      <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.25rem">
        <a href="/communities/<%= community.slug %>" style="color:var(--text-muted)"><i class="fa-solid fa-arrow-left"></i></a>
        <h1 style="font-size:1.4rem;font-weight:800">Digital Products</h1>
      </div>
      <p style="color:var(--text-muted);font-size:.88rem;padding-left:1.75rem"><%= community.name %></p>
    </div>
    <% if (isOwner) { %>
      <button class="btn btn-primary btn-sm" onclick="openCreate()">
        <i class="fa-solid fa-plus"></i> New Product
      </button>
    <% } %>
  </div>

  <!-- ══════════════════════════════════════════════════
       OWNER VIEW
  ══════════════════════════════════════════════════ -->
  <% if (isOwner) { %>

    <!-- Summary stats -->
    <% if (ownerStats) { %>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.75rem">
      <% const stats = [
        { label:'Products',       val: ownerStats.product_count,   icon:'fa-box',        color:'#6366F1', bg:'#EEF2FF' },
        { label:'Total Sales',    val: ownerStats.total_sales,     icon:'fa-receipt',    color:'#10B981', bg:'#F0FDF4' },
        { label:'Revenue',        val: formatUSD(ownerStats.total_revenue), icon:'fa-dollar-sign', color:'#0EA5E9', bg:'#EFF6FF', raw:true },
        { label:'Downloads',      val: ownerStats.total_downloads, icon:'fa-download',   color:'#F59E0B', bg:'#FFFBEB' },
      ]; %>
      <% stats.forEach(s => { %>
        <div class="card" style="padding:1rem 1.25rem;display:flex;align-items:center;gap:.85rem">
          <div style="width:40px;height:40px;border-radius:10px;background:<%= s.bg %>;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="fa-solid <%= s.icon %>" style="color:<%= s.color %>"></i>
          </div>
          <div>
            <div style="font-size:1.3rem;font-weight:800"><%= s.val %></div>
            <div style="font-size:.72rem;color:var(--text-muted);font-weight:600"><%= s.label %></div>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Products table -->
    <% if (products.length === 0) { %>
      <div class="card" style="padding:3rem;text-align:center">
        <i class="fa-solid fa-box-open" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
        <h3 style="font-size:1rem;color:var(--text-muted);font-weight:500">No products yet</h3>
        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.35rem">Upload PDFs, templates, ebooks, or any digital download to sell.</p>
        <button class="btn btn-primary btn-sm" style="margin-top:1rem" onclick="openCreate()">Add Your First Product</button>
      </div>
    <% } else { %>
      <div class="card" style="padding:0;overflow:hidden;margin-bottom:1.5rem">
        <div style="overflow-x:auto">
          <table class="owner-table">
            <thead><tr>
              <th style="width:44px"></th>
              <th>Product</th>
              <th>Price</th>
              <th>File</th>
              <th>Sales</th>
              <th>Downloads</th>
              <th>Revenue</th>
              <th>Status</th>
              <th>Actions</th>
            </tr></thead>
            <tbody>
              <% products.forEach(prod => { %>
                <tr>
                  <!-- Thumbnail -->
                  <td style="padding:.6rem .75rem">
                    <% if (prod.preview_image) { %>
                      <img src="<%= prod.preview_image %>" style="width:56px;height:32px;border-radius:5px;object-fit:cover" />
                    <% } else { %>
                      <div style="width:56px;height:32px;border-radius:5px;background:linear-gradient(135deg,#0F172A,#1E3A5F);display:flex;align-items:center;justify-content:center">
                        <i class="fa-solid fa-<%= prod.file_type==='PDF'?'file-pdf':prod.file_type==='ZIP'?'file-zipper':'file-arrow-down' %>" style="font-size:.75rem;color:rgba(255,255,255,.7)"></i>
                      </div>
                    <% } %>
                  </td>
                  <!-- Title + tags -->
                  <td style="max-width:220px">
                    <div style="font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= prod.title %></div>
                    <% if (prod.description) { %>
                      <div style="font-size:.75rem;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px"><%- prod.description.replace(/<[^>]+>/g,'') %></div>
                    <% } %>
                    <% if (prod.tags) { %>
                      <div style="margin-top:.25rem;display:flex;gap:.25rem;flex-wrap:wrap">
                        <% prod.tags.split(',').slice(0,3).forEach(t => { %><span class="prod-tag"><%= t.trim() %></span><% }) %>
                      </div>
                    <% } %>
                  </td>
                  <!-- Price -->
                  <td>
                    <% if (prod.original_price > 0 && prod.original_price > prod.price) { %>
                      <span class="price-was"><%= formatUSD(prod.original_price) %></span><br>
                    <% } %>
                    <span style="font-weight:800;color:<%= prod.price>0?'var(--primary)':'var(--success)' %>">
                      <%= prod.price > 0 ? formatUSD(prod.price) : 'Free' %>
                    </span>
                    <% if (prod.original_price > 0 && prod.original_price > prod.price) { %>
                      <span class="price-discount-badge">-<%= Math.round((1-prod.price/prod.original_price)*100) %>%</span>
                    <% } %>
                  </td>
                  <!-- File info -->
                  <td>
                    <% if (prod.file_type) { %>
                      <span class="file-badge" style="background:#EFF6FF;color:var(--primary)"><i class="fa-solid fa-file"></i> <%= prod.file_type %></span>
                    <% } %>
                    <% if (prod.file_size > 0) { %>
                      <div style="font-size:.7rem;color:var(--text-muted);margin-top:.2rem"><%= (prod.file_size/1024/1024).toFixed(1) %> MB</div>
                    <% } %>
                    <% if (!prod.file_url) { %><span style="font-size:.75rem;color:#F59E0B">No file</span><% } %>
                  </td>
                  <!-- Sales -->
                  <td style="font-weight:700"><%= prod.sale_count || 0 %></td>
                  <!-- Downloads -->
                  <td style="color:var(--text-muted)"><%= prod.download_count || 0 %></td>
                  <!-- Revenue -->
                  <td style="font-weight:700;color:var(--success)"><%= formatUSD(prod.total_revenue || 0) %></td>
                  <!-- Status -->
                  <td>
                    <form action="/communities/<%= community.slug %>/products/<%= prod.id %>/toggle" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-sm" style="font-size:.72rem;padding:.3rem .7rem;background:<%= prod.is_active?'#F0FDF4':'#F8FAFC' %>;color:<%= prod.is_active?'#16A34A':'#94A3B8' %>;border:1px solid <%= prod.is_active?'#86EFAC':'var(--border)' %>">
                        <span class="status-dot" style="background:<%= prod.is_active?'#16A34A':'#CBD5E1' %>"></span>
                        <%= prod.is_active ? 'Active' : 'Hidden' %>
                      </button>
                    </form>
                  </td>
                  <!-- Actions -->
                  <td>
                    <div style="display:flex;gap:.35rem;flex-wrap:wrap">
                      <button class="btn btn-sm btn-outline" style="font-size:.72rem;padding:.3rem .65rem"
                              onclick="openEdit(<%= JSON.stringify(prod) %>)" title="Edit">
                        <i class="fa-solid fa-pen"></i>
                      </button>
                      <button class="btn btn-sm btn-outline" style="font-size:.72rem;padding:.3rem .65rem"
                              onclick="shareProduct('<%= prod.id %>','<%= encodeURIComponent(prod.title) %>')" title="Share">
                        <i class="fa-solid fa-share-nodes"></i>
                      </button>
                      <a href="/products/<%= prod.id %>" class="btn btn-sm btn-outline" style="font-size:.72rem;padding:.3rem .65rem" title="View landing page" target="_blank">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i>
                      </a>
                      <% if (prod.file_url) { %>
                        <a href="/products/<%= prod.id %>/download" class="btn btn-sm btn-outline" style="font-size:.72rem;padding:.3rem .65rem" title="Download">
                          <i class="fa-solid fa-download"></i>
                        </a>
                      <% } %>
                      <form action="/communities/<%= community.slug %>/products/<%= prod.id %>/delete" method="POST"
                            onsubmit="return confirm('Permanently delete \'<%= prod.title %>\'? This cannot be undone.')">
                        <button class="btn btn-sm" style="font-size:.72rem;padding:.3rem .65rem;background:#FEE2E2;color:#DC2626;border:1px solid #FECACA" title="Delete">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  <!-- ══════════════════════════════════════════════════
       BUYER / PUBLIC VIEW
  ══════════════════════════════════════════════════ -->
  <% } else { %>

    <!-- Search + filter bar -->
    <div style="display:flex;gap:.75rem;margin-bottom:1.5rem;flex-wrap:wrap;align-items:center">
      <div style="position:relative;flex:1;min-width:200px">
        <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-size:.82rem"></i>
        <input type="text" id="prodSearch" placeholder="Search products…" oninput="filterProducts()"
               class="form-input" style="padding-left:2.2rem;font-size:.88rem" />
      </div>
      <select id="prodFilter" onchange="filterProducts()" class="form-input" style="width:auto;font-size:.88rem">
        <option value="all">All Products</option>
        <option value="free">Free</option>
        <option value="paid">Paid</option>
        <option value="owned">My Downloads</option>
      </select>
    </div>

    <% const visibleProducts = products.filter(p => p.is_active); %>
    <% if (visibleProducts.length === 0) { %>
      <div class="card" style="padding:3rem;text-align:center">
        <i class="fa-solid fa-box-open" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
        <h3 style="font-size:1rem;color:var(--text-muted);font-weight:500">No products available yet</h3>
        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.35rem">Check back soon — the creator is working on something great.</p>
      </div>
    <% } else { %>
      <div id="productGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:1.25rem">
        <% visibleProducts.forEach(prod => { %>
          <div class="prod-card"
               data-title="<%= prod.title.toLowerCase() %>"
               data-price="<%= prod.price > 0 ? 'paid' : 'free' %>"
               data-owned="<%= prod.isPurchased || prod.price==0 ? 'yes' : 'no' %>">

            <!-- Cover / placeholder (16:9) -->
            <% if (prod.preview_image) { %>
              <img src="<%= prod.preview_image %>" alt="<%= prod.title %>" class="prod-img" />
            <% } else { %>
              <div class="prod-img-placeholder" style="background:<%
                const gradients = ['linear-gradient(135deg,#0F172A,#1E3A5F)','linear-gradient(135deg,#1D4ED8,#7C3AED)','linear-gradient(135deg,#065F46,#0891B2)','linear-gradient(135deg,#92400E,#B45309)','linear-gradient(135deg,#1E1B4B,#4C1D95)'];
                print(gradients[prod.id % gradients.length]);
              %>">
                <i class="fa-solid fa-<%= prod.file_type==='PDF'?'file-pdf':prod.file_type==='ZIP'?'file-zipper':prod.file_type==='DOCX'||prod.file_type==='DOC'?'file-word':'file-arrow-down' %>" style="color:rgba(255,255,255,.75)"></i>
              </div>
            <% } %>

            <!-- Ribbon badges -->
            <% if (prod.isPurchased) { %>
              <div style="position:absolute;top:.65rem;right:.65rem;background:#10B981;color:#fff;font-size:.68rem;font-weight:700;padding:.2rem .6rem;border-radius:20px"><i class="fa-solid fa-check"></i> Owned</div>
            <% } else if (prod.price == 0) { %>
              <div style="position:absolute;top:.65rem;right:.65rem;background:#F0FDF4;color:#16A34A;font-size:.68rem;font-weight:700;padding:.2rem .6rem;border-radius:20px;border:1px solid #86EFAC">Free</div>
            <% } else if (prod.original_price > 0 && prod.original_price > prod.price) { %>
              <div style="position:absolute;top:.65rem;right:.65rem;background:#FEF2F2;color:#DC2626;font-size:.68rem;font-weight:700;padding:.2rem .6rem;border-radius:20px;border:1px solid #FECACA">
                -<%= Math.round((1-prod.price/prod.original_price)*100) %>% OFF
              </div>
            <% } %>

            <div class="prod-body">
              <!-- File type badge -->
              <% if (prod.file_type) { %>
                <span class="file-badge" style="background:#EFF6FF;color:var(--primary);align-self:flex-start">
                  <i class="fa-solid fa-file"></i> <%= prod.file_type %>
                  <% if (prod.file_size > 0) { %> · <%= (prod.file_size/1024/1024).toFixed(1) %>MB<% } %>
                </span>
              <% } %>

              <h3 style="font-size:.97rem;font-weight:700;margin:0;line-height:1.3"><%= prod.title %></h3>

              <% if (prod.description) { %>
                <p style="font-size:.8rem;color:var(--text-muted);margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.5"><%- prod.description.replace(/<[^>]+>/g,' ').replace(/\s+/g,' ').trim() %></p>
              <% } %>

              <!-- Tags -->
              <% if (prod.tags) { %>
                <div style="display:flex;gap:.3rem;flex-wrap:wrap;margin-top:.1rem">
                  <% prod.tags.split(',').slice(0,4).forEach(t => { %><span class="prod-tag"><%= t.trim() %></span><% }) %>
                </div>
              <% } %>

              <!-- Access note -->
              <% if (prod.access_type === 'members_only') { %>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:auto"><i class="fa-solid fa-users"></i> Members only</div>
              <% } else if (prod.access_type === 'plan_only') { %>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:auto"><i class="fa-solid fa-lock"></i> Specific plan required</div>
              <% } %>
            </div>

            <div class="prod-foot">
              <div>
                <% if (prod.original_price > 0 && prod.original_price > prod.price) { %>
                  <div style="display:flex;align-items:center;gap:.4rem">
                    <span class="price-was"><%= formatUSD(prod.original_price) %></span>
                  </div>
                <% } %>
                <span style="font-weight:800;font-size:1.1rem;color:<%= prod.price>0?'var(--primary)':'var(--success)' %>">
                  <%= prod.price > 0 ? formatUSD(prod.price) : 'Free' %>
                </span>
              </div>
              <div style="display:flex;gap:.4rem">
                <button class="btn btn-sm btn-outline" style="font-size:.78rem"
                        onclick="openDetail(<%= JSON.stringify(prod) %>)">
                  <i class="fa-solid fa-eye"></i> Details
                </button>
                <% if (prod.isPurchased || prod.price == 0) { %>
                  <% if (prod.file_url) { %>
                    <a href="/products/<%= prod.id %>/download" class="btn btn-sm" style="background:var(--success);color:#fff;font-size:.78rem">
                      <i class="fa-solid fa-download"></i> Download
                    </a>
                  <% } %>
                <% } else if (!currentUser) { %>
                  <a href="/auth/login" class="btn btn-primary btn-sm" style="font-size:.78rem">Sign in to buy</a>
                <% } else { %>
                  <button class="btn btn-primary btn-sm" style="font-size:.78rem"
                          onclick="openBuy(<%= JSON.stringify(prod) %>)">
                    <i class="fa-solid fa-shopping-cart"></i> Buy
                  </button>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="noResults" style="display:none;padding:3rem;text-align:center;color:var(--text-muted)">
        <i class="fa-solid fa-magnifying-glass" style="font-size:2rem;display:block;margin-bottom:.75rem;opacity:.3"></i>
        No products match your search.
      </div>
    <% } %>
  <% } %>
</div>

<!-- ══════════════════════════════════════════════════════════
     CREATE PRODUCT MODAL (owner)
══════════════════════════════════════════════════════════ -->
<% if (isOwner) { %>
<div class="modal-overlay" id="createProductModal">
  <div class="modal-box" style="max-width:620px;max-height:92vh;overflow-y:auto">
    <div class="modal-head">
      <h2 class="modal-title"><i class="fa-solid fa-box" style="color:var(--primary)"></i> New Product</h2>
      <button type="button" class="modal-close" onclick="closeCreate()"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form action="/communities/<%= community.slug %>/products" method="POST" enctype="multipart/form-data"
          style="display:flex;flex-direction:column;gap:1.1rem;padding:0 1.5rem 1.5rem">

      <!-- Title -->
      <div class="form-group" style="margin:0">
        <label class="form-label">Product Title *</label>
        <input type="text" name="title" class="form-input" placeholder="e.g. Ultimate Marketing Checklist PDF" required />
      </div>

      <!-- Description (RTE) -->
      <div class="form-group" style="margin:0">
        <label class="form-label">Description <span style="font-weight:400;color:var(--text-muted)">(what's inside?)</span></label>
        <textarea name="description" id="createDescTA" data-rte rows="4"
                  placeholder="Describe what buyers will get — problems it solves, what's included…"></textarea>
      </div>

      <!-- Prices -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Sale Price (USD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:700">$</span>
            <input type="number" name="price" class="form-input" placeholder="0.00" min="0" step="0.01" style="padding-left:1.75rem" />
          </div>
          <p style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem">Leave $0.00 for free</p>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Regular Price <span style="font-weight:400;color:var(--text-muted)">(optional)</span></label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:700">$</span>
            <input type="number" name="original_price" class="form-input" placeholder="0.00" min="0" step="0.01" style="padding-left:1.75rem" />
          </div>
          <p style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem">Shows as strikethrough if &gt; Sale Price</p>
        </div>
      </div>

      <!-- Access -->
      <div class="form-group" style="margin:0">
        <label class="form-label">Who Can Buy</label>
        <select name="access_type" class="form-input">
          <option value="anyone">Anyone</option>
          <option value="members_only">Members Only</option>
          <option value="plan_only">Specific Plan Only</option>
        </select>
      </div>

      <!-- Tags -->
      <div class="form-group" style="margin:0">
        <label class="form-label">Tags <span style="font-weight:400;color:var(--text-muted)">(comma separated)</span></label>
        <input type="text" name="tags" class="form-input" placeholder="PDF, Template, Marketing, Checklist" />
      </div>

      <!-- File upload -->
      <div style="padding:1rem;border:2px dashed var(--border);border-radius:10px;background:#FAFBFF">
        <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem">
          <i class="fa-solid fa-file-arrow-up" style="color:var(--primary)"></i>
          <span style="font-size:.85rem;font-weight:700">Product File</span>
          <span style="font-size:.75rem;color:var(--text-muted)">(PDF, ZIP, DOCX, XLS, PPTX…)</span>
        </div>
        <input type="file" name="product_file" class="form-input" id="createFileInput" style="font-size:.82rem"
               onchange="showFileInfo(this,'createFileInfo')" />
        <div id="createFileInfo" style="margin-top:.5rem;font-size:.75rem;color:var(--success);display:none"></div>
        <div class="file-block-warn" style="display:none;margin-top:.5rem;padding:.5rem .75rem;background:#FEF2F2;border-radius:7px;font-size:.75rem;color:#DC2626">
          <i class="fa-solid fa-ban"></i> Video files cannot be uploaded as products. Use the <strong>Courses</strong> feature instead.
        </div>
      </div>

      <!-- Cover image with dimension presets -->
      <div class="form-group" style="margin:0">
        <label class="form-label">Cover Image <span style="font-weight:400;color:var(--text-muted)">(optional)</span></label>

        <!-- Dimension preset picker -->
        <div style="margin-bottom:.75rem">
          <div style="font-size:.72rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem">Choose format for best results:</div>
          <div class="dim-presets" id="createDimPresets" style="display:flex;flex-wrap:wrap;gap:.4rem">
            <button type="button" class="dim-btn active" data-w="1280" data-h="720" data-label="1280×720 px" data-ratio="16/9" data-use="Product page &amp; general sharing" onclick="selectDim(this,'createCoverWrap','createDimHint')">
