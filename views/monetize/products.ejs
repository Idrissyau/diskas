    <input type="file" name="product_file" class="form-input" style="font-size:.8rem" onchange="showFileInfo(this,'editFileInfo')" />
    <div id="editFileInfo" style="margin-top:.4rem;font-size:.75rem;color:var(--success);display:none"></div>
    <div class="file-block-warn" style="display:none;margin-top:.5rem;padding:.5rem .75rem;background:#FEF2F2;border-radius:7px;font-size:.75rem;color:#DC2626">
      <i class="fa-solid fa-ban"></i> Video files cannot be uploaded. Use Courses instead.
    </div>
  </div>

  <div class="form-group" style="margin:0">
    <label class="form-label">Cover Image</label>
    <div style="margin-bottom:.65rem">
      <div style="font-size:.72rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.45rem">Choose format for best results:</div>
      <div style="display:flex;flex-wrap:wrap;gap:.4rem" id="editDimPresets">
        <button type="button" class="dim-btn active" data-w="1280" data-h="720" onclick="selectDim(this,'editCoverWrap','editDimHint')">
          <span class="dim-tag">⭐ 16:9</span><span class="dim-name">1280×720</span><span class="dim-desc">General / Landing page</span>
        </button>
        <button type="button" class="dim-btn" data-w="1200" data-h="630" onclick="selectDim(this,'editCoverWrap','editDimHint')">
          <span class="dim-tag">OG</span><span class="dim-name">1200×630</span><span class="dim-desc">Facebook / LinkedIn</span>
        </button>
        <button type="button" class="dim-btn" data-w="1080" data-h="1080" onclick="selectDim(this,'editCoverWrap','editDimHint')">
          <span class="dim-tag">1:1</span><span class="dim-name">1080×1080</span><span class="dim-desc">Instagram / Square</span>
        </button>
        <button type="button" class="dim-btn" data-w="1080" data-h="1920" onclick="selectDim(this,'editCoverWrap','editDimHint')">
          <span class="dim-tag">Story</span><span class="dim-name">1080×1920</span><span class="dim-desc">Stories / Reels</span>
        </button>
        <button type="button" class="dim-btn" data-w="1000" data-h="1500" onclick="selectDim(this,'editCoverWrap','editDimHint')">
          <span class="dim-tag">Pin</span><span class="dim-name">1000×1500</span><span class="dim-desc">Pinterest / Portrait</span>
        </button>
      </div>
      <div id="editDimHint" class="dim-hint">
        <i class="fa-solid fa-crop-simple"></i> <strong>Recommended: 1280×720 px (16:9)</strong> — Best for product page &amp; general sharing
      </div>
    </div>
    <div class="prod-cover-wrap" id="editCoverWrap">
      <div class="placeholder-inner" ${prod.preview_image?'style="display:none"':''}>
        <i class="fa-solid fa-image" style="font-size:1.75rem;color:#CBD5E1"></i>
        <span style="font-size:.8rem;color:var(--text-muted)">Click to replace cover</span>
      </div>
      <img id="editImgPrev" src="${esc(prod.preview_image||'')}" alt="" class="placed" style="${coverHasImg}" />
      <input type="file" name="preview_image" accept="image/*" onchange="previewCover(this,'editImgPrev','editCoverWrap')" />
    </div>
  </div>

  <div class="modal-footer-btns">
    <button type="button" class="btn btn-outline btn-sm" onclick="closeEdit()">Cancel</button>
    <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
  </div>
</form>`;

  // Init RTE on the freshly-created textarea
  const ta = document.getElementById('editDescTA');
  if (ta && window.initRTE) initRTE(ta);

  document.getElementById('editProductModal').classList.add('open');
}
function closeEdit() { document.getElementById('editProductModal').classList.remove('open'); }
document.getElementById('editProductModal')?.addEventListener('click', e => { if(e.target===document.getElementById('editProductModal')) closeEdit(); });

/* ─────────────── Buyer: Detail modal ─────────────── */
function openDetail(prod) {
  document.getElementById('detailTitle').textContent = prod.title;
  const isOwned = prod.isPurchased || prod.price == 0;
  const fileInfo = prod.file_type
    ? `<span style="font-size:.75rem;background:#EFF6FF;color:var(--primary);padding:.2rem .6rem;border-radius:5px;font-weight:700"><i class="fa-solid fa-file"></i> ${esc(prod.file_type)}${prod.file_size>0?` · ${(prod.file_size/1024/1024).toFixed(1)} MB`:''}</span>`
    : '';
  const pct = discountPct(prod.original_price, prod.price);
  const priceHtml = pct > 0
    ? `<span class="price-was">$${parseFloat(prod.original_price).toFixed(2)}</span>
       <span style="font-size:1.6rem;font-weight:800;color:var(--primary)">$${parseFloat(prod.price).toFixed(2)}</span>
       <span class="price-discount-badge">-${pct}%</span>`
    : `<span style="font-size:1.6rem;font-weight:800;color:${prod.price>0?'var(--primary)':'var(--success)'}">` +
      (prod.price>0?'$'+parseFloat(prod.price).toFixed(2):'Free') + `</span>`;

  document.getElementById('detailBody').innerHTML = `
    ${prod.preview_image ? `<img src="${esc(prod.preview_image)}" style="width:100%;aspect-ratio:16/9;object-fit:cover" />` : ''}
    <div style="padding:1.5rem;display:flex;flex-direction:column;gap:1rem">
      <div style="display:flex;align-items:center;gap:.65rem;flex-wrap:wrap">
        ${fileInfo}
        ${prod.tags ? prod.tags.split(',').slice(0,5).map(t=>`<span style="font-size:.72rem;padding:.15rem .55rem;border-radius:20px;background:#F1F5F9;color:var(--text-muted)">${esc(t.trim())}</span>`).join('') : ''}
      </div>
      ${prod.description ? `<div class="rich-content" style="font-size:.9rem;line-height:1.7;color:var(--body)">${prod.description}</div>` : ''}
      <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem;background:#F8FAFC;border-radius:10px;flex-wrap:wrap;gap:.75rem">
        <div>${priceHtml}
          ${prod.access_type!=='anyone'?`<div style="font-size:.75rem;color:var(--text-muted);margin-top:.2rem"><i class="fa-solid fa-lock"></i> ${prod.access_type==='members_only'?'Members only':'Plan required'}</div>`:''}
        </div>
        <div style="display:flex;gap:.5rem">
          ${isOwned && prod.file_url
            ? `<a href="/products/${prod.id}/download" class="btn btn-primary" style="font-size:.85rem"><i class="fa-solid fa-download"></i> Download</a>`
            : !isOwned
              ? `<button class="btn btn-primary" style="font-size:.85rem" onclick="closeDetail();openBuy(${JSON.stringify(prod).replace(/"/g,'&quot;')})"><i class="fa-solid fa-shopping-cart"></i> Buy Now</button>`
