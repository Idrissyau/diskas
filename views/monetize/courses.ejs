<div class="container" style="max-width:960px;padding:2rem 1.25rem">

  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem">
    <div>
      <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.25rem">
        <a href="/communities/<%= community.slug %>" style="color:var(--text-muted)"><i class="fa-solid fa-arrow-left"></i></a>
        <h1 style="font-size:1.4rem;font-weight:800">Courses</h1>
      </div>
      <p style="color:var(--text-muted);font-size:.88rem;padding-left:1.75rem"><%= community.name %></p>
    </div>
    <% if (isOwner) { %>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('createCourseModal').classList.add('open')">
        <i class="fa-solid fa-plus"></i> New Course
      </button>
    <% } %>
  </div>

  <!-- Course Grid -->
  <% if (courses.length === 0) { %>
    <div class="card" style="padding:3rem;text-align:center">
      <i class="fa-solid fa-graduation-cap" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
      <h3 style="font-size:1rem;color:var(--text-muted);font-weight:500">No courses yet</h3>
      <% if (isOwner) { %>
        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.35rem">Create your first course to teach and earn from your community.</p>
        <button class="btn btn-primary btn-sm" style="margin-top:1rem" onclick="document.getElementById('createCourseModal').classList.add('open')">Create Course</button>
      <% } else { %>
        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.35rem">No courses available yet. Check back soon!</p>
      <% } %>
    </div>
  <% } else { %>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem">
      <% courses.forEach(course => { %>
        <div class="card" style="padding:0;overflow:hidden;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,.1)'" onmouseout="this.style.boxShadow=''">
          <% if (course.thumbnail) { %>
            <img src="<%= course.thumbnail %>" alt="<%= course.title %>" style="width:100%;height:160px;object-fit:cover" />
          <% } else { %>
            <div style="height:120px;background:linear-gradient(135deg,#0EA5E9,#6366F1);display:flex;align-items:center;justify-content:center">
              <i class="fa-solid fa-graduation-cap" style="font-size:2.5rem;color:rgba(255,255,255,.7)"></i>
            </div>
          <% } %>
          <div style="padding:1.25rem">
            <h3 style="font-size:.98rem;font-weight:700;margin-bottom:.35rem;line-height:1.3"><%= course.title %></h3>
            <% if (course.description) { %>
              <p style="font-size:.82rem;color:var(--text-muted);margin-bottom:.75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= course.description %></p>
            <% } %>
            <div style="display:flex;align-items:center;gap:.75rem;font-size:.78rem;color:var(--text-muted);margin-bottom:1rem">
              <span><i class="fa-solid fa-layer-group"></i> <%= course.module_count %> modules</span>
              <span><i class="fa-solid fa-play-circle"></i> <%= course.lesson_count %> lessons</span>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem">
              <% if (course.billing_type === 'free' || course.billing_type === 'included') { %>
                <span style="font-weight:700;color:var(--success)">Free / Included</span>
              <% } else { %>
                <span style="font-weight:700;font-size:1.05rem;color:var(--primary)"><%= formatUSD(course.price) %></span>
              <% } %>
              <div style="display:flex;gap:.4rem">
                <a href="/communities/<%= community.slug %>/courses/<%= course.id %>" class="btn btn-outline btn-sm">View</a>
                <% if (isOwner) { %>
                  <a href="/communities/<%= community.slug %>/courses/<%= course.id %>/edit" class="btn btn-sm" style="background:#F1F5F9;color:var(--navy)">Edit</a>
                <% } %>
              </div>
            </div>
            <% if (!course.is_published) { %>
              <div style="margin-top:.5rem;font-size:.72rem;background:#FFF7ED;color:#C2410C;padding:.25rem .5rem;border-radius:5px;display:inline-block;font-weight:600">
                <i class="fa-solid fa-eye-slash"></i> Draft
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Create Course Modal -->
<% if (isOwner) { %>
<div class="modal-overlay" id="createCourseModal">
  <div class="modal-box" style="max-width:520px">
    <div class="modal-head">
      <h2 class="modal-title">Create New Course</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('createCourseModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form action="/communities/<%= community.slug %>/courses" method="POST" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:1rem">
      <div class="form-group" style="margin:0">
        <label class="form-label">Course Title *</label>
        <input type="text" name="title" class="form-input" placeholder="e.g. Complete Marketing Masterclass" required />
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-input" rows="3" placeholder="What will students learn?"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Access Type</label>
          <select name="billing_type" class="form-input">
            <option value="included">Included in membership</option>
            <option value="free">Free for all</option>
            <option value="one_time">Separate purchase</option>
          </select>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Price (if separate)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600">$</span>
            <input type="number" name="price" class="form-input" placeholder="0.00" min="0" step="0.01" style="padding-left:1.75rem" />
          </div>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Thumbnail Image</label>
        <input type="file" name="thumbnail" class="form-input" accept="image/*" style="font-size:.85rem" />
      </div>
      <div class="modal-footer-btns">
        <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('createCourseModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Create & Build</button>
      </div>
    </form>
  </div>
</div>
<script>
document.getElementById('createCourseModal').addEventListener('click', e => {
  if (e.target === document.getElementById('createCourseModal')) document.getElementById('createCourseModal').classList.remove('open');
});
</script>
<% } %>
