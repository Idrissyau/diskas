<%
/*
 * Partial: _lesson-form.ejs
 * Variables: community, course, mod, lesson (null for new), plans, action
 */
const l = lesson || {};
const isNew = !lesson;
const typeList = ['text','video','file','link','mixed'];
%>
<form action="<%= action %>" method="POST" enctype="multipart/form-data"
      style="display:flex;flex-direction:column;gap:.85rem;margin-top:.85rem">

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
    <div class="form-group" style="margin:0">
      <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Lesson Title *</label>
      <input type="text" name="title" class="form-input" value="<%= l.title||'' %>" placeholder="Lesson title" required style="font-size:.84rem" />
    </div>
    <div class="form-group" style="margin:0">
      <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Type</label>
      <select name="lesson_type" class="form-input lesson-type-sel" style="font-size:.84rem">
        <% typeList.forEach(t => { %><option value="<%= t %>" <%= (l.lesson_type===t)?'selected':'' %>><%= t.charAt(0).toUpperCase()+t.slice(1) %></option><% }) %>
      </select>
    </div>
  </div>

  <!-- Video fields -->
  <div class="video-section" style="border:1.5px solid #BFDBFE;border-radius:10px;padding:1rem;background:#F8FAFF;display:<%= (l.lesson_type==='video'||l.lesson_type==='mixed')?'flex':'none' %>;flex-direction:column;gap:.8rem">
    <div style="font-size:.78rem;font-weight:700;color:var(--primary);display:flex;align-items:center;gap:.5rem">
      <i class="fa-solid fa-video"></i> Video
      <span style="font-weight:400;color:var(--text-muted)">— No direct uploads. Paste a URL from YouTube, Vimeo, Bunny, Cloudflare, etc.</span>
    </div>
    <div class="form-group" style="margin:0">
      <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Video URL</label>
      <input type="url" name="video_url" class="form-input video-url-input" value="<%= l.video_url||'' %>"
             placeholder="https://youtu.be/... or https://vimeo.com/..." style="font-size:.84rem" />
      <div class="video-detect-status" style="font-size:.72rem;margin-top:.25rem;display:none"></div>
    </div>
    <div class="video-preview-wrap" style="display:<%= l.video_embed_url?'block':'none' %>;aspect-ratio:16/9;max-height:180px;border-radius:7px;overflow:hidden;background:#000">
      <iframe class="video-preview-iframe" src="<%= l.video_embed_url||'' %>" frameborder="0" allowfullscreen style="width:100%;height:100%;border:none"></iframe>
    </div>
    <div class="form-group" style="margin:0">
      <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Or paste Embed Code <span style="font-weight:400">(optional)</span></label>
      <textarea name="video_embed_code" class="form-input" rows="2" placeholder='<iframe src="https://..." ...></iframe>' style="font-size:.75rem;font-family:monospace"><%= l.video_embed_code||'' %></textarea>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.65rem">
      <div class="form-group" style="margin:0">
        <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Duration (e.g. 12:34)</label>
        <input type="text" name="video_duration" class="form-input" value="<%= l.video_duration||'' %>" placeholder="12:34" style="font-size:.84rem" />
      </div>
      <div class="form-group" style="margin:0">
        <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Custom Thumbnail</label>
        <input type="file" name="video_thumbnail" class="form-input" accept="image/*" style="font-size:.72rem" />
      </div>
    </div>
    <div style="display:flex;gap:1.25rem">
      <label style="display:flex;align-items:center;gap:.35rem;font-size:.8rem;cursor:pointer"><input type="checkbox" name="autoplay" value="1" <%= l.autoplay?'checked':'' %> /> Autoplay</label>
      <label style="display:flex;align-items:center;gap:.35rem;font-size:.8rem;cursor:pointer"><input type="checkbox" name="download_allowed" value="1" <%= l.download_allowed?'checked':'' %> /> Allow Download</label>
    </div>
  </div>

  <!-- File fields -->
  <div class="file-section" style="display:<%= (l.lesson_type==='file'||l.lesson_type==='mixed')?'flex':'none' %>;flex-direction:column;gap:.7rem">
    <div class="form-group" style="margin:0">
      <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Downloadable File (PDF, ZIP, doc…)</label>
      <input type="file" name="lesson_file" class="form-input lesson-file-input" style="font-size:.75rem" />
      <div class="file-upload-error" style="font-size:.72rem;color:#DC2626;margin-top:.25rem;display:none"></div>
      <% if (l.file_url) { %>
        <div style="font-size:.72rem;color:var(--success);margin-top:.25rem"><i class="fa-solid fa-check"></i> File: <%= (l.file_url||'').split('/').pop() %></div>
      <% } %>
    </div>
  </div>

  <!-- Link fields -->
  <div class="link-section" style="display:<%= (l.lesson_type==='link'||l.lesson_type==='mixed')?'flex':'none' %>;flex-direction:column;gap:.7rem">
    <div class="form-group" style="margin:0">
      <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">External Link URL</label>
      <input type="url" name="external_link" class="form-input" value="<%= l.external_link||'' %>" placeholder="https://..." style="font-size:.84rem" />
    </div>
  </div>

  <!-- Text content -->
  <div class="form-group" style="margin:0">
    <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Content / Notes</label>
    <textarea name="content" class="form-input" rows="3" placeholder="Lesson text, notes…" style="font-size:.84rem"><%= l.content||'' %></textarea>
  </div>

  <!-- Advanced -->
  <details>
    <summary style="font-size:.75rem;font-weight:600;color:var(--text-muted);cursor:pointer;list-style:none"><i class="fa-solid fa-sliders"></i> Advanced Settings</summary>
    <div style="display:flex;flex-direction:column;gap:.7rem;margin-top:.7rem">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.65rem">
        <div class="form-group" style="margin:0">
          <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Duration (mins)</label>
          <input type="number" name="duration_mins" class="form-input" value="<%= l.duration_mins||0 %>" min="0" style="font-size:.84rem" />
        </div>
        <div class="form-group" style="margin:0">
          <label style="font-size:.75rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:.2rem">Required Plan</label>
          <select name="required_plan_id" class="form-input" style="font-size:.84rem">
            <option value="">Any member</option>
            <% plans.forEach(p => { %><option value="<%= p.id %>" <%= (l.required_plan_id==p.id)?'selected':'' %>><%= p.name %></option><% }) %>
          </select>
        </div>
      </div>
      <div style="display:flex;gap:1.25rem;flex-wrap:wrap">
        <label style="display:flex;align-items:center;gap:.35rem;font-size:.8rem;cursor:pointer"><input type="checkbox" name="is_free_preview" value="1" <%= l.is_free_preview?'checked':'' %> /> Free Preview</label>
        <label style="display:flex;align-items:center;gap:.35rem;font-size:.8rem;cursor:pointer"><input type="checkbox" name="completion_tracking" value="1" <%= l.completion_tracking!==0?'checked':'' %> /> Completion Tracking</label>
      </div>
    </div>
  </details>

  <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-start"><i class="fa-solid fa-plus"></i> Add Lesson</button>
</form>
