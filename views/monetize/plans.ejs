<div class="container" style="max-width:800px;padding:2rem 1.25rem">

  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:.5rem">
    <a href="/communities/<%= community.slug %>/settings" style="color:var(--text-muted);font-size:1.1rem"><i class="fa-solid fa-arrow-left"></i></a>
    <div>
      <h1 style="font-size:1.5rem;font-weight:800">Membership Plans</h1>
      <p style="color:var(--text-muted);font-size:.88rem"><%= community.name %></p>
    </div>
    <div style="margin-left:auto;display:flex;gap:.5rem">
      <a href="/communities/<%= community.slug %>/coupons" class="btn btn-outline btn-sm"><i class="fa-solid fa-ticket"></i> Coupons</a>
      <a href="/wallet" class="btn btn-outline btn-sm"><i class="fa-solid fa-wallet"></i> Wallet</a>
    </div>
  </div>

  <p style="color:var(--text-muted);font-size:.88rem;margin-bottom:1.75rem;padding-left:2.2rem">
    Create plans to monetize your community. Members choose a plan at checkout.
    Platform commission: <strong>10%</strong> — you keep <strong>90%</strong>.
  </p>

  <!-- Existing Plans -->
  <% if (plans.length > 0) { %>
    <div style="display:flex;flex-direction:column;gap:1rem;margin-bottom:2rem">
      <% plans.forEach(plan => { %>
        <div class="card" style="padding:1.5rem">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap">
            <div>
              <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem">
                <span style="font-weight:700;font-size:1rem"><%= plan.name %></span>
                <% if (plan.billing_type === 'free') { %>
                  <span class="badge" style="background:#DCFCE7;color:#16A34A">Free</span>
                <% } else { %>
                  <span class="badge badge-admin"><%= plan.billing_type.replace('_',' ') %></span>
                <% } %>
                <span class="badge" style="background:<%= plan.is_active ? '#DCFCE7' : '#F1F5F9' %>;color:<%= plan.is_active ? '#16A34A' : '#64748B' %>">
                  <%= plan.is_active ? 'Active' : 'Inactive' %>
                </span>
              </div>
              <% if (plan.description) { %><p style="color:var(--text-muted);font-size:.88rem;margin-bottom:.35rem"><%= plan.description %></p><% } %>
              <div style="font-size:1.5rem;font-weight:800;color:var(--primary)">
                <%= plan.billing_type === 'free' ? 'Free' : formatUSD(plan.price) %>
                <span style="font-size:.85rem;font-weight:500;color:var(--text-muted)">
                  <% if (plan.billing_type === 'monthly') { %>/month<% } else if (plan.billing_type === 'yearly') { %>/year<% } else if (plan.billing_type === 'lifetime') { %> lifetime<% } %>
                </span>
              </div>
              <% if (plan.trial_days > 0) { %>
                <span style="font-size:.8rem;color:var(--success)"><i class="fa-solid fa-gift"></i> <%= plan.trial_days %>-day free trial</span>
              <% } %>
            </div>
            <div style="display:flex;gap:.5rem;flex-shrink:0">
              <button class="btn btn-outline btn-sm" onclick="openEditPlan(<%= JSON.stringify(plan) %>)">
                <i class="fa-solid fa-pen"></i> Edit
              </button>
              <form action="/communities/<%= community.slug %>/plans/<%= plan.id %>/delete" method="POST"
                    onsubmit="return confirm('Delete this plan? Members on this plan will lose access.')">
                <button class="btn btn-sm" style="background:#FEE2E2;color:#DC2626;border:1px solid #FECACA">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="card" style="padding:2.5rem;text-align:center;margin-bottom:2rem">
      <i class="fa-solid fa-layer-group" style="font-size:2.5rem;color:#CBD5E1;margin-bottom:.75rem;display:block"></i>
      <h3 style="font-size:1rem;color:var(--text-muted);font-weight:500">No plans yet</h3>
      <p style="color:var(--text-muted);font-size:.88rem;margin-top:.35rem">Create your first plan below to start monetizing your community.</p>
    </div>
  <% } %>

  <!-- Create New Plan -->
  <div class="card" style="padding:2rem">
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:1.25rem"><i class="fa-solid fa-plus" style="color:var(--primary)"></i> Add New Plan</h2>
    <form action="/communities/<%= community.slug %>/plans" method="POST" style="display:flex;flex-direction:column;gap:1rem">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Plan Name *</label>
          <input type="text" name="name" class="form-input" placeholder="e.g. Starter, Pro, VIP" maxlength="80" required />
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Billing Type *</label>
          <select name="billing_type" class="form-input" id="billingTypeSelect" onchange="togglePriceField(this.value)">
            <option value="free">Free</option>
            <option value="one_time">One-Time Payment</option>
            <option value="monthly">Monthly Subscription</option>
            <option value="yearly">Yearly Subscription</option>
            <option value="lifetime">Lifetime Access</option>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Description</label>
        <input type="text" name="description" class="form-input" placeholder="What do members get with this plan?" maxlength="200" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem" id="priceRow">
        <div class="form-group" style="margin:0" id="priceField">
          <label class="form-label">Price (USD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600">$</span>
            <input type="number" name="price" class="form-input" placeholder="0.00" min="0" step="0.01" style="padding-left:1.75rem" />
          </div>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Trial Days</label>
          <input type="number" name="trial_days" class="form-input" placeholder="0" min="0" max="90" value="0" />
        </div>
        <div class="form-group" style="margin:0;display:flex;align-items:flex-end">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.88rem;font-weight:600;padding-bottom:.5rem">
            <input type="checkbox" name="is_active" value="1" checked style="width:16px;height:16px" /> Active
          </label>
        </div>
      </div>
      <div>
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Create Plan</button>
      </div>
    </form>
  </div>

  <!-- Checkout Links Info -->
  <% if (plans.length > 0) { %>
    <div class="card" style="padding:1.25rem;margin-top:1.5rem;background:#F0F9FF;border-color:#BAE6FD">
      <h3 style="font-size:.9rem;font-weight:700;color:#0369A1;margin-bottom:.5rem"><i class="fa-solid fa-link"></i> Checkout Links</h3>
      <p style="font-size:.82rem;color:#0369A1;margin-bottom:.75rem">Share these links to let people join your paid community directly.</p>
      <% plans.forEach(plan => { if (plan.is_active && plan.billing_type !== 'free') { %>
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem">
          <code style="font-size:.78rem;background:#E0F2FE;padding:.25rem .6rem;border-radius:6px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
            <%= locals.appUrl %>/checkout/plan/<%= plan.id %>
          </code>
          <button class="btn btn-sm btn-outline" onclick="navigator.clipboard.writeText('<%= locals.appUrl %>/checkout/plan/<%= plan.id %>');this.textContent='Copied!'">Copy</button>
          <span style="font-size:.78rem;color:#0369A1;white-space:nowrap"><%= plan.name %></span>
        </div>
      <% } }) %>
    </div>
  <% } %>
</div>

<!-- Edit Plan Modal -->
<div class="modal-overlay" id="editPlanModal">
  <div class="modal-box" style="max-width:520px">
    <div class="modal-head">
      <h2 class="modal-title">Edit Plan</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('editPlanModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form id="editPlanForm" method="POST" style="display:flex;flex-direction:column;gap:1rem">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Plan Name</label>
          <input type="text" name="name" id="editPlanName" class="form-input" required />
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Billing Type</label>
          <select name="billing_type" id="editBillingType" class="form-input">
            <option value="free">Free</option>
            <option value="one_time">One-Time</option>
            <option value="monthly">Monthly</option>
            <option value="yearly">Yearly</option>
            <option value="lifetime">Lifetime</option>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Description</label>
        <input type="text" name="description" id="editPlanDesc" class="form-input" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Price (USD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600">$</span>
            <input type="number" name="price" id="editPlanPrice" class="form-input" min="0" step="0.01" style="padding-left:1.75rem" />
          </div>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Trial Days</label>
          <input type="number" name="trial_days" id="editTrialDays" class="form-input" min="0" max="90" />
        </div>
      </div>
      <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.88rem;font-weight:600">
        <input type="checkbox" name="is_active" id="editPlanActive" value="1" style="width:16px;height:16px" /> Active
      </label>
      <div class="modal-footer-btns">
        <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('editPlanModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
function togglePriceField(val) {
  document.getElementById('priceField').style.display = val === 'free' ? 'none' : 'block';
}
togglePriceField(document.getElementById('billingTypeSelect').value);

function openEditPlan(plan) {
  document.getElementById('editPlanForm').action = `/communities/<%= community.slug %>/plans/${plan.id}/update`;
  document.getElementById('editPlanName').value   = plan.name;
  document.getElementById('editPlanDesc').value   = plan.description || '';
  document.getElementById('editPlanPrice').value  = plan.price;
  document.getElementById('editBillingType').value = plan.billing_type;
  document.getElementById('editTrialDays').value  = plan.trial_days;
  document.getElementById('editPlanActive').checked = !!plan.is_active;
  document.getElementById('editPlanModal').classList.add('open');
}
document.getElementById('editPlanModal').addEventListener('click', e => {
  if (e.target === document.getElementById('editPlanModal')) document.getElementById('editPlanModal').classList.remove('open');
});
</script>
