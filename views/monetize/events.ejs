<div class="container" style="max-width:960px;padding:2rem 1.25rem">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem">
    <div>
      <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.25rem">
        <a href="/communities/<%= community.slug %>" style="color:var(--text-muted)"><i class="fa-solid fa-arrow-left"></i></a>
        <h1 style="font-size:1.4rem;font-weight:800">Events</h1>
      </div>
      <p style="color:var(--text-muted);font-size:.88rem;padding-left:1.75rem"><%= community.name %></p>
    </div>
    <% if (isOwner) { %>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('createEventModal').classList.add('open')">
        <i class="fa-solid fa-plus"></i> New Event
      </button>
    <% } %>
  </div>

  <% if (events.length === 0) { %>
    <div class="card" style="padding:3rem;text-align:center">
      <i class="fa-solid fa-calendar-days" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
      <h3 style="font-size:1rem;color:var(--text-muted);font-weight:500">No events scheduled</h3>
      <% if (isOwner) { %>
        <button class="btn btn-primary btn-sm" style="margin-top:1rem" onclick="document.getElementById('createEventModal').classList.add('open')">Create Event</button>
      <% } else { %>
        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.35rem">Check back soon for upcoming events!</p>
      <% } %>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:1rem">
      <% events.forEach(ev => { %>
        <div class="card" style="padding:1.5rem;display:flex;gap:1.25rem;align-items:flex-start;flex-wrap:wrap">
          <!-- Date Box -->
          <div style="text-align:center;background:var(--primary);color:#fff;border-radius:10px;padding:.5rem .85rem;flex-shrink:0;min-width:56px">
            <div style="font-size:1.5rem;font-weight:800;line-height:1"><%= new Date(ev.starts_at).getDate() %></div>
            <div style="font-size:.7rem;font-weight:600;text-transform:uppercase"><%= new Date(ev.starts_at).toLocaleString('en-US',{month:'short'}) %></div>
          </div>
          <!-- Info -->
          <div style="flex:1;min-width:0">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:.75rem;flex-wrap:wrap">
              <div>
                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.25rem;flex-wrap:wrap">
                  <h3 style="font-size:1rem;font-weight:700;margin:0"><%= ev.title %></h3>
                  <span class="badge" style="background:#EFF6FF;color:var(--primary);font-size:.7rem"><%= ev.event_type.replace('_',' ') %></span>
                  <% if (ev.is_free) { %><span class="badge" style="background:#F0FDF4;color:#16A34A;font-size:.7rem">Free</span>
                  <% } else { %><span class="badge" style="background:#FFF7ED;color:#C2410C;font-size:.7rem"><%= formatUSD(ev.price) %></span><% } %>
                </div>
                <% if (ev.description) { %><p style="font-size:.85rem;color:var(--text-muted);margin-bottom:.4rem;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical"><%= ev.description %></p><% } %>
                <div style="font-size:.78rem;color:var(--text-muted);display:flex;gap:1rem;flex-wrap:wrap">
                  <span><i class="fa-regular fa-clock"></i> <%= new Date(ev.starts_at).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'}) %></span>
                  <% if (ev.is_online && ev.online_link) { %><span><i class="fa-solid fa-video"></i> Online</span>
                  <% } else if (ev.location) { %><span><i class="fa-solid fa-location-dot"></i> <%= ev.location %></span><% } %>
                  <span><i class="fa-solid fa-users"></i> <%= ev.attendee_count %> registered<% if (ev.max_attendees>0) { %>/<%= ev.max_attendees %><% } %></span>
                </div>
              </div>
              <div style="display:flex;gap:.4rem;flex-shrink:0;align-items:flex-start">
                <% if (currentUser) { %>
                  <% if (ev.isAttending) { %>
                    <form action="/communities/<%= community.slug %>/events/<%= ev.id %>/rsvp" method="POST">
                      <button class="btn btn-sm" style="background:#DCFCE7;color:#16A34A;border:1px solid #86EFAC"><i class="fa-solid fa-check"></i> Attending</button>
                    </form>
                  <% } else { %>
                    <form action="/communities/<%= community.slug %>/events/<%= ev.id %>/rsvp" method="POST">
                      <button class="btn btn-primary btn-sm"><i class="fa-solid fa-calendar-plus"></i> <%= ev.is_free ? 'RSVP' : 'Get Ticket' %></button>
                    </form>
                  <% } %>
                <% } else { %>
                  <a href="/auth/login" class="btn btn-primary btn-sm">Sign in to RSVP</a>
                <% } %>
                <% if (isOwner) { %>
                  <form action="/communities/<%= community.slug %>/events/<%= ev.id %>/delete" method="POST"
                        onsubmit="return confirm('Delete this event?')">
                    <button class="btn btn-sm" style="background:#FEE2E2;color:#DC2626;border:1px solid #FECACA">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
            <% if (ev.is_online && ev.online_link && ev.isAttending) { %>
              <div style="margin-top:.75rem;padding:.5rem .85rem;background:#EFF6FF;border-radius:8px;font-size:.82rem">
                <i class="fa-solid fa-link" style="color:var(--primary)"></i>
                <a href="<%= ev.online_link %>" target="_blank" rel="noopener" style="color:var(--primary);font-weight:600;word-break:break-all"><%= ev.online_link %></a>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Create Event Modal -->
<% if (isOwner) { %>
<div class="modal-overlay" id="createEventModal">
  <div class="modal-box" style="max-width:600px">
    <div class="modal-head">
      <h2 class="modal-title">Create New Event</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('createEventModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form action="/communities/<%= community.slug %>/events" method="POST" style="display:flex;flex-direction:column;gap:1rem">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Event Title *</label>
          <input type="text" name="title" class="form-input" placeholder="e.g. Marketing Masterclass" required />
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Event Type</label>
          <select name="event_type" class="form-input">
            <option value="webinar">Webinar</option>
            <option value="workshop">Workshop</option>
            <option value="coaching">Coaching Call</option>
            <option value="group_call">Group Call</option>
            <option value="masterclass">Masterclass</option>
            <option value="live_class">Live Class</option>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-input" rows="3" placeholder="What will attendees learn or experience?"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Starts At *</label>
          <input type="datetime-local" name="starts_at" class="form-input" required />
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Ends At</label>
          <input type="datetime-local" name="ends_at" class="form-input" />
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Online Link (Zoom, Meet, etc.)</label>
          <input type="url" name="online_link" class="form-input" placeholder="https://zoom.us/j/..." />
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Physical Location</label>
          <input type="text" name="location" class="form-input" placeholder="City, Venue (optional)" />
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem">
        <div class="form-group" style="margin:0">
          <label class="form-label">Ticket Price (USD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600">$</span>
            <input type="number" name="price" class="form-input" placeholder="0.00" min="0" step="0.01" style="padding-left:1.75rem" value="0" />
          </div>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Max Attendees (0=unlimited)</label>
          <input type="number" name="max_attendees" class="form-input" placeholder="0" min="0" value="0" />
        </div>
        <div class="form-group" style="margin:0;display:flex;align-items:flex-end;gap:1rem">
          <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem;cursor:pointer;padding-bottom:.4rem">
            <input type="checkbox" name="is_free" value="1" checked /> Free event
          </label>
          <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem;cursor:pointer;padding-bottom:.4rem">
            <input type="checkbox" name="is_online" value="1" checked /> Online
          </label>
        </div>
      </div>
      <div class="modal-footer-btns">
        <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('createEventModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-calendar-plus"></i> Create Event</button>
      </div>
    </form>
  </div>
</div>
<script>
document.getElementById('createEventModal').addEventListener('click', e => {
  if (e.target === document.getElementById('createEventModal')) document.getElementById('createEventModal').classList.remove('open');
});
</script>
<% } %>
