<div class="container" style="max-width:960px;padding:2rem 1.25rem">

  <!-- Header -->
  <div style="display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:2rem;flex-wrap:wrap">
    <% if (course.thumbnail) { %>
      <img src="<%= course.thumbnail %>" style="width:140px;height:88px;border-radius:10px;object-fit:cover;flex-shrink:0" />
    <% } %>
    <div style="flex:1;min-width:0">
      <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.35rem;flex-wrap:wrap">
        <a href="/communities/<%= community.slug %>/courses" style="color:var(--text-muted);font-size:.85rem"><i class="fa-solid fa-arrow-left"></i> All Courses</a>
        <% if (community.avatar) { %><img src="<%= community.avatar %>" style="width:20px;height:20px;border-radius:50%;margin-left:.25rem" /><% } %>
        <span style="font-size:.8rem;color:var(--text-muted)"><%= community.name %></span>
      </div>
      <h1 style="font-size:1.6rem;font-weight:800;margin-bottom:.4rem"><%= course.title %></h1>
      <% if (course.description) { %><p style="color:var(--text-muted);font-size:.9rem;margin-bottom:.65rem"><%= course.description %></p><% } %>
      <div style="display:flex;gap:1.25rem;font-size:.82rem;color:var(--text-muted);flex-wrap:wrap">
        <span><i class="fa-solid fa-layer-group"></i> <%= modules.length %> modules</span>
        <span><i class="fa-solid fa-play-circle"></i> <%= totalLessons %> lessons</span>
        <% if (hasAccess && totalLessons > 0) { %>
          <span style="color:var(--primary);font-weight:600"><i class="fa-solid fa-chart-simple"></i> <%= completedLessons %>/<%= totalLessons %> completed (<%= Math.round(completedLessons/totalLessons*100) %>%)</span>
        <% } %>
        <% if (course.billing_type === 'included') { %><span style="color:var(--success);font-weight:600"><i class="fa-solid fa-check-circle"></i> Included in membership</span><% } %>
        <% if (course.billing_type === 'free') { %><span style="color:var(--success);font-weight:600"><i class="fa-solid fa-unlock"></i> Free course</span><% } %>
      </div>
    </div>
    <div style="display:flex;gap:.5rem;flex-shrink:0">
      <% if (isOwner) { %>
        <a href="/communities/<%= community.slug %>/courses/<%= course.id %>/edit" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i> Edit Course</a>
      <% } %>
    </div>
  </div>

  <!-- Progress bar (if enrolled) -->
  <% if (hasAccess && totalLessons > 0) { %>
    <div style="height:6px;background:var(--border);border-radius:3px;margin-bottom:1.75rem;overflow:hidden">
      <div style="height:100%;background:var(--primary);border-radius:3px;width:<%= Math.round(completedLessons/totalLessons*100) %>%;transition:width .3s"></div>
    </div>
  <% } %>

  <!-- LOCKED STATE -->
  <% if (!hasAccess) { %>
    <div class="card" style="padding:3rem;text-align:center;border:2px dashed var(--border);margin-bottom:1.5rem">
      <i class="fa-solid fa-lock" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
      <h2 style="font-size:1.2rem;font-weight:700;margin-bottom:.5rem">Join to access this course</h2>
      <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:1.25rem">Become a member of <strong><%= community.name %></strong> to access this course and all other member content.</p>
      <% if (plans && plans.length > 0) { %>
        <div style="display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap">
          <% plans.forEach(p => { %>
            <a href="/checkout/plan/<%= p.id %>" class="btn btn-primary"><i class="fa-solid fa-unlock"></i> Join — <%= formatUSD(p.price) %>/<%= p.billing_type %></a>
          <% }) %>
        </div>
      <% } else { %>
        <a href="/communities/<%= community.slug %>" class="btn btn-primary">View Membership Plans</a>
      <% } %>
    </div>
  <% } %>

  <!-- Module + Lesson list -->
  <div style="display:flex;flex-direction:column;gap:1rem">
    <% modules.forEach((mod, mi) => { %>
      <div class="card" style="padding:0;overflow:hidden">
        <!-- Module header -->
        <div style="padding:1rem 1.5rem;background:#F8FAFC;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem">
          <span style="width:28px;height:28px;background:var(--primary);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;flex-shrink:0"><%= mi+1 %></span>
          <span style="font-weight:700"><%= mod.title %></span>
          <span style="font-size:.78rem;color:var(--text-muted);margin-left:auto"><%= mod.lessons.length %> lesson<%= mod.lessons.length!==1?'s':'' %></span>
        </div>

        <!-- Lessons -->
        <% mod.lessons.forEach((lesson, li) => {
             const isLocked = !hasAccess && !lesson.is_free_preview;
             const lessonUrl = `/communities/${community.slug}/courses/${course.id}/lessons/${lesson.id}`;
             const typeIcons = {video:'fa-play-circle',text:'fa-file-lines',file:'fa-file-arrow-down',link:'fa-external-link-alt',mixed:'fa-layer-group'};
             const typeColors = {video:'var(--primary)',text:'var(--text-muted)',file:'var(--success)',link:'#6366F1',mixed:'#8B5CF6'};
        %>
          <div style="padding:.9rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;transition:background .1s" onmouseover="this.style.background='#F8FAFC'" onmouseout="this.style.background=''">
            <!-- Completion circle -->
            <div style="width:28px;height:28px;border-radius:50%;border:2px solid <%= lesson.completed?'var(--success)':'var(--border)' %>;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:<%= lesson.completed?'#F0FDF4':'#fff' %>">
              <% if (lesson.completed) { %><i class="fa-solid fa-check" style="font-size:.65rem;color:var(--success)"></i>
              <% } else if (isLocked) { %><i class="fa-solid fa-lock" style="font-size:.6rem;color:#94A3B8"></i>
              <% } else { %><span style="font-size:.7rem;color:var(--text-muted)"><%= li+1 %></span><% } %>
            </div>

            <!-- Thumbnail for video lessons -->
            <% if (lesson.lesson_type === 'video' && lesson.video_thumbnail_url) { %>
              <div style="width:64px;height:40px;border-radius:5px;overflow:hidden;flex-shrink:0;position:relative;background:#000">
                <img src="<%= lesson.video_thumbnail_url %>" style="width:100%;height:100%;object-fit:cover;opacity:<%= isLocked?'.4':'1' %>" />
                <% if (!isLocked) { %>
                  <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
                    <i class="fa-solid fa-play" style="font-size:.6rem;color:#fff;background:rgba(0,0,0,.5);padding:.25rem .35rem;border-radius:50%"></i>
                  </div>
                <% } %>
              </div>
            <% } else { %>
              <i class="fa-solid <%= typeIcons[lesson.lesson_type]||'fa-file-lines' %>"
                 style="color:<%= isLocked?'#94A3B8':typeColors[lesson.lesson_type]||'var(--text-muted)' %>;font-size:.88rem;flex-shrink:0"></i>
            <% } %>

            <!-- Info -->
            <div style="flex:1;min-width:0">
              <div style="font-size:.9rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:<%= isLocked?'var(--text-muted)':'' %>">
                <%= lesson.title %>
              </div>
              <div style="font-size:.75rem;color:var(--text-muted);display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.1rem">
                <% if (lesson.video_provider) { %><span><%= lesson.video_provider.charAt(0).toUpperCase()+lesson.video_provider.slice(1) %></span><% } %>
                <% if (lesson.video_duration) { %><span><i class="fa-regular fa-clock"></i> <%= lesson.video_duration %></span><% } else if (lesson.duration_mins > 0) { %><span><%= lesson.duration_mins %> min</span><% } %>
              </div>
            </div>

            <!-- Badges + Action -->
            <div style="display:flex;align-items:center;gap:.5rem;flex-shrink:0">
              <% if (lesson.is_free_preview) { %><span class="badge" style="background:#F0FDF4;color:#16A34A;font-size:.7rem">Free Preview</span><% } %>
              <% if (isLocked) { %>
                <span class="badge" style="background:#F1F5F9;color:#64748B;font-size:.7rem"><i class="fa-solid fa-lock"></i> Locked</span>
              <% } else { %>
                <a href="<%= lessonUrl %>" class="btn btn-sm btn-primary" style="font-size:.78rem">
                  <% if (lesson.lesson_type === 'video') { %><i class="fa-solid fa-play"></i> Watch<% } else if (lesson.lesson_type === 'file') { %><i class="fa-solid fa-download"></i> Get Resource<% } else { %><i class="fa-solid fa-arrow-right"></i> Open<% } %>
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% }) %>
  </div>

  <!-- CTA for non-members at bottom -->
  <% if (!hasAccess && plans && plans.length > 0) { %>
    <div style="margin-top:2rem;text-align:center">
      <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:1rem">Ready to unlock all <%= totalLessons %> lessons?</p>
      <div style="display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap">
        <% plans.forEach(p => { %>
          <a href="/checkout/plan/<%= p.id %>" class="btn btn-primary">Get Access — <%= formatUSD(p.price) %></a>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>
