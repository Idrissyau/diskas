<div class="container post-layout">
  <div class="post-main">
    <article class="card job-detail" itemscope itemtype="https://schema.org/JobPosting">
      <div class="job-detail-header">
        <div class="job-company-info">
          <% if (job.company_logo) { %>
            <img src="<%= job.company_logo %>" alt="<%= job.company %> logo" class="company-logo-lg" loading="lazy" />
          <% } else { %>
            <div class="company-logo-placeholder-lg" aria-hidden="true"><%= job.company.charAt(0) %></div>
          <% } %>
          <div>
            <h1 itemprop="title"><%= job.title %></h1>
            <p class="job-company" itemprop="hiringOrganization" itemscope itemtype="https://schema.org/Organization">
              <i class="fa-solid fa-building fa-sm" style="color:#0EA5E9"></i>
              <span itemprop="name"><%= job.company %></span>
            </p>
          </div>
        </div>
        <% if (job.apply_url) { %>
          <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-arrow-up-right-from-square fa-sm"></i> Apply Now
          </a>
        <% } else if (job.apply_email) { %>
          <a href="mailto:<%= job.apply_email %>" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-envelope fa-sm"></i> Apply via Email
          </a>
        <% } %>
      </div>

      <div class="job-meta-grid">
        <div class="job-meta-item">
          <i class="fa-solid fa-location-dot" style="color:#0EA5E9"></i>
          <span itemprop="jobLocation" itemscope itemtype="https://schema.org/Place">
            <span itemprop="address"><%= job.location %></span>
          </span>
        </div>
        <div class="job-meta-item">
          <i class="fa-regular fa-clock" style="color:#0EA5E9"></i>
          <span itemprop="employmentType" style="text-transform:capitalize"><%= job.type %></span>
        </div>
        <% if (job.salary_min) { %>
          <div class="job-meta-item">
            <i class="fa-solid fa-dollar-sign" style="color:#10B981"></i>
            <span itemprop="baseSalary" itemscope itemtype="https://schema.org/MonetaryAmount">
              <span itemprop="currency" content="<%= job.currency %>"></span>
              <%= job.salary_min.toLocaleString() %> – <%= (job.salary_max || 0).toLocaleString() %> <%= job.currency %>
            </span>
          </div>
        <% } %>
        <% if (job.category_name) { %>
          <div class="job-meta-item">
            <i class="fa-solid fa-tag" style="color:#0EA5E9"></i>
            <span><%= job.category_name %></span>
          </div>
        <% } %>
        <div class="job-meta-item">
          <i class="fa-regular fa-eye" style="color:#94A3B8"></i>
          <span><%= job.views %> views</span>
        </div>
        <div class="job-meta-item">
          <i class="fa-regular fa-calendar" style="color:#94A3B8"></i>
          <time itemprop="datePosted" datetime="<%= job.created_at %>">Posted <%= job.timeAgo %></time>
        </div>
      </div>

      <div class="content-section" itemprop="description">
        <h2>Job Description</h2>
        <div class="prose"><%= job.description %></div>
      </div>
      <% if (job.requirements) { %>
        <div class="content-section">
          <h2>Requirements</h2>
          <div class="prose"><%= job.requirements %></div>
        </div>
      <% } %>
      <% if (job.benefits) { %>
        <div class="content-section">
          <h2>Benefits</h2>
          <div class="prose"><%= job.benefits %></div>
        </div>
      <% } %>

      <div class="job-apply-box">
        <h3>Interested in this role?</h3>
        <% if (job.apply_url) { %>
          <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-arrow-up-right-from-square fa-sm"></i> Apply on Company Website
          </a>
        <% } else if (job.apply_email) { %>
          <a href="mailto:<%= job.apply_email %>" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-envelope fa-sm"></i> Send Application to <%= job.apply_email %>
          </a>
        <% } else { %>
          <p class="text-muted">Contact the company directly for application details.</p>
        <% } %>
      </div>
    </article>
  </div>

  <aside class="post-sidebar">
    <!-- Posted by card -->
    <% if (job.poster_name) { %>
    <div class="card">
      <h4 style="font-weight:700;margin-bottom:1rem">
        <i class="fa-solid fa-circle-user fa-sm" style="color:#0EA5E9"></i> Posted by
      </h4>
      <div class="sidebar-author">
        <a href="/users/<%= job.user_id %>" class="author-avatar-link">
          <% if (job.poster_avatar) { %>
            <img src="<%= job.poster_avatar %>" alt="<%= job.poster_name %>" class="avatar-md" loading="lazy" />
          <% } else { %>
            <div class="avatar-placeholder-md" aria-hidden="true"><%= job.poster_name.charAt(0) %></div>
          <% } %>
        </a>
        <a href="/users/<%= job.user_id %>" class="author-name-link"><strong><%= job.poster_name %></strong></a>
        <div class="sidebar-author-actions">
          <a href="/users/<%= job.user_id %>" class="btn btn-outline btn-sm">
            <i class="fa-solid fa-user fa-xs"></i> View Profile
          </a>
          <% if (currentUser && currentUser.id !== job.user_id) { %>
            <form action="/messages" method="POST" style="display:inline">
              <input type="hidden" name="user_id" value="<%= job.user_id %>" />
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-comment fa-xs"></i> Message
              </button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <div class="card">
      <h4 style="font-weight:700;margin-bottom:1rem">
        <i class="fa-solid fa-list-check fa-sm" style="color:#0EA5E9"></i> Job Summary
      </h4>
      <ul class="summary-list">
        <li><span>Type</span> <strong style="text-transform:capitalize"><%= job.type %></strong></li>
        <li><span>Location</span> <strong><%= job.location %></strong></li>
        <% if (job.salary_min) { %>
          <li><span>Salary</span> <strong><%= job.salary_min.toLocaleString() %>–<%= (job.salary_max||0).toLocaleString() %> <%= job.currency %></strong></li>
        <% } %>
        <% if (job.expires_at) { %>
          <li><span>Deadline</span> <strong><%= new Date(job.expires_at).toLocaleDateString() %></strong></li>
        <% } %>
        <li><span>Views</span> <strong><%= job.views %></strong></li>
      </ul>
    </div>

    <% if (related.length) { %>
      <div class="card">
        <h4 style="font-weight:700;margin-bottom:.75rem">
          <i class="fa-solid fa-briefcase fa-xs" style="color:#0EA5E9"></i> Similar Jobs
        </h4>
        <% related.forEach(r => { %>
          <a href="/jobs/<%= r.slug %>" class="related-item">
            <strong><%= r.title %></strong><br>
            <small style="color:#94A3B8"><%= r.company %></small>
          </a>
        <% }) %>
      </div>
    <% } %>

    <div class="card">
      <h4 style="font-weight:700;margin-bottom:.75rem">
        <i class="fa-solid fa-briefcase fa-xs" style="color:#0EA5E9"></i> Looking for talent?
      </h4>
      <a href="/jobs/new" class="btn btn-primary btn-sm btn-full">
        <i class="fa-solid fa-plus fa-xs"></i> Post a Job
      </a>
    </div>
  </aside>
</div>
