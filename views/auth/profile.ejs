<div class="page-header">
  <div class="container">
    <div class="profile-header">
      <% if (user.avatar) { %>
        <img src="<%= user.avatar %>" alt="<%= user.name %>" class="avatar-lg" />
      <% } else { %>
        <div class="avatar-placeholder-lg"><%= user.name.charAt(0).toUpperCase() %></div>
      <% } %>
      <div>
        <h1><%= user.name %></h1>
        <p class="text-muted"><%= user.email %></p>
        <% if (user.bio) { %><p><%= user.bio %></p><% } %>
        <div class="profile-meta">
          <% if (user.location) { %><span><i data-feather="map-pin"></i> <%= user.location %></span><% } %>
          <% if (user.website) { %><a href="<%= user.website %>" target="_blank" rel="noopener"><i data-feather="link"></i> Website</a><% } %>
          <span class="badge badge-<%= user.role %>"><%= user.role %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container profile-layout">
  <div class="profile-sidebar">
    <!-- Edit Profile -->
    <div class="card">
      <h3>Edit Profile</h3>
      <form action="/profile" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>Avatar</label>
          <input type="file" name="avatar" accept="image/*" />
        </div>
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" value="<%= user.name %>" required />
        </div>
        <div class="form-group">
          <label>Bio</label>
          <textarea name="bio" rows="3" placeholder="Tell us about yourself..."><%= user.bio || '' %></textarea>
        </div>
        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location" value="<%= user.location || '' %>" placeholder="City, Country" />
        </div>
        <div class="form-group">
          <label>Website</label>
          <input type="url" name="website" value="<%= user.website || '' %>" placeholder="https://..." />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Save Changes</button>
      </form>
    </div>

    <!-- Change Password -->
    <div class="card mt-4">
      <h3>Change Password</h3>
      <form action="/profile/password" method="POST">
        <div class="form-group">
          <label>Current Password</label>
          <input type="password" name="current_password" required />
        </div>
        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="new_password" required minlength="6" />
        </div>
        <div class="form-group">
          <label>Confirm New Password</label>
          <input type="password" name="confirm_new_password" required />
        </div>
        <button type="submit" class="btn btn-outline btn-full">Update Password</button>
      </form>
    </div>
  </div>

  <div class="profile-main">
    <div class="card">
      <h3>My Recent Discussions</h3>
      <% if (posts.length === 0) { %>
        <div class="empty-state"><i data-feather="message-circle"></i><p>You haven't posted anything yet.</p></div>
      <% } else { %>
        <div class="posts-list">
          <% posts.forEach(post => { %>
            <div class="post-card post-card-compact">
              <a href="/discussions/<%= post.slug %>" class="post-title"><%= post.title %></a>
              <div class="post-info">
                <span class="badge badge-<%= post.status %>"><%= post.status %></span>
                <span><i data-feather="eye"></i> <%= post.views %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>
