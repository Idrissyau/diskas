<div class="page-header">
  <div class="container">
    <h1>Search Results: "<%= query %>"</h1>
  </div>
</div>
<div class="container">
  <% if (results.posts && results.posts.length) { %>
    <div class="card mb-4">
      <h2>Discussions (<%= results.posts.length %>)</h2>
      <% results.posts.forEach(p => { %>
        <div class="post-card post-card-compact">
          <a href="/discussions/<%= p.slug %>" class="post-title"><%= p.title %></a>
          <span class="text-muted">by <%= p.author_name %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
  <% if (results.jobs && results.jobs.length) { %>
    <div class="card mb-4">
      <h2>Jobs (<%= results.jobs.length %>)</h2>
      <% results.jobs.forEach(j => { %>
        <div class="post-card post-card-compact">
          <a href="/jobs/<%= j.slug %>" class="post-title"><%= j.title %> — <%= j.company %></a>
          <span class="tag"><%= j.type %></span> <span class="tag"><%= j.location %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
  <% if (results.skills && results.skills.length) { %>
    <div class="card mb-4">
      <h2>Skills (<%= results.skills.length %>)</h2>
      <% results.skills.forEach(s => { %>
        <div class="post-card post-card-compact">
          <a href="/skills/<%= s.slug %>" class="post-title"><%= s.title %></a>
          <span class="badge badge-level-<%= s.level %>"><%= s.level %></span>
          <span class="text-muted">by <%= s.author_name %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
  <% const hasResults = (results.posts && results.posts.length) || (results.jobs && results.jobs.length) || (results.skills && results.skills.length); %>
  <% if (!hasResults) { %>
    <div class="empty-state card">
      <i data-feather="search"></i>
      <h3>No results found</h3>
      <p>Try different keywords or browse our <a href="/discussions">discussions</a>.</p>
    </div>
  <% } %>
</div>
