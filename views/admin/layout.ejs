<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Diskas Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 15px; }
    body { font-family: 'Inter', sans-serif; background: #F0F2F5; color: #334155; min-height: 100vh; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; font-family: inherit; }
    img { max-width: 100%; }

    /* ─── OVERLAY ─────────────────────────────────────────────────────── */
    .overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 98;
      backdrop-filter: blur(2px);
    }
    .overlay.active { display: block; }

    /* ─── SIDEBAR ─────────────────────────────────────────────────────── */
    .sidebar {
      position: fixed;
      top: 0; left: 0; bottom: 0;
      width: 260px;
      background: #0F172A;
      z-index: 99;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      overflow-x: hidden;
      transition: transform .28s cubic-bezier(.4,0,.2,1);
      box-shadow: 4px 0 24px rgba(0,0,0,.25);
    }

    .sidebar-brand {
      display: flex; align-items: center; gap: .75rem;
      padding: 1.25rem 1.25rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,.07);
      flex-shrink: 0;
    }
    .brand-icon {
      width: 40px; height: 40px; border-radius: 11px;
      background: linear-gradient(135deg,#0EA5E9,#0284C7);
      display: grid; place-items: center;
      color: #fff; font-weight: 800; font-size: 1.15rem; flex-shrink: 0;
    }
    .brand-name { font-size: 1rem; font-weight: 700; color: #fff; }
    .brand-sub  { font-size: .68rem; color: #64748B; text-transform: uppercase; letter-spacing: .07em; }

    .sidebar-nav { padding: .75rem .85rem; flex: 1; }
    .nav-section-label {
      font-size: .67rem; font-weight: 700; color: #475569;
      text-transform: uppercase; letter-spacing: .1em;
      padding: .6rem .5rem .25rem; display: block;
    }
    .nav-link {
      display: flex; align-items: center; gap: .7rem;
      padding: .62rem .75rem; border-radius: 9px;
      color: #94A3B8; font-size: .87rem; font-weight: 500;
      transition: all .15s; margin-bottom: .08rem;
    }
    .nav-link:hover { background: rgba(255,255,255,.07); color: #e2e8f0; }
    .nav-link.active {
      background: linear-gradient(135deg,#0EA5E9,#0284C7);
      color: #fff; box-shadow: 0 4px 14px rgba(14,165,233,.3);
    }
    .nav-link i { width: 17px; text-align: center; font-size: .88rem; flex-shrink: 0; }
    .nav-divider { height: 1px; background: rgba(255,255,255,.06); margin: .5rem .5rem; }

    .sidebar-footer {
      padding: .85rem;
      border-top: 1px solid rgba(255,255,255,.06);
      flex-shrink: 0;
    }
    .sidebar-user {
      display: flex; align-items: center; gap: .65rem;
      padding: .65rem .75rem; border-radius: 10px;
      background: rgba(255,255,255,.05);
    }
    .sidebar-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: linear-gradient(135deg,#0EA5E9,#F97316);
      display: grid; place-items: center;
      color: #fff; font-weight: 700; font-size: .85rem; flex-shrink: 0;
    }
    .sidebar-user-name { color: #e2e8f0; font-size: .83rem; font-weight: 600; display: block; }
    .sidebar-user-role { color: #64748B; font-size: .7rem; text-transform: capitalize; }

    /* ─── WRAPPER ─────────────────────────────────────────────────────── */
    .admin-wrapper {
      margin-left: 260px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      transition: margin-left .28s cubic-bezier(.4,0,.2,1);
    }

    /* ─── TOPBAR ──────────────────────────────────────────────────────── */
    .topbar {
      position: sticky; top: 0; z-index: 50;
      background: #fff;
      height: 62px;
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      border-bottom: 1px solid #E2E8F0;
      box-shadow: 0 1px 6px rgba(0,0,0,.05);
      gap: 1rem;
    }
    .topbar-left { display: flex; align-items: center; gap: .85rem; min-width: 0; }
    .hamburger-btn {
      display: none;
      background: none; border: 1.5px solid #E2E8F0;
      border-radius: 9px; width: 38px; height: 38px;
      align-items: center; justify-content: center;
      color: #334155; font-size: 1rem;
      flex-shrink: 0; transition: all .15s;
    }
    .hamburger-btn:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .topbar-title { font-size: 1rem; font-weight: 700; color: #0F172A; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .topbar-breadcrumb { font-size: .73rem; color: #94A3B8; white-space: nowrap; }
    .topbar-breadcrumb span { color: #0EA5E9; }

    .topbar-right { display: flex; align-items: center; gap: .6rem; flex-shrink: 0; }
    .topbar-icon-btn {
      width: 36px; height: 36px; border-radius: 9px;
      border: 1.5px solid #E2E8F0; background: #fff;
      display: grid; place-items: center;
      color: #64748B; font-size: .85rem; transition: all .15s;
    }
    .topbar-icon-btn:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .topbar-user-pill {
      display: flex; align-items: center; gap: .55rem;
      padding: .35rem .85rem .35rem .45rem;
      border: 1.5px solid #E2E8F0; border-radius: 9px;
      background: #fff; cursor: default;
    }
    .topbar-user-avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: linear-gradient(135deg,#0EA5E9,#F97316);
      display: grid; place-items: center;
      color: #fff; font-weight: 700; font-size: .75rem;
    }
    .topbar-user-name { font-size: .83rem; font-weight: 600; color: #0F172A; }

    /* ─── FLASH ───────────────────────────────────────────────────────── */
    .flash {
      display: flex; align-items: center; gap: .7rem;
      padding: .8rem 1.5rem; font-size: .87rem; font-weight: 500;
    }
    .flash-success { background: #D1FAE5; color: #065F46; border-left: 4px solid #10B981; }
    .flash-error   { background: #FEE2E2; color: #991B1B; border-left: 4px solid #EF4444; }
    .flash-info    { background: #DBEAFE; color: #1E40AF; border-left: 4px solid #3B82F6; }

    /* ─── CONTENT ─────────────────────────────────────────────────────── */
    .page-content { padding: 1.5rem; flex: 1; }

    /* ─── STAT CARDS ──────────────────────────────────────────────────── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.1rem;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      background: #fff; border-radius: 14px;
      padding: 1.25rem 1.35rem;
      border: 1px solid #E2E8F0;
      box-shadow: 0 2px 8px rgba(0,0,0,.04);
      display: flex; align-items: flex-start;
      justify-content: space-between;
      transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,.09); }
    .stat-label { font-size: .73rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94A3B8; margin-bottom: .4rem; }
    .stat-value { font-size: 1.9rem; font-weight: 800; color: #0F172A; line-height: 1; margin-bottom: .3rem; }
    .stat-sub   { font-size: .75rem; color: #64748B; }
    .stat-sub .up   { color: #10B981; font-weight: 600; }
    .stat-sub .down { color: #EF4444; font-weight: 600; }
    .stat-icon {
      width: 48px; height: 48px; border-radius: 13px;
      display: grid; place-items: center;
      font-size: 1.2rem; flex-shrink: 0;
    }

    /* ─── PANEL ───────────────────────────────────────────────────────── */
    .panel {
      background: #fff; border-radius: 14px;
      border: 1px solid #E2E8F0;
      box-shadow: 0 2px 8px rgba(0,0,0,.04);
      overflow: hidden; margin-bottom: 1.25rem;
    }
    .panel-head {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 1rem 1.35rem;
      border-bottom: 1px solid #F1F5F9;
      gap: .75rem; flex-wrap: wrap;
    }
    .panel-head-title {
      font-size: .92rem; font-weight: 700; color: #0F172A;
      display: flex; align-items: center; gap: .55rem;
    }
    .panel-head-title i { color: #0EA5E9; }
    .panel-body { padding: 1.25rem 1.35rem; }

    /* ─── GRID LAYOUTS ────────────────────────────────────────────────── */
    .layout-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .layout-main-side { display: grid; grid-template-columns: 1fr 340px; gap: 1.25rem; }

    /* ─── TABLE ───────────────────────────────────────────────────────── */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .data-table { width: 100%; border-collapse: collapse; font-size: .84rem; min-width: 540px; }
    .data-table th {
      text-align: left; padding: .7rem 1rem;
      font-size: .7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .06em;
      color: #94A3B8; background: #F8FAFC;
      border-bottom: 1px solid #E2E8F0;
      white-space: nowrap;
    }
    .data-table td { padding: .8rem 1rem; border-bottom: 1px solid #F1F5F9; vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #F8FAFC; }
    .data-table a { color: #0EA5E9; font-weight: 600; }

    /* ─── USER CELL ───────────────────────────────────────────────────── */
    .user-cell { display: flex; align-items: center; gap: .6rem; }
    .user-avatar {
      width: 32px; height: 32px; border-radius: 50%;
      background: linear-gradient(135deg,#0EA5E9,#0F172A);
      display: grid; place-items: center;
      color: #fff; font-weight: 700; font-size: .78rem; flex-shrink: 0;
    }
    .user-name  { font-weight: 600; color: #0F172A; font-size: .84rem; }
    .user-email { font-size: .72rem; color: #94A3B8; }

    /* ─── BADGES ──────────────────────────────────────────────────────── */
    .badge {
      display: inline-flex; align-items: center; gap: .28rem;
      padding: .22rem .62rem; border-radius: 20px;
      font-size: .7rem; font-weight: 700; white-space: nowrap;
    }
    .badge-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: .65; }
    .b-admin      { background:#EDE9FE; color:#7C3AED; }
    .b-moderator  { background:#DBEAFE; color:#1D4ED8; }
    .b-user       { background:#F1F5F9; color:#475569; }
    .b-active     { background:#D1FAE5; color:#065F46; }
    .b-suspended  { background:#FEF3C7; color:#92400E; }
    .b-banned     { background:#FEE2E2; color:#991B1B; }
    .b-pending    { background:#FEF3C7; color:#92400E; }
    .b-closed     { background:#F1F5F9; color:#475569; }
    .b-draft      { background:#FEE2E2; color:#991B1B; }
    .b-pinned     { background:#FEF3C7; color:#92400E; }
    .b-discussion { background:#EDE9FE; color:#7C3AED; }
    .b-question   { background:#DBEAFE; color:#1D4ED8; }
    .b-announcement { background:#FEE2E2; color:#991B1B; }
    .b-beginner   { background:#D1FAE5; color:#065F46; }
    .b-intermediate { background:#DBEAFE; color:#1D4ED8; }
    .b-advanced   { background:#FEE2E2; color:#991B1B; }
    /* alias for status without prefix */
    .badge-admin      { background:#EDE9FE; color:#7C3AED; }
    .badge-moderator  { background:#DBEAFE; color:#1D4ED8; }
    .badge-user       { background:#F1F5F9; color:#475569; }
    .badge-active     { background:#D1FAE5; color:#065F46; }
    .badge-suspended  { background:#FEF3C7; color:#92400E; }
    .badge-banned     { background:#FEE2E2; color:#991B1B; }
    .badge-pending    { background:#FEF3C7; color:#92400E; }
    .badge-closed     { background:#F1F5F9; color:#475569; }
    .badge-draft      { background:#FEE2E2; color:#991B1B; }
    .badge-pinned     { background:#FEF3C7; color:#92400E; }
    .badge-discussion { background:#EDE9FE; color:#7C3AED; }
    .badge-question   { background:#DBEAFE; color:#1D4ED8; }
    .badge-announcement { background:#FEE2E2; color:#991B1B; }
    .badge-beginner   { background:#D1FAE5; color:#065F46; }
    .badge-intermediate { background:#DBEAFE; color:#1D4ED8; }
    .badge-advanced   { background:#FEE2E2; color:#991B1B; }

    /* ─── BUTTONS ─────────────────────────────────────────────────────── */
    .btn { display: inline-flex; align-items: center; gap: .38rem; padding: .48rem 1rem; border-radius: 8px; font-weight: 600; font-size: .82rem; border: none; transition: all .15s; white-space: nowrap; }
    .btn-primary { background: #0EA5E9; color: #fff; }
    .btn-primary:hover { background: #0284C7; }
    .btn-outline { background: transparent; border: 1.5px solid #E2E8F0; color: #334155; }
    .btn-outline:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .btn-success { background: #10B981; color: #fff; }
    .btn-success:hover { background: #059669; }
    .btn-danger  { background: #EF4444; color: #fff; }
    .btn-danger:hover { background: #DC2626; }
    .btn-orange  { background: #F97316; color: #fff; }
    .btn-orange:hover { background: #EA6C0A; }
    .btn-sm { padding: .3rem .75rem; font-size: .78rem; border-radius: 7px; }
    .btn-xs { padding: .2rem .55rem; font-size: .72rem; border-radius: 6px; }

    /* ─── FORMS ───────────────────────────────────────────────────────── */
    .form-ctrl {
      width: 100%; padding: .52rem .88rem;
      border: 1.5px solid #E2E8F0; border-radius: 8px;
      font-size: .84rem; outline: none; background: #fff;
      font-family: inherit; color: #334155; transition: border .15s;
    }
    .form-ctrl:focus { border-color: #0EA5E9; }
    .form-ctrl-xs { padding: .28rem .58rem; font-size: .77rem; border-radius: 6px; }
    .form-group { margin-bottom: .95rem; }
    .form-group label { display: block; font-weight: 600; font-size: .8rem; color: #475569; margin-bottom: .32rem; }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .inline-form { display: inline-flex; align-items: center; gap: .35rem; flex-wrap: wrap; }

    /* ─── FILTER BAR ──────────────────────────────────────────────────── */
    .filter-bar { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; margin-bottom: 1.25rem; }
    .filter-bar .form-ctrl { width: auto; }

    /* ─── PENDING ITEM ────────────────────────────────────────────────── */
    .pend-item { display: flex; align-items: center; justify-content: space-between; padding: .85rem 1.35rem; border-bottom: 1px solid #F1F5F9; gap: .75rem; flex-wrap: wrap; }
    .pend-item:last-child { border-bottom: none; }
    .pend-title { font-size: .86rem; font-weight: 600; color: #0F172A; }
    .pend-sub   { font-size: .73rem; color: #94A3B8; }
    .pend-actions { display: flex; gap: .4rem; flex-shrink: 0; }

    /* ─── EMPTY ───────────────────────────────────────────────────────── */
    .empty-state { text-align: center; padding: 2rem 1rem; color: #94A3B8; }
    .empty-state i { font-size: 2rem; margin-bottom: .6rem; display: block; }
    .empty-state p { font-size: .85rem; }

    /* ─── PAGINATION ──────────────────────────────────────────────────── */
    .pagination { display: flex; align-items: center; justify-content: center; gap: .5rem; padding: 1rem 1.35rem; border-top: 1px solid #F1F5F9; flex-wrap: wrap; }
    .page-btn { padding: .38rem .88rem; border-radius: 7px; border: 1.5px solid #E2E8F0; font-size: .8rem; font-weight: 600; color: #334155; background: #fff; transition: all .15s; }
    .page-btn:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .page-info { font-size: .8rem; color: #94A3B8; }

    /* ─── SETTINGS ────────────────────────────────────────────────────── */
    .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }

    /* ─── SCROLLBAR ───────────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }

    /* ─── LEGACY ALIASES (backwards-compat with existing view templates) ─── */

    /* Stats row */
    .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1.1rem; margin-bottom:1.5rem; }
    .stat-card-info  { flex:1; min-width:0; }
    .stat-card-label { font-size:.73rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#94A3B8; margin-bottom:.4rem; }
    .stat-card-value { font-size:1.9rem; font-weight:800; color:#0F172A; line-height:1; margin-bottom:.3rem; }
    .stat-card-sub   { font-size:.75rem; color:#64748B; }
    .stat-card-sub .up   { color:#10B981; font-weight:600; }
    .stat-card-sub .down { color:#EF4444; font-weight:600; }
    .stat-card-icon  { width:48px; height:48px; border-radius:13px; display:grid; place-items:center; font-size:1.2rem; flex-shrink:0; }

    /* Grid layouts */
    .grid-3       { display:grid; grid-template-columns:1fr 340px; gap:1.25rem; }
    .admin-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
    .form-row     { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }

    /* Panel aliases */
    .panel-header { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.35rem; border-bottom:1px solid #F1F5F9; gap:.75rem; flex-wrap:wrap; }
    .panel-title  { font-size:.92rem; font-weight:700; color:#0F172A; display:flex; align-items:center; gap:.55rem; }
    .panel-title i { color:#0EA5E9; }
    .panel-body-flush { overflow-x:auto; -webkit-overflow-scrolling:touch; }

    /* Admin card (older views use this instead of .panel) */
    .admin-card { background:#fff; border-radius:14px; border:1px solid #E2E8F0; box-shadow:0 2px 8px rgba(0,0,0,.04); overflow-x:auto; margin-bottom:1.25rem; }
    .admin-card h3 { font-size:.95rem; font-weight:700; color:#0F172A; padding:1rem 1.35rem; border-bottom:1px solid #F1F5F9; margin:0; }

    /* Admin table (older views use .admin-table instead of .data-table) */
    .admin-table { width:100%; border-collapse:collapse; font-size:.84rem; min-width:540px; }
    .admin-table th { text-align:left; padding:.7rem 1rem; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#94A3B8; background:#F8FAFC; border-bottom:1px solid #E2E8F0; white-space:nowrap; }
    .admin-table td { padding:.8rem 1rem; border-bottom:1px solid #F1F5F9; vertical-align:middle; }
    .admin-table tr:last-child td { border-bottom:none; }
    .admin-table tr:hover td { background:#F8FAFC; }
    .admin-table a { color:#0EA5E9; font-weight:600; }

    /* Form aliases (.form-control / .form-select map to .form-ctrl) */
    .form-control,.form-select { width:100%; padding:.52rem .88rem; border:1.5px solid #E2E8F0; border-radius:8px; font-size:.84rem; outline:none; background:#fff; font-family:inherit; color:#334155; transition:border .15s; }
    .form-control:focus,.form-select:focus { border-color:#0EA5E9; }
    .form-control-xs,.form-select-xs { padding:.28rem .58rem !important; font-size:.77rem !important; border-radius:6px !important; }

    /* Bare inputs inside .form-group (settings page) */
    .form-group input[type="text"],
    .form-group input[type="number"],
    .form-group input[type="email"],
    .form-group input[type="password"],
    .form-group input[type="color"] { width:100%; padding:.52rem .88rem; border:1.5px solid #E2E8F0; border-radius:8px; font-size:.84rem; outline:none; background:#fff; font-family:inherit; color:#334155; transition:border .15s; }
    .form-group input:focus { border-color:#0EA5E9; }

    /* User cell aliases */
    .user-cell-avatar { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#0EA5E9,#0F172A); display:grid; place-items:center; color:#fff; font-weight:700; font-size:.78rem; flex-shrink:0; }
    .user-cell-name   { font-weight:600; color:#0F172A; font-size:.84rem; }
    .user-cell-email  { font-size:.72rem; color:#94A3B8; }

    /* Pending item aliases */
    .pending-item { display:flex; align-items:center; justify-content:space-between; padding:.85rem 1.35rem; border-bottom:1px solid #F1F5F9; gap:.75rem; flex-wrap:wrap; }
    .pending-item:last-child { border-bottom:none; }
    .pending-item-info { flex:1; min-width:0; }
    .pending-item-info strong { display:block; font-size:.86rem; font-weight:600; color:#0F172A; margin-bottom:.15rem; }
    .pending-item-info span   { font-size:.73rem; color:#94A3B8; }
    .pending-item-actions { display:flex; gap:.4rem; flex-shrink:0; }

    /* Empty state aliases */
    .empty-box,.empty-state { text-align:center; padding:2rem 1rem; color:#94A3B8; }
    .empty-box i,.empty-state i { font-size:2rem; margin-bottom:.6rem; display:block; }
    .empty-box p,.empty-state p { font-size:.85rem; }

    /* Filter bar aliases (older views use .admin-filters / .filter-form) */
    .admin-filters { margin-bottom:1.25rem; }
    .filter-form { display:flex; flex-wrap:wrap; gap:.75rem; align-items:center; }
    .filter-form input { padding:.52rem .88rem; border:1.5px solid #E2E8F0; border-radius:8px; font-size:.84rem; outline:none; font-family:inherit; color:#334155; }
    .filter-form input:focus { border-color:#0EA5E9; }

    /* Misc utilities */
    .text-muted { color:#94A3B8; font-size:.78rem; }
    .cat-dot    { display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:.35rem; vertical-align:middle; }

    /* Badge extras */
    .badge-type               { background:#EDE9FE; color:#7C3AED; }
    .badge-level-beginner     { background:#D1FAE5; color:#065F46; }
    .badge-level-intermediate { background:#DBEAFE; color:#1D4ED8; }
    .badge-level-advanced     { background:#FEE2E2; color:#991B1B; }

    /* ═══════════════════════════════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════════════════════════════ */

    /* ── Tablet ── */
    @media (max-width: 1100px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .stats-row  { grid-template-columns: repeat(2, 1fr); }
      .layout-main-side { grid-template-columns: 1fr; }
      .layout-2col { grid-template-columns: 1fr; }
      .settings-grid { grid-template-columns: 1fr; }
      .form-row-2 { grid-template-columns: 1fr; }
      .grid-3     { grid-template-columns: 1fr; }
      .admin-grid-2 { grid-template-columns: 1fr; }
      .form-row   { grid-template-columns: 1fr; }
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
      /* Sidebar hidden off-screen by default */
      .sidebar {
        transform: translateX(-100%);
        width: 240px;
      }
      .sidebar.sidebar-open {
        transform: translateX(0);
      }

      /* Main takes full width */
      .admin-wrapper { margin-left: 0 !important; }

      /* Show hamburger */
      .hamburger-btn { display: inline-flex; }

      /* Topbar */
      .topbar { padding: 0 1rem; }
      .topbar-breadcrumb { display: none; }
      .topbar-user-name { display: none; }

      /* Content */
      .page-content { padding: 1rem; }

      /* Stats */
      .stats-grid,.stats-row { grid-template-columns: 1fr 1fr; gap: .75rem; }
      .stat-value,.stat-card-value { font-size: 1.6rem; }
      .stat-icon,.stat-card-icon  { width: 42px; height: 42px; font-size: 1.05rem; }

      /* Filter bar full width inputs */
      .filter-bar .form-ctrl,
      .filter-bar .form-control,
      .filter-bar .form-select { width: 100% !important; max-width: 100% !important; }
      .filter-bar form { width: 100%; }
      .filter-form { flex-direction: column; align-items: stretch; }
      .filter-form input,.filter-form .form-select,.filter-form .form-control { width: 100% !important; }
      .admin-filters .filter-form { width: 100%; }

      /* Panel header wraps */
      .panel-head,.panel-header { padding: .85rem 1rem; }
      .panel-body { padding: 1rem; }
    }

    /* ── Small mobile ── */
    @media (max-width: 480px) {
      .stats-grid,.stats-row { grid-template-columns: 1fr; }
      .stat-card { flex-direction: row; }
      .topbar-icon-btn { display: none; }
      .topbar-icon-btn:last-of-type { display: grid; }
      .admin-grid-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- Overlay -->
<div class="overlay" id="sidebarOverlay"></div>

<!-- ── SIDEBAR ──────────────────────────────────────────────────────────── -->
<aside class="sidebar" id="adminSidebar">
  <div class="sidebar-brand">
    <div class="brand-icon">D</div>
    <div>
      <div class="brand-name">Diskas</div>
      <div class="brand-sub">Admin Panel</div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <span class="nav-section-label">Main</span>
    <a href="/admin" class="nav-link <%= title === 'Admin Dashboard' ? 'active' : '' %>">
      <i class="fa-solid fa-gauge-high"></i> Dashboard
    </a>

    <span class="nav-section-label" style="margin-top:.5rem">Community</span>
    <a href="/admin/users" class="nav-link <%= title === 'Manage Users' ? 'active' : '' %>">
      <i class="fa-solid fa-users"></i> Users
    </a>
    <a href="/admin/posts" class="nav-link <%= title === 'Manage Posts' ? 'active' : '' %>">
      <i class="fa-solid fa-comments"></i> Posts
    </a>
    <a href="/admin/reports" class="nav-link <%= title === 'Reports' ? 'active' : '' %>">
      <i class="fa-solid fa-flag"></i> Reports
    </a>

    <span class="nav-section-label" style="margin-top:.5rem">Content</span>
    <a href="/admin/jobs" class="nav-link <%= title === 'Manage Jobs' ? 'active' : '' %>">
      <i class="fa-solid fa-briefcase"></i> Jobs
    </a>
    <a href="/admin/skills" class="nav-link <%= title === 'Manage Skills' ? 'active' : '' %>">
      <i class="fa-solid fa-book-open"></i> Skills
    </a>
    <a href="/admin/categories" class="nav-link <%= title === 'Categories' ? 'active' : '' %>">
      <i class="fa-solid fa-tags"></i> Categories
    </a>

    <span class="nav-section-label" style="margin-top:.5rem">Revenue</span>
    <a href="/admin/monetize" class="nav-link <%= title === 'Revenue Dashboard' ? 'active' : '' %>">
      <i class="fa-solid fa-dollar-sign"></i> Monetize
    </a>

    <% if (currentUser && currentUser.role === 'admin') { %>
    <span class="nav-section-label" style="margin-top:.5rem">System</span>
    <a href="/admin/settings" class="nav-link <%= title === 'Site Settings' ? 'active' : '' %>">
      <i class="fa-solid fa-sliders"></i> Settings
    </a>
    <% } %>

    <div class="nav-divider"></div>
    <a href="/" class="nav-link"><i class="fa-solid fa-arrow-up-right-from-square"></i> View Site</a>
    <a href="/auth/logout" class="nav-link" style="color:#F87171">
      <i class="fa-solid fa-right-from-bracket"></i> Logout
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-avatar">
        <%= currentUser ? currentUser.name.charAt(0).toUpperCase() : 'A' %>
      </div>
      <div>
        <span class="sidebar-user-name"><%= currentUser ? currentUser.name : 'Admin' %></span>
        <span class="sidebar-user-role"><%= currentUser ? currentUser.role : '' %></span>
      </div>
    </div>
  </div>
</aside>

<!-- ── MAIN WRAPPER ──────────────────────────────────────────────────────── -->
<div class="admin-wrapper" id="adminWrapper">

  <!-- Topbar -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menu">
        <i class="fa-solid fa-bars"></i>
      </button>
      <div>
        <div class="topbar-title"><%= title %></div>
        <div class="topbar-breadcrumb">Admin &rsaquo; <span><%= title %></span></div>
      </div>
    </div>
    <div class="topbar-right">
      <a href="/admin/reports" class="topbar-icon-btn" title="Reports">
        <i class="fa-solid fa-flag"></i>
      </a>
      <a href="/" class="topbar-icon-btn" title="View Site">
        <i class="fa-solid fa-globe"></i>
      </a>
      <div class="topbar-user-pill">
        <div class="topbar-user-avatar">
          <%= currentUser ? currentUser.name.charAt(0).toUpperCase() : 'A' %>
        </div>
        <span class="topbar-user-name"><%= currentUser ? currentUser.name : 'Admin' %></span>
      </div>
    </div>
  </header>

  <!-- Flash -->
  <% if (flashSuccess && flashSuccess.length) { %>
    <div class="flash flash-success"><i class="fa-solid fa-circle-check"></i> <%= flashSuccess[0] %></div>
  <% } %>
  <% if (flashError && flashError.length) { %>
    <div class="flash flash-error"><i class="fa-solid fa-circle-xmark"></i> <%= flashError[0] %></div>
  <% } %>
  <% if (flashInfo && flashInfo.length) { %>
    <div class="flash flash-info"><i class="fa-solid fa-circle-info"></i> <%= flashInfo[0] %></div>
  <% } %>

  <!-- Content -->
  <div class="page-content">
    <%- body %>
  </div>
</div>

<script>
  const sidebar  = document.getElementById('adminSidebar');
  const overlay  = document.getElementById('sidebarOverlay');
  const hamburger = document.getElementById('hamburgerBtn');
  const wrapper  = document.getElementById('adminWrapper');

  function openSidebar() {
    sidebar.classList.add('sidebar-open');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar.classList.remove('sidebar-open');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', () => {
    sidebar.classList.contains('sidebar-open') ? closeSidebar() : openSidebar();
  });
  overlay.addEventListener('click', closeSidebar);

  // Close on nav click (mobile)
  document.querySelectorAll('.nav-link').forEach(l => {
    l.addEventListener('click', () => { if (window.innerWidth <= 768) closeSidebar(); });
  });

  // Reset on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) closeSidebar();
  });

  // Auto-hide flash messages
  document.querySelectorAll('.flash').forEach(f => {
    setTimeout(() => {
      f.style.transition = 'opacity .5s';
      f.style.opacity = '0';
      setTimeout(() => f.remove(), 500);
    }, 4000);
  });
</script>
</body>
</html>
