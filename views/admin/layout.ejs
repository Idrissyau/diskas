<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Diskas Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 15px; }
    body { font-family: 'Inter', sans-serif; background: #F0F2F5; color: #334155; display: flex; min-height: 100vh; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; font-family: inherit; }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 260px; min-height: 100vh; background: #0F172A;
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0;
      z-index: 100; transition: width .25s;
      box-shadow: 4px 0 20px rgba(0,0,0,.3);
    }
    .sidebar-brand {
      padding: 1.5rem 1.25rem;
      border-bottom: 1px solid rgba(255,255,255,.07);
      display: flex; align-items: center; gap: .75rem;
    }
    .brand-icon {
      width: 42px; height: 42px; background: linear-gradient(135deg, #0EA5E9, #0284C7);
      border-radius: 12px; display: grid; place-items: center;
      color: #fff; font-weight: 800; font-size: 1.2rem; flex-shrink: 0;
    }
    .brand-text { color: #fff; }
    .brand-text strong { font-size: 1.1rem; font-weight: 700; display: block; }
    .brand-text span { font-size: .72rem; color: #94A3B8; text-transform: uppercase; letter-spacing: .08em; }

    .sidebar-section { padding: .75rem 1rem .25rem; }
    .sidebar-section-label {
      font-size: .68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: #475569; padding: 0 .5rem; margin-bottom: .35rem;
    }
    .nav-item {
      display: flex; align-items: center; gap: .75rem;
      padding: .65rem .75rem; border-radius: 10px;
      color: #94A3B8; font-size: .88rem; font-weight: 500;
      transition: all .15s; margin-bottom: .1rem; position: relative;
    }
    .nav-item:hover { background: rgba(255,255,255,.06); color: #fff; }
    .nav-item.active { background: linear-gradient(135deg, #0EA5E9, #0284C7); color: #fff; box-shadow: 0 4px 12px rgba(14,165,233,.35); }
    .nav-item i { width: 18px; text-align: center; font-size: .9rem; flex-shrink: 0; }
    .nav-badge {
      margin-left: auto; background: #F97316; color: #fff;
      font-size: .65rem; font-weight: 700; padding: .15rem .45rem;
      border-radius: 20px; min-width: 20px; text-align: center;
    }
    .nav-badge.red { background: #ef4444; }
    .sidebar-divider { height: 1px; background: rgba(255,255,255,.06); margin: .5rem 1rem; }
    .sidebar-footer {
      margin-top: auto; padding: 1rem;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .sidebar-user {
      display: flex; align-items: center; gap: .75rem;
      padding: .65rem .75rem; border-radius: 10px;
      background: rgba(255,255,255,.05);
    }
    .sidebar-user-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #0EA5E9, #F97316);
      display: grid; place-items: center;
      color: #fff; font-weight: 700; font-size: .9rem; flex-shrink: 0;
    }
    .sidebar-user-info strong { color: #fff; font-size: .85rem; display: block; }
    .sidebar-user-info span { color: #64748B; font-size: .72rem; }

    /* ── MAIN ── */
    .main { margin-left: 260px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

    /* ── TOPBAR ── */
    .topbar {
      background: #fff; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; border-bottom: 1px solid #E2E8F0;
      position: sticky; top: 0; z-index: 50;
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    .topbar-left { display: flex; flex-direction: column; }
    .topbar-title { font-size: 1.1rem; font-weight: 700; color: #0F172A; }
    .topbar-breadcrumb { font-size: .75rem; color: #94A3B8; display: flex; align-items: center; gap: .35rem; }
    .topbar-breadcrumb span { color: #0EA5E9; }
    .topbar-right { display: flex; align-items: center; gap: .75rem; }
    .topbar-btn {
      width: 38px; height: 38px; border-radius: 10px;
      border: 1.5px solid #E2E8F0; background: #fff;
      display: grid; place-items: center; color: #64748B;
      font-size: .9rem; transition: all .15s; position: relative;
    }
    .topbar-btn:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .topbar-notif {
      position: absolute; top: -4px; right: -4px;
      width: 16px; height: 16px; background: #ef4444;
      border-radius: 50%; font-size: .6rem; color: #fff;
      display: grid; place-items: center; font-weight: 700;
    }
    .topbar-user {
      display: flex; align-items: center; gap: .6rem;
      padding: .4rem .75rem; border-radius: 10px;
      border: 1.5px solid #E2E8F0; background: #fff; cursor: pointer;
    }
    .topbar-user-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      background: linear-gradient(135deg, #0EA5E9, #F97316);
      display: grid; place-items: center; color: #fff;
      font-weight: 700; font-size: .8rem;
    }
    .topbar-user span { font-size: .85rem; font-weight: 600; color: #0F172A; }

    /* ── FLASH ── */
    .flash {
      display: flex; align-items: center; gap: .75rem;
      padding: .85rem 2rem; font-size: .88rem; font-weight: 500;
    }
    .flash-success { background: #D1FAE5; color: #065F46; border-left: 4px solid #10B981; }
    .flash-error { background: #FEE2E2; color: #991B1B; border-left: 4px solid #EF4444; }
    .flash-info { background: #DBEAFE; color: #1E40AF; border-left: 4px solid #3B82F6; }

    /* ── CONTENT ── */
    .content { padding: 1.75rem 2rem; flex: 1; }

    /* ── STAT CARDS ── */
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; margin-bottom: 1.75rem; }
    .stat-card {
      background: #fff; border-radius: 16px; padding: 1.4rem 1.5rem;
      border: 1px solid #E2E8F0; box-shadow: 0 2px 8px rgba(0,0,0,.04);
      display: flex; align-items: flex-start; justify-content: space-between;
      transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.09); }
    .stat-card-info {}
    .stat-card-label { font-size: .78rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: #94A3B8; margin-bottom: .4rem; }
    .stat-card-value { font-size: 2rem; font-weight: 800; color: #0F172A; line-height: 1; margin-bottom: .35rem; }
    .stat-card-sub { font-size: .78rem; color: #64748B; }
    .stat-card-sub .up { color: #10B981; font-weight: 600; }
    .stat-card-sub .down { color: #EF4444; font-weight: 600; }
    .stat-card-icon {
      width: 52px; height: 52px; border-radius: 14px;
      display: grid; place-items: center; font-size: 1.3rem; flex-shrink: 0;
    }

    /* ── SECTION GRID ── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
    .grid-3 { display: grid; grid-template-columns: 2fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }

    /* ── PANEL ── */
    .panel {
      background: #fff; border-radius: 16px; border: 1px solid #E2E8F0;
      box-shadow: 0 2px 8px rgba(0,0,0,.04); overflow: hidden;
    }
    .panel-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 1.5rem; border-bottom: 1px solid #F1F5F9;
    }
    .panel-title { font-size: .95rem; font-weight: 700; color: #0F172A; display: flex; align-items: center; gap: .6rem; }
    .panel-title i { color: #0EA5E9; }
    .panel-body { padding: 1.25rem 1.5rem; }
    .panel-body-flush { }

    /* ── TABLE ── */
    .data-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
    .data-table th {
      text-align: left; padding: .75rem 1rem;
      font-size: .72rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .06em; color: #94A3B8;
      background: #F8FAFC; border-bottom: 1px solid #E2E8F0;
    }
    .data-table td { padding: .85rem 1rem; border-bottom: 1px solid #F1F5F9; vertical-align: middle; color: #334155; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #F8FAFC; }
    .data-table a { color: #0EA5E9; font-weight: 600; }
    .data-table a:hover { text-decoration: underline; }

    /* ── USER CELL ── */
    .user-cell { display: flex; align-items: center; gap: .65rem; }
    .user-cell-avatar {
      width: 32px; height: 32px; border-radius: 50%; object-fit: cover;
      background: linear-gradient(135deg, #0EA5E9, #0F172A);
      display: grid; place-items: center; color: #fff;
      font-weight: 700; font-size: .8rem; flex-shrink: 0;
    }
    .user-cell-name { font-weight: 600; color: #0F172A; font-size: .85rem; }
    .user-cell-email { font-size: .75rem; color: #94A3B8; }

    /* ── BADGES ── */
    .badge {
      display: inline-flex; align-items: center; gap: .3rem;
      padding: .25rem .65rem; border-radius: 20px;
      font-size: .72rem; font-weight: 700; white-space: nowrap;
    }
    .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: .6; }
    .badge-admin { background: #EDE9FE; color: #7C3AED; }
    .badge-moderator { background: #DBEAFE; color: #1D4ED8; }
    .badge-user { background: #F1F5F9; color: #475569; }
    .badge-active { background: #D1FAE5; color: #065F46; }
    .badge-suspended { background: #FEF3C7; color: #92400E; }
    .badge-banned { background: #FEE2E2; color: #991B1B; }
    .badge-pending { background: #FEF3C7; color: #92400E; }
    .badge-approved, .badge-active2 { background: #D1FAE5; color: #065F46; }
    .badge-closed { background: #F1F5F9; color: #475569; }
    .badge-draft { background: #FEE2E2; color: #991B1B; }
    .badge-pinned { background: #FEF3C7; color: #92400E; }
    .badge-discussion { background: #EDE9FE; color: #7C3AED; }
    .badge-question { background: #DBEAFE; color: #1D4ED8; }
    .badge-announcement { background: #FEE2E2; color: #991B1B; }
    .badge-beginner { background: #D1FAE5; color: #065F46; }
    .badge-intermediate { background: #DBEAFE; color: #1D4ED8; }
    .badge-advanced { background: #FEE2E2; color: #991B1B; }

    /* ── BUTTONS ── */
    .btn { display: inline-flex; align-items: center; gap: .4rem; padding: .5rem 1.1rem; border-radius: 8px; font-weight: 600; font-size: .82rem; border: none; transition: all .15s; }
    .btn-primary { background: #0EA5E9; color: #fff; }
    .btn-primary:hover { background: #0284C7; }
    .btn-orange { background: #F97316; color: #fff; }
    .btn-orange:hover { background: #EA6C0A; }
    .btn-outline { background: transparent; border: 1.5px solid #E2E8F0; color: #334155; }
    .btn-outline:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .btn-success { background: #10B981; color: #fff; }
    .btn-success:hover { background: #059669; }
    .btn-danger { background: #EF4444; color: #fff; }
    .btn-danger:hover { background: #DC2626; }
    .btn-sm { padding: .3rem .75rem; font-size: .78rem; border-radius: 6px; }
    .btn-xs { padding: .2rem .55rem; font-size: .72rem; border-radius: 5px; }

    /* ── FORMS ── */
    .form-control {
      width: 100%; padding: .55rem .9rem; border: 1.5px solid #E2E8F0;
      border-radius: 8px; font-size: .85rem; outline: none;
      background: #fff; font-family: inherit; color: #334155;
      transition: border .15s;
    }
    .form-control:focus { border-color: #0EA5E9; }
    .form-control-xs { padding: .3rem .6rem; font-size: .78rem; border-radius: 6px; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-weight: 600; font-size: .82rem; color: #475569; margin-bottom: .35rem; }
    .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: .75rem; }
    .form-actions { display: flex; gap: .75rem; margin-top: 1.25rem; }
    .inline-form { display: inline-flex; gap: .35rem; align-items: center; }

    /* ── FILTER BAR ── */
    .filter-bar { display: flex; gap: .75rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .filter-bar .form-control { width: auto; }

    /* ── PENDING ITEM ── */
    .pending-item { display: flex; align-items: center; justify-content: space-between; padding: .9rem 1.5rem; border-bottom: 1px solid #F1F5F9; gap: 1rem; }
    .pending-item:last-child { border-bottom: none; }
    .pending-item-info strong { font-size: .88rem; font-weight: 600; color: #0F172A; display: block; }
    .pending-item-info span { font-size: .75rem; color: #94A3B8; }
    .pending-item-actions { display: flex; gap: .5rem; flex-shrink: 0; }

    /* ── EMPTY ── */
    .empty-box { text-align: center; padding: 2.5rem 1rem; color: #94A3B8; }
    .empty-box i { font-size: 2.5rem; margin-bottom: .75rem; display: block; }
    .empty-box p { font-size: .88rem; }

    /* ── PAGINATION ── */
    .pagination { display: flex; align-items: center; justify-content: center; gap: .5rem; padding: 1.25rem; border-top: 1px solid #F1F5F9; }
    .page-btn { padding: .4rem .9rem; border-radius: 8px; border: 1.5px solid #E2E8F0; font-size: .82rem; font-weight: 600; color: #334155; background: #fff; transition: all .15s; }
    .page-btn:hover { border-color: #0EA5E9; color: #0EA5E9; }
    .page-info { font-size: .82rem; color: #94A3B8; padding: 0 .5rem; }

    /* ── SETTINGS ── */
    .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

    /* ── ACTIVITY ITEM ── */
    .activity-item { display: flex; gap: .85rem; padding: .85rem 1.5rem; border-bottom: 1px solid #F1F5F9; }
    .activity-item:last-child { border-bottom: none; }
    .activity-dot { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; font-size: .85rem; flex-shrink: 0; }
    .activity-info strong { font-size: .85rem; font-weight: 600; color: #0F172A; display: block; }
    .activity-info span { font-size: .75rem; color: #94A3B8; }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }
  </style>
</head>
<body>

<!-- ── SIDEBAR ────────────────────────────────────────────────────────────── -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon">D</div>
    <div class="brand-text">
      <strong>Diskas</strong>
      <span>Admin Panel</span>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Main</div>
    <a href="/admin" class="nav-item <%= title === 'Admin Dashboard' ? 'active' : '' %>">
      <i class="fa-solid fa-gauge-high"></i> Dashboard
    </a>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Community</div>
    <a href="/admin/users" class="nav-item <%= title === 'Manage Users' ? 'active' : '' %>">
      <i class="fa-solid fa-users"></i> Users
    </a>
    <a href="/admin/posts" class="nav-item <%= title === 'Manage Posts' ? 'active' : '' %>">
      <i class="fa-solid fa-comments"></i> Posts & Discussions
    </a>
    <a href="/admin/reports" class="nav-item <%= title === 'Reports' ? 'active' : '' %>">
      <i class="fa-solid fa-flag"></i> Reports
      <% /* badge shown dynamically */ %>
    </a>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Content</div>
    <a href="/admin/jobs" class="nav-item <%= title === 'Manage Jobs' ? 'active' : '' %>">
      <i class="fa-solid fa-briefcase"></i> Jobs
    </a>
    <a href="/admin/skills" class="nav-item <%= title === 'Manage Skills' ? 'active' : '' %>">
      <i class="fa-solid fa-book-open"></i> Skills
    </a>
    <a href="/admin/categories" class="nav-item <%= title === 'Categories' ? 'active' : '' %>">
      <i class="fa-solid fa-tags"></i> Categories
    </a>
  </div>

  <% if (currentUser && currentUser.role === 'admin') { %>
  <div class="sidebar-section">
    <div class="sidebar-section-label">System</div>
    <a href="/admin/settings" class="nav-item <%= title === 'Site Settings' ? 'active' : '' %>">
      <i class="fa-solid fa-sliders"></i> Settings
    </a>
  </div>
  <% } %>

  <div class="sidebar-divider"></div>

  <div class="sidebar-section">
    <a href="/" class="nav-item">
      <i class="fa-solid fa-arrow-up-right-from-square"></i> View Site
    </a>
    <a href="/auth/logout" class="nav-item" style="color:#F87171">
      <i class="fa-solid fa-right-from-bracket"></i> Logout
    </a>
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-user-avatar">
        <%= currentUser ? currentUser.name.charAt(0).toUpperCase() : 'A' %>
      </div>
      <div class="sidebar-user-info">
        <strong><%= currentUser ? currentUser.name : 'Admin' %></strong>
        <span><%= currentUser ? currentUser.role : '' %></span>
      </div>
    </div>
  </div>
</aside>

<!-- ── MAIN ───────────────────────────────────────────────────────────────── -->
<div class="main">

  <!-- Topbar -->
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-title"><%= title %></div>
      <div class="topbar-breadcrumb">
        <i class="fa-solid fa-house" style="font-size:.65rem"></i>
        Admin &rsaquo; <span><%= title %></span>
      </div>
    </div>
    <div class="topbar-right">
      <a href="/admin/reports" class="topbar-btn" title="Reports">
        <i class="fa-solid fa-flag"></i>
      </a>
      <a href="/" class="topbar-btn" title="View Site">
        <i class="fa-solid fa-globe"></i>
      </a>
      <div class="topbar-user">
        <div class="topbar-user-avatar">
          <%= currentUser ? currentUser.name.charAt(0).toUpperCase() : 'A' %>
        </div>
        <span><%= currentUser ? currentUser.name : 'Admin' %></span>
      </div>
    </div>
  </div>

  <!-- Flash Messages -->
  <% if (flashSuccess && flashSuccess.length) { %>
    <div class="flash flash-success"><i class="fa-solid fa-circle-check"></i> <%= flashSuccess[0] %></div>
  <% } %>
  <% if (flashError && flashError.length) { %>
    <div class="flash flash-error"><i class="fa-solid fa-circle-xmark"></i> <%= flashError[0] %></div>
  <% } %>
  <% if (flashInfo && flashInfo.length) { %>
    <div class="flash flash-info"><i class="fa-solid fa-circle-info"></i> <%= flashInfo[0] %></div>
  <% } %>

  <!-- Page Content -->
  <div class="content">
    <%- body %>
  </div>

</div>

<script>
  // Auto-hide flash
  document.querySelectorAll('.flash').forEach(f => {
    setTimeout(() => { f.style.transition = 'opacity .5s'; f.style.opacity = '0'; setTimeout(() => f.remove(), 500); }, 4000);
  });
</script>
</body>
</html>
