<div class="admin-filters">
  <form action="/admin/skills" method="GET" class="filter-form">
    <select name="status" class="form-select">
      <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
      <option value="active" <%= currentStatus === 'active' ? 'selected' : '' %>>Active</option>
      <option value="draft" <%= currentStatus === 'draft' ? 'selected' : '' %>>Draft/Rejected</option>
    </select>
    <button class="btn btn-primary">Filter</button>
  </form>
</div>

<div class="admin-card">
  <table class="admin-table">
    <thead><tr><th>Title</th><th>Author</th><th>Level</th><th>Views</th><th>Date</th><th>Actions</th></tr></thead>
    <tbody>
      <% skills.forEach(skill => { %>
        <tr>
          <td><a href="/skills/<%= skill.slug %>"><%= skill.title.substring(0,50) %></a></td>
          <td><%= skill.author_name %></td>
          <td><span class="badge badge-level-<%= skill.level %>"><%= skill.level %></span></td>
          <td><%= skill.views %></td>
          <td class="text-muted"><%= new Date(skill.created_at).toLocaleDateString() %></td>
          <td>
            <form action="/admin/skills/<%= skill.id %>" method="POST" class="inline-form">
              <select name="status" class="form-select form-select-xs">
                <option value="active" <%= skill.status === 'active' ? 'selected' : '' %>>Approve</option>
                <option value="pending" <%= skill.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="draft" <%= skill.status === 'draft' ? 'selected' : '' %>>Reject</option>
              </select>
              <button class="btn btn-sm btn-primary">Save</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
