<div class="page-header">
  <div class="container">
    <h1>Share a Skill</h1>
    <p>Help others learn by sharing your knowledge and expertise</p>
  </div>
</div>
<div class="container form-layout">
  <form action="/skills/new" method="POST" enctype="multipart/form-data" class="card">
    <div class="form-group">
      <label>Title <span class="required">*</span></label>
      <input type="text" name="title" placeholder="e.g. Introduction to Python Programming" required />
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Skill Level</label>
        <select name="level" class="form-select">
          <option value="beginner">Beginner</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </div>
      <div class="form-group">
        <label>Category</label>
        <select name="category_id" class="form-select">
          <option value="">— Select Category —</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>Description / Content <span class="required">*</span></label>
      <textarea name="description" rows="10" placeholder="Share your knowledge, step-by-step guide, or tutorial content..." required></textarea>
    </div>
    <div class="form-group">
      <label>Thumbnail Image</label>
      <input type="file" name="thumbnail" accept="image/*" />
    </div>
    <div class="form-group">
      <label>Video URL <span class="text-muted">(YouTube, Vimeo, etc.)</span></label>
      <input type="url" name="video_url" placeholder="https://youtube.com/watch?v=..." />
    </div>
    <div class="form-group">
      <label>Additional Resources <span class="text-muted">(links, books, tools)</span></label>
      <textarea name="resources" rows="4" placeholder="List helpful resources, books, tools, or links..."></textarea>
    </div>
    <div class="form-group">
      <label>Tags <span class="text-muted">(comma separated)</span></label>
      <input type="text" name="tags" placeholder="e.g. python, programming, beginners" />
    </div>
    <div class="form-actions">
      <a href="/skills" class="btn btn-outline">Cancel</a>
      <button type="submit" class="btn btn-primary">Submit Skill</button>
    </div>
  </form>
</div>
