<div class="page-header">
  <div class="container">
    <div class="page-header-row">
      <div>
        <h1>Learn New Skills</h1>
        <p>Community-shared guides, tutorials, and resources</p>
      </div>
      <% if (currentUser) { %>
        <a href="/skills/new" class="btn btn-primary">
          <i class="fa-solid fa-plus fa-sm"></i> Share a Skill
        </a>
      <% } else { %>
        <a href="/auth/register" class="btn btn-primary">
          <i class="fa-solid fa-user-plus fa-sm"></i> Join to Share
        </a>
      <% } %>
    </div>
  </div>
</div>

<div class="container main-layout">
  <aside class="sidebar">
    <div class="card">
      <h4 style="font-weight:700;margin-bottom:.5rem">Level</h4>
      <nav class="filter-nav" aria-label="Skill level filter">
        <a href="/skills<%= filters.category ? '?category=' + filters.category : '' %>"
           class="filter-item <%= !filters.level ? 'active' : '' %>">All Levels</a>
        <a href="/skills?level=beginner<%= filters.category ? '&category=' + filters.category : '' %>"
           class="filter-item <%= filters.level === 'beginner' ? 'active' : '' %>">
          <span class="badge badge-beginner" style="font-size:.7rem">Beginner</span>
        </a>
        <a href="/skills?level=intermediate<%= filters.category ? '&category=' + filters.category : '' %>"
           class="filter-item <%= filters.level === 'intermediate' ? 'active' : '' %>">
          <span class="badge badge-intermediate" style="font-size:.7rem">Intermediate</span>
        </a>
        <a href="/skills?level=advanced<%= filters.category ? '&category=' + filters.category : '' %>"
           class="filter-item <%= filters.level === 'advanced' ? 'active' : '' %>">
          <span class="badge badge-advanced" style="font-size:.7rem">Advanced</span>
        </a>
      </nav>
    </div>
    <div class="card mt-3">
      <h4 style="font-weight:700;margin-bottom:.5rem">Categories</h4>
      <nav class="filter-nav" aria-label="Category filter">
        <a href="/skills<%= filters.level ? '?level=' + filters.level : '' %>"
           class="filter-item <%= !filters.category ? 'active' : '' %>">All Categories</a>
        <% categories.forEach(cat => { %>
          <a href="/skills?category=<%= cat.slug %><%= filters.level ? '&level=' + filters.level : '' %>"
             class="filter-item <%= filters.category === cat.slug ? 'active' : '' %>"><%= cat.name %></a>
        <% }) %>
      </nav>
    </div>
  </aside>

  <div class="content-area">
    <% if (skills.length === 0) { %>
      <div class="empty-state card">
        <i class="fa-solid fa-book-open" style="font-size:2.5rem;color:#CBD5E1;display:block;margin-bottom:.75rem"></i>
        <h3>No skills found</h3>
        <p>Be the first to <a href="/skills/new">share a skill</a>!</p>
      </div>
    <% } else { %>
      <div class="skills-grid">
        <% skills.forEach(skill => { %>
          <a href="/skills/<%= skill.slug %>" class="skill-card"
             itemscope itemtype="https://schema.org/Course">
            <% if (skill.thumbnail) { %>
              <img src="<%= skill.thumbnail %>" alt="<%= skill.title %>" class="skill-thumb" loading="lazy" itemprop="image" />
            <% } else { %>
              <div class="skill-thumb-placeholder" aria-hidden="true">
                <i class="fa-solid fa-book fa-2x"></i>
              </div>
            <% } %>
            <div class="skill-card-body">
              <span class="badge badge-level-<%= skill.level %>"><%= skill.level %></span>
              <% if (skill.category_name) { %>
                <span class="badge" style="background:<%= skill.category_color %>22;color:<%= skill.category_color %>"><%= skill.category_name %></span>
              <% } %>
              <h3 itemprop="name"><%= skill.title %></h3>
              <p class="skill-author">by <span itemprop="author"><%= skill.author_name %></span></p>
              <% if (skill.description) { %>
                <p class="skill-desc"><%= skill.description.substring(0, 80) %><%= skill.description.length > 80 ? '…' : '' %></p>
              <% } %>
              <div class="skill-meta">
                <span><i class="fa-regular fa-eye fa-xs"></i> <%= skill.views %> views</span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>

      <% if (pagination.totalPages > 1) { %>
        <nav class="pagination" aria-label="Page navigation">
          <% if (pagination.hasPrev) { %><a href="?page=<%= pagination.page - 1 %>" class="page-btn">‹ Prev</a><% } %>
          <span class="page-info">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
          <% if (pagination.hasNext) { %><a href="?page=<%= pagination.page + 1 %>" class="page-btn">Next ›</a><% } %>
        </nav>
      <% } %>
    <% } %>
  </div>
</div>
