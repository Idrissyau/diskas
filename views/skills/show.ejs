<div class="container post-layout">
  <div class="post-main">
    <article class="card skill-detail" itemscope itemtype="https://schema.org/Course">
      <% if (skill.thumbnail) { %>
        <img src="<%= skill.thumbnail %>" alt="<%= skill.title %>" class="skill-detail-thumb" loading="lazy" itemprop="image" />
      <% } %>
      <div class="skill-detail-header">
        <div class="post-badges">
          <span class="badge badge-level-<%= skill.level %>"><%= skill.level %></span>
          <% if (skill.category_name) { %>
            <span class="badge" style="background:<%= skill.category_color %>22;color:<%= skill.category_color %>"><%= skill.category_name %></span>
          <% } %>
        </div>
        <h1 itemprop="name"><%= skill.title %></h1>
        <div class="skill-author-row">
          <a href="/users/<%= skill.user_id %>" class="author-avatar-link">
            <% if (skill.author_avatar) { %>
              <img src="<%= skill.author_avatar %>" alt="<%= skill.author_name %>" class="avatar-sm" loading="lazy" />
            <% } else { %>
              <div class="avatar-placeholder-sm" aria-hidden="true"><%= (skill.author_name||'U').charAt(0) %></div>
            <% } %>
          </a>
          <span>by <a href="/users/<%= skill.user_id %>" itemprop="author" class="author-name-link"><strong><%= skill.author_name %></strong></a></span>
          <span class="text-muted">
            <time itemprop="datePublished" datetime="<%= skill.created_at %>"><%= skill.timeAgo %></time>
          </span>
          <span class="text-muted"><i class="fa-regular fa-eye fa-xs"></i> <%= skill.views %> views</span>
        </div>
      </div>

      <% if (skill.video_url) { %>
        <div class="video-embed">
          <iframe
            src="<%= skill.video_url.replace('watch?v=','embed/').replace('youtu.be/','www.youtube.com/embed/') %>"
            title="<%= skill.title %> video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen loading="lazy">
          </iframe>
        </div>
      <% } %>

      <div class="content-section" itemprop="description">
        <h2>About this Skill</h2>
        <div class="prose"><%= skill.description %></div>
      </div>

      <% if (skill.resources) { %>
        <div class="content-section">
          <h2>Resources &amp; References</h2>
          <div class="prose"><%= skill.resources %></div>
        </div>
      <% } %>

      <% if (skill.tags) { %>
        <div class="skill-tags">
          <% skill.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(tag => { %>
            <a href="/skills?q=<%= encodeURIComponent(tag) %>" class="tag">
              <i class="fa-solid fa-hashtag fa-xs"></i> <%= tag %>
            </a>
          <% }) %>
        </div>
      <% } %>
    </article>
  </div>

  <aside class="post-sidebar">
    <div class="card">
      <h4 style="font-weight:700;margin-bottom:1rem">
        <i class="fa-solid fa-chalkboard-user fa-sm" style="color:#0EA5E9"></i> Instructor
      </h4>
      <div class="sidebar-author">
        <a href="/users/<%= skill.user_id %>" class="author-avatar-link">
          <% if (skill.author_avatar) { %>
            <img src="<%= skill.author_avatar %>" alt="<%= skill.author_name %>" class="avatar-md" loading="lazy" />
          <% } else { %>
            <div class="avatar-placeholder-md" aria-hidden="true"><%= (skill.author_name||'U').charAt(0) %></div>
          <% } %>
        </a>
        <a href="/users/<%= skill.user_id %>" class="author-name-link"><strong><%= skill.author_name %></strong></a>
        <% if (skill.author_bio) { %><p class="text-muted" style="font-size:.85rem;margin:.4rem 0"><%= skill.author_bio %></p><% } %>
        <div class="sidebar-author-actions">
          <a href="/users/<%= skill.user_id %>" class="btn btn-outline btn-sm">
            <i class="fa-solid fa-user fa-xs"></i> View Profile
          </a>
          <% if (currentUser && currentUser.id !== skill.user_id) { %>
            <form action="/messages" method="POST" style="display:inline">
              <input type="hidden" name="user_id" value="<%= skill.user_id %>" />
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-comment fa-xs"></i> Message
              </button>
            </form>
          <% } %>
        </div>
      </div>
    </div>

    <div class="card">
      <h4 style="font-weight:700;margin-bottom:.75rem">Skill Details</h4>
      <ul class="summary-list">
        <li><span>Level</span> <span class="badge badge-level-<%= skill.level %>"><%= skill.level %></span></li>
        <% if (skill.category_name) { %>
          <li><span>Category</span> <strong><%= skill.category_name %></strong></li>
        <% } %>
        <li><span>Views</span> <strong><%= skill.views %></strong></li>
      </ul>
    </div>

    <% if (related.length) { %>
      <div class="card">
        <h4 style="font-weight:700;margin-bottom:.75rem">
          <i class="fa-solid fa-book fa-xs" style="color:#0EA5E9"></i> Related Skills
        </h4>
        <% related.forEach(r => { %>
          <a href="/skills/<%= r.slug %>" class="related-item"><%= r.title %></a>
        <% }) %>
      </div>
    <% } %>

    <div class="card">
      <h4 style="font-weight:700;margin-bottom:.75rem">Share your knowledge</h4>
      <a href="/skills/new" class="btn btn-primary btn-sm btn-full">
        <i class="fa-solid fa-plus fa-xs"></i> Share a Skill
      </a>
    </div>
  </aside>
</div>
