<%
  const handle    = profile.username ? '@' + profile.username : null;
  const isAdmin   = ['admin','moderator'].includes(profile.role);
  const joinDate  = profile.created_at ? new Date(profile.created_at) : null;
  const joinYear  = joinDate ? joinDate.getFullYear() : '';
  const joinMonth = joinDate ? joinDate.toLocaleString('en-US',{month:'long'}) : '';
%>

<!-- Cover Banner -->
<div class="tw-cover">
  <% if (profile.cover_image) { %>
    <img src="<%= profile.cover_image %>" alt="Cover" class="tw-cover-img" />
  <% } %>
</div>

<!-- Profile body -->
<div class="tw-profile-wrap">

  <!-- Avatar + action buttons row -->
  <div class="tw-top-row">
    <div class="tw-avatar-wrap">
      <% if (profile.avatar) { %>
        <img src="<%= profile.avatar %>" alt="<%= profile.name %>" class="tw-avatar" />
      <% } else { %>
        <div class="tw-avatar tw-avatar-placeholder"><%= profile.name.charAt(0).toUpperCase() %></div>
      <% } %>
    </div>

    <div class="tw-actions">
      <% if (currentUser && currentUser.id === profile.id) { %>
        <a href="/profile" class="btn btn-outline btn-sm">
          <i class="fa-solid fa-pen fa-xs"></i> Edit Profile
        </a>
      <% } else { %>
        <% if (canMessage) { %>
          <% if (existingConvId) { %>
            <a href="/messages/<%= existingConvId %>" class="btn btn-outline btn-sm">
              <i class="fa-solid fa-comment fa-xs"></i> Message
            </a>
          <% } else { %>
            <form action="/messages" method="POST" style="display:inline">
              <input type="hidden" name="user_id" value="<%= profile.id %>" />
              <button type="submit" class="btn btn-outline btn-sm">
                <i class="fa-solid fa-comment fa-xs"></i> Message
              </button>
            </form>
          <% } %>
        <% } %>
        <% if (canFollow) { %>
          <button id="followBtn"
            class="btn <%= isFollowing ? 'btn-follow-active' : 'btn-primary' %> btn-sm"
            data-user-id="<%= profile.id %>"
            data-following="<%= isFollowing %>">
            <% if (isFollowing) { %>
              <i class="fa-solid fa-user-check fa-xs"></i> <span>Following</span>
            <% } else { %>
              <i class="fa-solid fa-user-plus fa-xs"></i> <span>Follow</span>
            <% } %>
          </button>
        <% } %>
      <% } %>
    </div>
  </div>

  <!-- Name / handle / badge -->
  <div class="tw-name-row">
    <h1 class="tw-name">
      <%= profile.name %>
      <% if (isAdmin) { %>
        <i class="fa-solid fa-circle-check tw-verified" title="<%= profile.role %>"></i>
      <% } %>
    </h1>
    <% if (handle) { %><p class="tw-handle"><%= handle %></p><% } %>
  </div>

  <!-- Bio -->
  <% if (profile.bio) { %>
    <p class="tw-bio"><%= profile.bio %></p>
  <% } %>

  <!-- Meta row -->
  <div class="tw-meta-row">
    <% if (profile.location) { %>
      <span><i class="fa-solid fa-location-dot fa-xs"></i> <%= profile.location %></span>
    <% } %>
    <% if (profile.website) { %>
      <a href="<%= profile.website %>" target="_blank" rel="noopener noreferrer">
        <i class="fa-solid fa-link fa-xs"></i>
        <%= profile.website.replace(/^https?:\/\/(www\.)?/,'').replace(/\/$/, '') %>
      </a>
    <% } %>
    <% if (joinDate) { %><span><i class="fa-regular fa-calendar fa-xs"></i> Joined <%= joinMonth %> <%= joinYear %></span><% } %>
  </div>

  <!-- Stats row -->
  <div class="tw-stats-row">
    <a href="/users/<%= profile.id %>/following" class="tw-stat">
      <strong><%= followingCount %></strong> Following
    </a>
    <a href="/users/<%= profile.id %>/followers" class="tw-stat">
      <strong><%= followerCount %></strong> Followers
    </a>
    <span class="tw-stat">
      <strong><%= posts.length %></strong> Posts
    </span>
  </div>

  <!-- Tab bar -->
  <div class="tw-tabs">
    <span class="tw-tab active" data-tab="posts">Posts</span>
    <% if (communities && communities.length > 0) { %>
      <span class="tw-tab" data-tab="communities">
        Communities <span class="tw-tab-badge"><%= communities.length %></span>
      </span>
    <% } %>
  </div>

  <!-- Posts feed -->
  <div class="tw-feed" id="tabPosts">
    <% if (posts.length === 0) { %>
      <div class="tw-empty">
        <i class="fa-solid fa-feather-pointed"></i>
        <p><%= profile.name %> hasn't posted anything yet.</p>
      </div>
    <% } else { %>
      <% posts.forEach(post => { %>
        <article class="tw-post-item">
          <div class="tw-post-avatar">
            <% if (profile.avatar) { %>
              <img src="<%= profile.avatar %>" alt="<%= profile.name %>" class="avatar-sm" />
            <% } else { %>
              <div class="avatar-placeholder-sm"><%= profile.name.charAt(0).toUpperCase() %></div>
            <% } %>
          </div>
          <div class="tw-post-body">
            <div class="tw-post-header">
              <span class="tw-post-author"><%= profile.name %></span>
              <% if (handle) { %><span class="tw-post-handle"><%= handle %></span><% } %>
              <span class="tw-post-dot">·</span>
              <span class="tw-post-time"><%= post.timeAgo %></span>
            </div>
            <a href="/discussions/<%= post.slug %>" class="tw-post-title"><%= post.title %></a>
            <div class="tw-post-stats">
              <span><i class="fa-solid fa-arrow-up fa-xs"></i> <%= post.vote_count || 0 %></span>
              <span><i class="fa-regular fa-comment fa-xs"></i> <%= post.reply_count || 0 %></span>
              <span><i class="fa-regular fa-eye fa-xs"></i> <%= post.views || 0 %></span>
            </div>
          </div>
        </article>
      <% }) %>
    <% } %>
  </div>

  <!-- Communities tab -->
  <% if (communities && communities.length > 0) { %>
  <div class="tw-feed" id="tabCommunities" style="display:none">
    <div class="prof-comm-grid">
      <% communities.forEach(comm => { %>
        <div class="prof-comm-card">
          <!-- Cover -->
          <div class="prof-comm-cover">
            <% if (comm.cover_image) { %>
              <img src="<%= comm.cover_image %>" alt="" />
            <% } else { %>
              <div class="prof-comm-cover-default"></div>
            <% } %>
            <% if (comm.is_private) { %>
              <span class="prof-comm-private"><i class="fa-solid fa-lock"></i> Private</span>
            <% } %>
          </div>
          <!-- Body -->
          <div class="prof-comm-body">
            <div class="prof-comm-avatar-wrap">
              <% if (comm.avatar) { %>
                <img src="<%= comm.avatar %>" alt="<%= comm.name %>" class="prof-comm-avatar" />
              <% } else { %>
                <div class="prof-comm-avatar prof-comm-avatar-placeholder"><%= comm.name.charAt(0).toUpperCase() %></div>
              <% } %>
            </div>
            <h3 class="prof-comm-name"><a href="/communities/<%= comm.slug %>"><%= comm.name %></a></h3>
            <p class="prof-comm-members"><i class="fa-solid fa-users fa-xs"></i> <%= comm.member_count %> member<%= comm.member_count !== 1 ? 's' : '' %></p>
            <a href="/communities/<%= comm.slug %>" class="btn btn-primary btn-sm prof-comm-join-btn">
              View Community
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

</div><!-- /tw-profile-wrap -->

<script>
/* ── Follow toggle ── */
const followBtn = document.getElementById('followBtn');
if (followBtn) {
  followBtn.addEventListener('click', async () => {
    const userId = followBtn.dataset.userId;
    try {
      const res  = await fetch(`/users/${userId}/follow`, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await res.json();
      if (typeof data.following !== 'undefined') {
        if (data.following) {
          followBtn.className = 'btn btn-follow-active btn-sm';
          followBtn.innerHTML = '<i class="fa-solid fa-user-check fa-xs"></i> <span>Following</span>';
        } else {
          followBtn.className = 'btn btn-primary btn-sm';
          followBtn.innerHTML = '<i class="fa-solid fa-user-plus fa-xs"></i> <span>Follow</span>';
        }
      }
    } catch (e) { console.error(e); }
  });
}

/* ── Tab switching ── */
document.querySelectorAll('.tw-tab[data-tab]').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tw-tab[data-tab]').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const target = tab.dataset.tab;
    document.getElementById('tabPosts').style.display       = target === 'posts'       ? '' : 'none';
    const commTab = document.getElementById('tabCommunities');
    if (commTab) commTab.style.display = target === 'communities' ? '' : 'none';
  });
});
</script>
