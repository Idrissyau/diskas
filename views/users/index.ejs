<div class="comm-hero">
  <div class="container">
    <div class="comm-hero-inner">
      <div>
        <h1 class="comm-hero-title">Find People</h1>
        <p class="comm-hero-sub">Connect with professionals, learners, and creators on Diskas.</p>
      </div>
    </div>
    <form action="/users" method="GET" class="comm-search-bar">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="search" name="q" placeholder="Search by name, username, or bio…"
             value="<%= searchQ %>" autocomplete="off" />
      <button type="submit" class="btn btn-primary btn-sm">Search</button>
    </form>
  </div>
</div>

<div class="container users-page-wrap">
  <% if (users.length === 0) { %>
    <div class="comm-empty">
      <div class="comm-empty-icon"><i class="fa-solid fa-users"></i></div>
      <h3><%= searchQ ? 'No users match your search.' : 'No users found.' %></h3>
    </div>
  <% } else { %>
    <div class="users-grid">
      <% users.forEach(u => { %>
        <div class="user-card card">
          <!-- Avatar -->
          <a href="/users/<%= u.id %>" class="user-card-avatar-link">
            <% if (u.avatar) { %>
              <img src="<%= u.avatar %>" alt="<%= u.name %>" class="user-card-avatar" />
            <% } else { %>
              <div class="user-card-avatar user-card-avatar-placeholder"><%= u.name.charAt(0).toUpperCase() %></div>
            <% } %>
          </a>

          <!-- Info -->
          <div class="user-card-info">
            <a href="/users/<%= u.id %>" class="user-card-name"><%= u.name %></a>
            <% if (u.username) { %>
              <span class="user-card-handle">@<%= u.username %></span>
            <% } %>
            <% if (u.role === 'admin') { %>
              <span class="badge badge-admin" style="font-size:.68rem">Admin</span>
            <% } else if (u.role === 'moderator') { %>
              <span class="badge badge-moderator" style="font-size:.68rem">Mod</span>
            <% } %>
          </div>

          <% if (u.bio) { %>
            <p class="user-card-bio"><%= u.bio.length > 72 ? u.bio.substring(0,72)+'…' : u.bio %></p>
          <% } %>

          <div class="user-card-followers">
            <i class="fa-solid fa-users"></i>
            <%= u.follower_count %> follower<%= u.follower_count !== 1 ? 's' : '' %>
          </div>

          <% if (!u.isMe && currentUser) { %>
            <button class="btn btn-sm <%= u.isFollowing ? 'btn-follow-active' : 'btn-primary' %> user-card-follow-btn"
                    onclick="toggleFollow(<%= u.id %>, this)">
              <i class="fa-solid <%= u.isFollowing ? 'fa-user-check' : 'fa-user-plus' %>"></i>
              <%= u.isFollowing ? 'Following' : 'Follow' %>
            </button>
          <% } else if (!currentUser) { %>
            <a href="/auth/login" class="btn btn-sm btn-primary user-card-follow-btn">
              <i class="fa-solid fa-user-plus"></i> Follow
            </a>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
async function toggleFollow(userId, btn) {
  try {
    const r = await fetch(`/users/${userId}/follow`, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const d = await r.json();
    if (d.following) {
      btn.className = btn.className.replace('btn-primary','btn-follow-active');
      btn.innerHTML = '<i class="fa-solid fa-user-check"></i> Following';
    } else {
      btn.className = btn.className.replace('btn-follow-active','btn-primary');
      btn.innerHTML = '<i class="fa-solid fa-user-plus"></i> Follow';
    }
  } catch(e) { console.error(e); }
}
</script>
