<%# Public landing page — rendered server-side from JSON blocks %>

<% if (isOwnerPreview) { %>
<div style="background:#f59e0b;color:#fff;text-align:center;padding:10px 16px;font-size:.85rem;font-weight:600;position:sticky;top:0;z-index:9999">
  <i class="fa-solid fa-eye"></i> Preview Mode — This page is a <strong>Draft</strong> and not visible to the public.
  <a href="/pages/<%= page.id %>/edit" style="color:#fff;text-decoration:underline;margin-left:12px">Edit Page</a>
</div>
<% } %>

<%
// ── Helpers ──────────────────────────────────────────────────────────────
function he(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function getVideoEmbed(url) {
  if (!url) return '';
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([A-Za-z0-9_-]{11})/);
  if (yt) return 'https://www.youtube.com/embed/' + yt[1];
  const vi = url.match(/vimeo\.com\/(\d+)/);
  if (vi) return 'https://player.vimeo.com/video/' + vi[1];
  return url;
}

function renderBlock(block) {
  const d = block.data || {};
  switch (block.type) {

    case 'hero': {
      const heroBgStyle = d.bgImage
        ? `background:${he(d.bgColor||'#1e1b4b')};background-image:url(${he(d.bgImage)});background-size:cover;background-position:center`
        : `background:${he(d.bgColor||'#1e1b4b')}`;
      return `<section class="pub-hero" style="${heroBgStyle};color:${he(d.textColor||'#fff')};text-align:${he(d.align||'center')};position:relative;overflow:hidden">
        ${d.bgVideo ? `<video autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;opacity:.7"><source src="${he(d.bgVideo)}" type="video/mp4" /></video>` : ''}
        <div class="pub-container" style="position:relative;z-index:1">
          ${d.image ? `<img src="${he(d.image)}" class="pub-hero-img" alt="" />` : ''}
          <h1 class="pub-hero-h1">${he(d.heading||'')}</h1>
          ${d.subheading ? `<p class="pub-hero-sub">${he(d.subheading)}</p>` : ''}
          ${d.btnText ? `<a href="${he(d.btnUrl||'#')}" class="pub-btn" style="background:${he(d.btnColor||'#6366f1')};color:#fff">${he(d.btnText)}</a>` : ''}
        </div>
      </section>`;
    }

    case 'text':
      return `<section class="pub-text"><div class="pub-container pub-prose">${d.html||''}</div></section>`;

    case 'features': {
      const items = d.items || [];
      return `<section class="pub-features">
        <div class="pub-container">
          ${d.heading ? `<h2 class="pub-section-title">${he(d.heading)}</h2>` : ''}
          <ul class="pub-feat-list">
            ${items.map(i=>`<li>${he(i)}</li>`).join('')}
          </ul>
        </div>
      </section>`;
    }

    case 'cta':
      return `<section class="pub-cta" style="background:${he(d.bgColor||'#6366f1')};color:${he(d.textColor||'#fff')}">
        <div class="pub-container" style="text-align:center">
          <h2 class="pub-cta-h2">${he(d.heading||'')}</h2>
          ${d.sub ? `<p class="pub-cta-sub">${he(d.sub)}</p>` : ''}
          ${d.btnText ? `<a href="${he(d.btnUrl||'#')}" class="pub-btn" style="background:${he(d.textColor||'#fff')};color:${he(d.bgColor||'#6366f1')}">${he(d.btnText)}</a>` : ''}
        </div>
      </section>`;

    case 'image':
      return `<section class="pub-image">
        <div class="pub-container" style="text-align:center">
          ${d.url ? `<img src="${he(d.url)}" alt="${he(d.alt||'')}" style="border-radius:${he(d.radius||'10')}px;max-width:100%" />` : ''}
          ${d.caption ? `<p class="pub-caption">${he(d.caption)}</p>` : ''}
        </div>
      </section>`;

    case 'video': {
      const embed = getVideoEmbed(d.url||'');
      return `<section class="pub-video">
        <div class="pub-container">
          ${embed ? `<div class="pub-video-wrap"><iframe src="${he(embed)}" frameborder="0" allowfullscreen></iframe></div>` : ''}
        </div>
      </section>`;
    }

    case 'countdown': {
      const target = d.targetDate ? new Date(d.targetDate).getTime() : 0;
      const diff   = Math.max(0, target - Date.now());
      const days   = Math.floor(diff/86400000);
      const hrs    = Math.floor((diff%86400000)/3600000);
      const mins   = Math.floor((diff%3600000)/60000);
      const secs   = Math.floor((diff%60000)/1000);
      const pad    = n => String(n).padStart(2,'0');
      return `<section class="pub-countdown" style="color:${he(d.textColor||'#1e293b')}">
        <div class="pub-container" style="text-align:center">
          ${d.label ? `<p class="pub-cd-label">${he(d.label)}</p>` : ''}
          <div class="pub-cd-timer" data-target="${he(d.targetDate||'')}">
            <div class="pub-cd-unit"><div class="pub-cd-num" id="pub-days">${pad(days)}</div><div class="pub-cd-lbl">days</div></div>
            <div class="pub-cd-unit"><div class="pub-cd-num" id="pub-hrs">${pad(hrs)}</div><div class="pub-cd-lbl">hours</div></div>
            <div class="pub-cd-unit"><div class="pub-cd-num" id="pub-mins">${pad(mins)}</div><div class="pub-cd-lbl">mins</div></div>
            <div class="pub-cd-unit"><div class="pub-cd-num" id="pub-secs">${pad(secs)}</div><div class="pub-cd-lbl">secs</div></div>
          </div>
        </div>
      </section>`;
    }

    case 'testimonial': {
      const items = d.items || [];
      return `<section class="pub-testi">
        <div class="pub-container">
          ${d.heading ? `<h2 class="pub-section-title">${he(d.heading)}</h2>` : ''}
          <div class="pub-testi-grid">
            ${items.map(t=>`<div class="pub-testi-card">
              <div class="pub-testi-quote">${he(t.quote||'')}</div>
              <div class="pub-testi-name">${he(t.name||'')}</div>
              ${t.title ? `<div class="pub-testi-role">${he(t.title)}</div>` : ''}
            </div>`).join('')}
          </div>
        </div>
      </section>`;
    }

    case 'faq': {
      const items = d.items || [];
      return `<section class="pub-faq">
        <div class="pub-container">
          ${d.heading ? `<h2 class="pub-section-title">${he(d.heading)}</h2>` : ''}
          ${items.map((f,i)=>`<details class="pub-faq-item">
            <summary class="pub-faq-q">${he(f.q||'')} <i class="fa-solid fa-chevron-down pub-faq-icon"></i></summary>
            <div class="pub-faq-a">${he(f.a||'')}</div>
          </details>`).join('')}
        </div>
      </section>`;
    }

    case 'columns':
      return `<section class="pub-columns">
        <div class="pub-container">
          <div class="pub-cols-grid">
            <div class="pub-prose">${d.col1||''}</div>
            <div class="pub-prose">${d.col2||''}</div>
          </div>
        </div>
      </section>`;

    case 'divider':
      return `<div class="pub-divider" style="padding:${he(d.paddingV||'16')}px 0">
        <div class="pub-container"><hr style="border:none;border-top:${he(d.thickness||'1')}px solid ${he(d.color||'#e2e8f0')}" /></div>
      </div>`;

    case 'spacer':
      return `<div style="height:${he(d.height||'60')}px"></div>`;

    case 'buy_button':
      return `<section class="pub-buy-btn" style="text-align:${he(d.align||'center')};padding:32px 24px">
        <a href="${he(d.url||'#')}" class="pub-btn" style="background:${he(d.color||'#6366f1')};color:${he(d.textColor||'#fff')};font-size:${d.size==='large'?'1.1rem':d.size==='small'?'.85rem':'1rem'}">
          ${d.icon?`<i class="fa-solid ${he(d.icon)}"></i> `:''}${he(d.text||'Buy Now')}
        </a>
        ${d.subtext?`<p style="margin-top:10px;font-size:.8rem;color:#94a3b8">${he(d.subtext)}</p>`:''}
      </section>`;

    case 'gallery': {
      const imgs = d.images || [];
      const cols = parseInt(d.cols||3);
      return `<section class="pub-gallery">
        <div class="pub-container">
          ${imgs.length ? `<div style="display:grid;grid-template-columns:repeat(${cols},1fr);gap:${he(d.gap||'12')}px">
            ${imgs.map(url=>`<img src="${he(url)}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:${he(d.radius||'8')}px" />`).join('')}
          </div>` : ''}
        </div>
      </section>`;
    }

    case 'product': {
      const layout = d.layout || 'horizontal';
      return `<section class="pub-product">
        <div class="pub-container">
          <div style="display:${layout==='horizontal'?'grid':'block'};grid-template-columns:1fr 1fr;gap:40px;align-items:center">
            <div>
              ${d.image ? `<img src="${he(d.image)}" style="width:100%;border-radius:14px;max-height:360px;object-fit:cover" alt="${he(d.name||'')}" />` : ''}
            </div>
            <div>
              ${d.badge?`<span style="background:#f59e0b;color:#fff;padding:3px 12px;border-radius:20px;font-size:.75rem;font-weight:700">${he(d.badge)}</span>`:''}
              <h2 style="font-size:1.8rem;font-weight:800;margin:12px 0 8px">${he(d.name||'')}</h2>
              <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px">
                <span style="font-size:2rem;font-weight:800;color:${he(d.btnColor||'#6366f1')}">${he(d.price||'')}</span>
                ${d.originalPrice?`<span style="font-size:1.1rem;text-decoration:line-through;color:#94a3b8">${he(d.originalPrice)}</span>`:''}
              </div>
              <p style="color:#64748b;line-height:1.75;margin-bottom:24px">${he(d.description||'')}</p>
              ${d.btnText?`<a href="${he(d.btnUrl||'#')}" class="pub-btn" style="background:${he(d.btnColor||'#6366f1')};color:#fff">${he(d.btnText)}</a>`:''}
            </div>
          </div>
        </div>
      </section>`;
    }

    case 'pricing': {
      const tiers = d.tiers || [];
      return `<section class="pub-pricing">
        <div class="pub-container">
          ${d.heading?`<h2 class="pub-section-title">${he(d.heading)}</h2>`:''}
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;max-width:860px;margin:0 auto">
            ${tiers.map(t=>`<div style="border:${t.highlight?'2px solid #6366f1':'1px solid #e2e8f0'};border-radius:14px;padding:28px;background:${t.highlight?'#eef2ff':'#fff'};text-align:center">
              ${t.highlight?`<div style="background:#6366f1;color:#fff;font-size:.72rem;font-weight:700;padding:3px 12px;border-radius:20px;display:inline-block;margin-bottom:10px">MOST POPULAR</div>`:''}
              <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:8px">${he(t.name||'')}</h3>
              <div style="font-size:2rem;font-weight:800;color:${t.highlight?'#6366f1':'#0f172a'}">${he(t.price||'')}</div>
              <div style="font-size:.78rem;color:#94a3b8;margin-bottom:16px">${he(t.period||'')}</div>
              <ul style="list-style:none;padding:0;margin:0 0 20px;font-size:.88rem;color:#374151;text-align:left">
                ${(t.features||[]).map(f=>`<li style="padding:6px 0;border-bottom:1px solid #f1f5f9">✅ ${he(f)}</li>`).join('')}
              </ul>
              ${t.btnText?`<a href="${he(t.btnUrl||'#')}" class="pub-btn" style="background:${t.highlight?'#6366f1':'#f1f5f9'};color:${t.highlight?'#fff':'#374151'};font-size:.85rem;padding:10px 20px;display:block">${he(t.btnText)}</a>`:''}
            </div>`).join('')}
          </div>
        </div>
      </section>`;
    }

    case 'trust': {
      const items = d.items || [];
      return `<section class="pub-trust" style="background:${he(d.bgColor||'#f8fafc')};padding:32px 24px">
        <div class="pub-container">
          ${d.heading?`<h3 style="text-align:center;font-size:1rem;font-weight:600;color:#64748b;margin-bottom:20px">${he(d.heading)}</h3>`:''}
          <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:24px">
            ${items.map(it=>`<div style="display:flex;align-items:center;gap:8px;color:#374151;font-size:.9rem;font-weight:600">
              <i class="fa-solid ${he(it.icon||'fa-check')}" style="color:#10b981;font-size:1.1rem"></i>
              ${he(it.label||'')}
            </div>`).join('')}
          </div>
        </div>
      </section>`;
    }

    case 'section': {
      const numCols = parseInt(d.cols||2);
      const colItems = d.items || Array.from({length:numCols}, ()=>[]);
      return `<section style="padding:${he(d.padding||'32')}px 0;background:${he(d.bgColor||'transparent')}">
        <div class="pub-container">
          <div style="display:grid;grid-template-columns:repeat(${numCols},1fr);gap:${he(d.gap||'24')}px">
            ${colItems.map(col=>`<div>${col.map(sb=>renderBlock(sb)).join('')}</div>`).join('')}
          </div>
        </div>
      </section>`;
    }

    case 'html':
      return `<div class="pub-html pub-container">${d.html||''}</div>`;

    default:
      return '';
  }
}
%>

<!-- Render all blocks -->
<% blocks.forEach(block => { %>
  <%- renderBlock(block) %>
<% }) %>

<% if (!blocks.length) { %>
<div style="text-align:center;padding:120px 24px;color:#94a3b8">
  <p style="font-size:1.1rem">This page has no content yet.</p>
</div>
<% } %>

<!-- Public page styles -->
<style>
  :root {
    --pub-primary: <%= page.primary_color || '#6366f1' %>;
    --pub-bg:      <%= page.bg_color      || '#ffffff' %>;
  }
  body {
    background: var(--pub-bg);
    <% if (bgImage) { %>
    background-image: url('<%= bgImage.replace(/'/g, "\\'") %>');
    background-size: cover;
    background-attachment: fixed;
    background-position: center;
    <% } %>
  }

  .pub-container { max-width: 860px; margin: 0 auto; padding: 0 24px; }

  /* Hero */
  .pub-hero { padding: 80px 24px; }
  .pub-hero-img { max-height: 300px; border-radius: 12px; margin-bottom: 24px; display: block; margin-left: auto; margin-right: auto; }
  .pub-hero-h1 { font-size: clamp(1.8rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: 16px; }
  .pub-hero-sub { font-size: 1.05rem; opacity: .85; max-width: 560px; margin: 0 auto 28px; line-height: 1.65; }
  .pub-btn { display: inline-block; padding: 14px 32px; border-radius: 10px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: opacity .2s; }
  .pub-btn:hover { opacity: .9; }

  /* Text */
  .pub-text { padding: 48px 0; }
  .pub-prose { line-height: 1.75; }
  .pub-prose h1,.pub-prose h2,.pub-prose h3,.pub-prose h4 { font-weight: 700; margin: 1.2em 0 .5em; }
  .pub-prose h2 { font-size: 1.6rem; }
  .pub-prose h3 { font-size: 1.25rem; }
  .pub-prose p  { margin-bottom: .9em; color: #374151; }
  .pub-prose ul,.pub-prose ol { margin: .75em 0 .75em 1.5em; }
  .pub-prose li { margin-bottom: .4em; }
  .pub-prose blockquote { border-left: 4px solid var(--pub-primary); padding: 12px 20px; margin: 1em 0; background: #f8fafc; border-radius: 0 8px 8px 0; }
  .pub-prose a { color: var(--pub-primary); }

  /* Features */
  .pub-features { padding: 48px 0; }
  .pub-section-title { font-size: 1.6rem; font-weight: 700; text-align: center; margin-bottom: 28px; }
  .pub-feat-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px; max-width: 560px; margin: 0 auto; }
  .pub-feat-list li { font-size: .98rem; color: #374151; padding: 10px 16px; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; }

  /* CTA */
  .pub-cta { padding: 72px 24px; }
  .pub-cta-h2 { font-size: 2rem; font-weight: 800; margin-bottom: 12px; }
  .pub-cta-sub { font-size: 1rem; opacity: .85; margin-bottom: 28px; }

  /* Image */
  .pub-image { padding: 32px 0; }
  .pub-caption { font-size: .83rem; color: #94a3b8; margin-top: 10px; }

  /* Video */
  .pub-video { padding: 32px 0; }
  .pub-video-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; }
  .pub-video-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border-radius: 12px; }

  /* Countdown */
  .pub-countdown { padding: 56px 0; }
  .pub-cd-label { font-size: .9rem; color: #64748b; font-weight: 500; margin-bottom: 16px; }
  .pub-cd-timer { display: inline-flex; gap: 16px; }
  .pub-cd-unit  { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .pub-cd-num   { font-size: 2.4rem; font-weight: 800; min-width: 72px; padding: 12px 8px; background: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0; text-align: center; line-height: 1; }
  .pub-cd-lbl   { font-size: .72rem; color: #94a3b8; text-transform: uppercase; letter-spacing: .05em; }

  /* Testimonials */
  .pub-testi { padding: 56px 0; }
  .pub-testi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }
  .pub-testi-card { background: #f8fafc; border-radius: 14px; padding: 24px; border: 1px solid #e2e8f0; }
  .pub-testi-quote { font-style: italic; color: #374151; font-size: .92rem; margin-bottom: 14px; line-height: 1.65; }
  .pub-testi-name { font-weight: 700; font-size: .88rem; color: #0f172a; }
  .pub-testi-role { font-size: .78rem; color: #94a3b8; margin-top: 2px; }

  /* FAQ */
  .pub-faq { padding: 56px 0; }
  .pub-faq-item { border-bottom: 1px solid #f1f5f9; }
  .pub-faq-item summary { list-style: none; }
  .pub-faq-item summary::-webkit-details-marker { display: none; }
  .pub-faq-q { font-weight: 600; color: #0f172a; font-size: .98rem; cursor: pointer; padding: 16px 0; display: flex; justify-content: space-between; align-items: center; }
  .pub-faq-icon { font-size: .75rem; color: #94a3b8; transition: transform .2s; }
  details[open] .pub-faq-icon { transform: rotate(180deg); }
  .pub-faq-a { font-size: .9rem; color: #64748b; padding-bottom: 16px; line-height: 1.7; }

  /* Columns */
  .pub-columns { padding: 48px 0; }
  .pub-cols-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  @media (max-width: 640px) { .pub-cols-grid { grid-template-columns: 1fr; } }

  /* HTML block */
  .pub-html { padding: 24px 0; }

  /* Divider */
  .pub-divider .pub-container { padding: 0 24px; }

  /* Gallery */
  .pub-gallery { padding: 32px 0; }

  /* Product */
  .pub-product { padding: 48px 0; }
  @media (max-width: 640px) { .pub-product div[style*="grid"] { display: block !important; } }

  /* Pricing */
  .pub-pricing { padding: 56px 0; }

  /* Trust */
  .pub-trust { }

  /* Buy Button */
  .pub-buy-btn { }
</style>

<!-- Countdown live tick -->
<script>
(function() {
  const timerEl = document.querySelector('.pub-cd-timer');
  if (!timerEl) return;
  const target = new Date(timerEl.dataset.target).getTime();
  if (!target || isNaN(target)) return;
  const pad = n => String(n).padStart(2,'0');
  function tick() {
    const diff = Math.max(0, target - Date.now());
    document.getElementById('pub-days').textContent = pad(Math.floor(diff/86400000));
    document.getElementById('pub-hrs').textContent  = pad(Math.floor((diff%86400000)/3600000));
    document.getElementById('pub-mins').textContent = pad(Math.floor((diff%3600000)/60000));
    document.getElementById('pub-secs').textContent = pad(Math.floor((diff%60000)/1000));
    if (diff > 0) setTimeout(tick, 1000);
  }
  tick();
})();
</script>

<% if (typeof customHTML !== 'undefined' && customHTML) { %>
<!-- Custom HTML (injected by page builder) -->
<%- customHTML %>
<% } %>

<% if (typeof customJS !== 'undefined' && customJS) { %>
<!-- Custom JS (injected by page builder) -->
<script>
<%- customJS %>
</script>
<% } %>
