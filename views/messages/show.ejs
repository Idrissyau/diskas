<div class="msg-shell">

  <!-- Sidebar -->
  <aside class="msg-sidebar">
    <div class="msg-sidebar-head">
      <a href="/messages" class="msg-back-mobile"><i class="fa-solid fa-arrow-left"></i></a>
      <h1 class="msg-sidebar-title">Messages</h1>
    </div>
    <div class="msg-conv-list">
      <% if (conversations.length === 0) { %>
        <div class="msg-empty-sidebar">
          <i class="fa-solid fa-comment-dots"></i>
          <p>No conversations yet</p>
        </div>
      <% } %>
      <% conversations.forEach(conv => { %>
        <a href="/messages/<%= conv.id %>"
           class="msg-conv-item <%= conv.id === activeConvId ? 'msg-conv-item--active' : '' %>">
          <div class="msg-conv-avatar">
            <% if (conv.other_avatar) { %>
              <img src="<%= conv.other_avatar %>" alt="<%= conv.other_name %>" />
            <% } else { %>
              <div class="msg-conv-initial"><%= conv.other_name.charAt(0).toUpperCase() %></div>
            <% } %>
            <% if (conv.unread > 0 && conv.id !== activeConvId) { %><span class="msg-unread-dot"></span><% } %>
          </div>
          <div class="msg-conv-body">
            <div class="msg-conv-top">
              <span class="msg-conv-name <%= conv.unread > 0 && conv.id !== activeConvId ? 'msg-conv-name--bold' : '' %>"><%= conv.other_name %></span>
              <span class="msg-conv-time"><%= conv.timeAgo %></span>
            </div>
            <p class="msg-conv-preview <%= conv.unread > 0 && conv.id !== activeConvId ? 'msg-conv-preview--bold' : '' %>">
              <% if (conv.last_msg) { %>
                <%= conv.last_msg.substring(0,55) + (conv.last_msg.length > 55 ? '…' : '') %>
              <% } else { %>
                <i class="fa-solid fa-paperclip" style="font-size:.75rem"></i> Attachment
              <% } %>
            </p>
          </div>
        </a>
      <% }) %>
    </div>
  </aside>

  <!-- Chat Panel -->
  <main class="msg-chat-panel" id="chatPanel">

    <!-- Header -->
    <div class="msg-chat-header">
      <a href="/messages" class="msg-back-btn"><i class="fa-solid fa-arrow-left"></i></a>
      <% if (other) { %>
        <a href="/users/<%= other.id %>" class="msg-chat-header-avatar">
          <% if (other.avatar) { %><img src="<%= other.avatar %>" alt="<%= other.name %>" />
          <% } else { %><div class="msg-chat-initial"><%= (other.name||'U').charAt(0).toUpperCase() %></div><% } %>
        </a>
        <div class="msg-chat-header-info">
          <a href="/users/<%= other.id %>" class="msg-chat-other-name"><%= other.name %></a>
          <span class="msg-chat-status">Active</span>
        </div>
        <div class="msg-chat-header-actions">
          <a href="/users/<%= other.id %>" class="msg-header-btn" title="View profile">
            <i class="fa-solid fa-user"></i>
          </a>
        </div>
      <% } %>
    </div>

    <!-- Messages -->
    <div class="msg-messages-area" id="chatMessages">
      <% if (messages.length === 0) { %>
        <div class="msg-chat-start" id="chatEmptyState">
          <% if (other && other.avatar) { %><img src="<%= other.avatar %>" alt="" class="msg-chat-start-avatar" />
          <% } else if (other) { %><div class="msg-chat-start-initial"><%= (other.name||'U').charAt(0) %></div><% } %>
          <p class="msg-chat-start-name"><%= other?.name %></p>
          <p class="msg-chat-start-hint">Say hello and start the conversation!</p>
        </div>
      <% } %>

      <% let lastDate = null; %>
      <% messages.forEach(msg => { %>
        <%
          const msgDate   = new Date(msg.created_at).toDateString();
          const today     = new Date().toDateString();
          const yesterday = new Date(Date.now()-86400000).toDateString();
          const dateLabel = msgDate===today?'Today':msgDate===yesterday?'Yesterday':new Date(msg.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
          const senderLabel = msg.isMine ? 'You' : (other ? other.name : 'User');
        %>
        <% if (msgDate !== lastDate) { %>
          <div class="msg-date-divider"><span><%= dateLabel %></span></div>
          <% lastDate = msgDate; %>
        <% } %>

        <div class="msg-bubble-row <%= msg.isMine ? 'msg-bubble-row--mine' : 'msg-bubble-row--theirs' %>"
             data-id="<%= msg.id %>"
             data-is-mine="<%= msg.isMine ? 1 : 0 %>">

          <%/* Avatar — only for theirs, placed first in DOM */%>
          <% if (!msg.isMine) { %>
            <div class="msg-bubble-avatar">
              <% if (other && other.avatar) { %><img src="<%= other.avatar %>" alt="" />
              <% } else { %><div class="msg-bubble-initial"><%= (other?.name||'U').charAt(0) %></div><% } %>
            </div>
          <% } %>

          <%/* Bubble content */%>
          <div class="msg-bubble-wrap">
            <%/* Reply quote block */%>
            <% if (msg.reply_to_content) { %>
              <div class="msg-reply-quote">
                <span class="msg-reply-quote-name"><%= msg.reply_to_name || 'Someone' %></span>
                <span class="msg-reply-quote-text"><%= msg.reply_to_content %></span>
              </div>
            <% } %>

            <div class="msg-bubble">
              <%- msg.content ? msg.content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>') : '' %>
              <% if (msg.file_url) { %>
                <% if (msg.file_type === 'image') { %>
                  <a href="<%= msg.file_url %>" target="_blank" class="msg-media-img-wrap">
                    <img src="<%= msg.file_url %>" alt="<%= msg.file_name %>" class="msg-media-img" loading="lazy" />
                  </a>
                <% } else if (msg.file_type === 'video') { %>
                  <video class="msg-media-video" controls preload="metadata" playsinline>
                    <source src="<%= msg.file_url %>" type="<%=
                      msg.file_url.endsWith('.mp4')  ? 'video/mp4'       :
                      msg.file_url.endsWith('.webm') ? 'video/webm'      :
                      msg.file_url.endsWith('.ogg')  ? 'video/ogg'       :
                      msg.file_url.endsWith('.mov')  ? 'video/quicktime' : 'video/mp4'
                    %>" />
                    Your browser does not support video.
                  </video>
                <% } else { %>
                  <a href="<%= msg.file_url %>" target="_blank" download="<%= msg.file_name %>" class="msg-file-chip">
                    <i class="fa-solid fa-file-arrow-down"></i>
                    <span><%= msg.file_name %></span>
                  </a>
                <% } %>
              <% } %>
            </div>

            <%/* Reaction chips */%>
            <div class="msg-reactions" id="rxn-<%= msg.id %>">
              <% if (msg.like_count > 0) { %>
                <span class="msg-rxn-chip" data-type="like">❤️ <%= msg.like_count %></span>
              <% } %>
              <% if (msg.dislike_count > 0) { %>
                <span class="msg-rxn-chip" data-type="dislike">👎 <%= msg.dislike_count %></span>
              <% } %>
            </div>

            <span class="msg-bubble-time"><%= msg.timeAgo %></span>
          </div>

          <%/* Action bar — sits beside the bubble */%>
          <div class="msg-actions">
            <button class="msg-action-btn msg-action-reply" title="Reply"
                    data-content="<%= (msg.content || (msg.file_name ? msg.file_name : 'Attachment')).substring(0,80).replace(/"/g,'&quot;') %>"
                    data-name="<%= senderLabel.replace(/"/g,'&quot;') %>">
              <i class="fa-solid fa-reply"></i>
            </button>
            <button class="msg-action-btn msg-action-like <%= msg.my_reaction === 'like' ? 'active' : '' %>" title="Like">
              <i class="fa-solid fa-heart"></i>
            </button>
            <button class="msg-action-btn msg-action-dislike <%= msg.my_reaction === 'dislike' ? 'active' : '' %>" title="Dislike">
              <i class="fa-solid fa-thumbs-down"></i>
            </button>
            <% if (msg.isMine) { %>
              <button class="msg-action-btn msg-action-delete" title="Delete message">
                <i class="fa-solid fa-trash-can"></i>
              </button>
            <% } %>
          </div>

        </div><%/* end .msg-bubble-row */%>
      <% }) %>
    </div>

    <!-- Input bar -->
    <div class="msg-input-bar">

      <!-- Reply strip (shown when replying) -->
      <div class="msg-reply-strip" id="replyStrip" style="display:none">
        <i class="fa-solid fa-reply msg-reply-strip-icon"></i>
        <div class="msg-reply-strip-body">
          <span class="msg-reply-strip-name" id="replyToName"></span>
          <span class="msg-reply-strip-text" id="replyToText"></span>
        </div>
        <button type="button" class="msg-reply-strip-cancel" id="cancelReply" title="Cancel reply">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <!-- File preview strip -->
      <div class="msg-file-preview" id="filePreview" style="display:none">
        <div class="msg-file-preview-inner">
          <img id="filePreviewImg" src="" alt="" style="display:none" />
          <div id="filePreviewChip" class="msg-file-preview-chip" style="display:none">
            <i class="fa-solid fa-file"></i>
            <span id="filePreviewName"></span>
          </div>
          <button type="button" id="clearFile" class="msg-clear-file" title="Remove file">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
      </div>

      <form id="messageForm" class="msg-input-form" autocomplete="off" enctype="multipart/form-data">
        <label class="msg-attach-label" title="Attach file">
          <i class="fa-solid fa-paperclip"></i>
          <input type="file" id="fileInput" name="file"
                 accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.zip,.rar"
                 style="display:none" />
        </label>

        <div class="msg-input-wrap">
          <textarea id="messageInput" class="msg-textarea" placeholder="Type a message…" rows="1" maxlength="2000"></textarea>
        </div>

        <button type="submit" class="msg-send-btn" id="sendBtn" aria-label="Send">
          <i class="fa-solid fa-paper-plane"></i>
        </button>
      </form>
    </div>

  </main>
</div>

<script>
(function () {
  const CONV_ID      = <%= conversation.id %>;
  const CURRENT_UID  = <%= currentUserId %>;
  const otherName    = '<%= (other?.name || "User").replace(/'/g, "\\'") %>';
  const otherAvatar  = '<%= other?.avatar || "" %>';
  const otherInitial = '<%= (other?.name || "U").charAt(0).toUpperCase() %>';

  const area       = document.getElementById('chatMessages');
  const form       = document.getElementById('messageForm');
  const input      = document.getElementById('messageInput');
  const fileInput  = document.getElementById('fileInput');
  const preview    = document.getElementById('filePreview');
  const prevImg    = document.getElementById('filePreviewImg');
  const prevChip   = document.getElementById('filePreviewChip');
  const prevName   = document.getElementById('filePreviewName');
  const clearBtn   = document.getElementById('clearFile');
  const sendBtn    = document.getElementById('sendBtn');
  const emptyState = document.getElementById('chatEmptyState');
  const replyStrip = document.getElementById('replyStrip');
  const replyToName= document.getElementById('replyToName');
  const replyToText= document.getElementById('replyToText');
  const cancelReply= document.getElementById('cancelReply');

  // Reply state
  let replyingToId      = null;
  let replyingToContent = '';
  let replyingToName    = '';

  let lastId = 0;
  const renderedIds = new Set(); // guard against poll returning a msg we just sent
  const rows = area.querySelectorAll('.msg-bubble-row[data-id]');
  rows.forEach(r => { const id = parseInt(r.dataset.id); if (id) renderedIds.add(id); });
  if (rows.length) lastId = parseInt(rows[rows.length - 1].dataset.id);

  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function scrollBottom(smooth) { area.scrollTo({ top: area.scrollHeight, behavior: smooth ? 'smooth' : 'instant' }); }
  scrollBottom(false);

  /* ─────────────────────────────────────────────────────── file picker */
  fileInput.addEventListener('change', () => {
    const file = fileInput.files[0];
    if (!file) return;
    preview.style.display = 'block';
    if (file.type.startsWith('image/')) {
      prevImg.src = URL.createObjectURL(file);
      prevImg.style.cssText = 'display:block;height:72px;width:auto;max-width:120px;object-fit:cover;border-radius:8px;border:1px solid #e2e8f0;flex-shrink:0;';
      prevChip.style.display = 'none';
    } else {
      prevImg.style.display = 'none';
      prevChip.style.display = 'flex';
      prevName.textContent = file.name;
    }
  });
  clearBtn.addEventListener('click', () => {
    fileInput.value = '';
    preview.style.display = 'none';
    prevImg.src = ''; prevImg.style.cssText = 'display:none;';
    prevChip.style.display = 'none';
  });

  /* ─────────────────────────────────────────────────────── build bubble */
  function buildReactionBar(likes, dislikes) {
    let html = '';
    if (likes   > 0) html += `<span class="msg-rxn-chip" data-type="like">❤️ ${likes}</span>`;
    if (dislikes > 0) html += `<span class="msg-rxn-chip" data-type="dislike">👎 ${dislikes}</span>`;
    return html;
  }

  function buildBubble(msg) {
    if (emptyState) emptyState.remove();
    const isMine = msg.isMine || msg.sender_id === CURRENT_UID;
    const row = document.createElement('div');
    row.className = `msg-bubble-row ${isMine ? 'msg-bubble-row--mine' : 'msg-bubble-row--theirs'}`;
    row.dataset.id     = msg.id;
    row.dataset.isMine = isMine ? '1' : '0';

    const avatarHtml = !isMine
      ? (otherAvatar
          ? `<div class="msg-bubble-avatar"><img src="${esc(otherAvatar)}" alt="${esc(otherName)}" /></div>`
          : `<div class="msg-bubble-avatar"><div class="msg-bubble-initial">${esc(otherInitial)}</div></div>`)
      : '';

    const textHtml = msg.content
      ? `<span>${esc(msg.content).replace(/\n/g,'<br>')}</span>`
      : '';

    let mediaHtml = '';
    if (msg.file_url) {
      if (msg.file_type === 'image') {
        mediaHtml = `<a href="${esc(msg.file_url)}" target="_blank" class="msg-media-img-wrap">
          <img src="${esc(msg.file_url)}" alt="${esc(msg.file_name||'image')}" class="msg-media-img" loading="lazy" />
        </a>`;
      } else if (msg.file_type === 'video') {
        const ext  = (msg.file_url||'').split('.').pop().toLowerCase();
        const mime = ext==='webm'?'video/webm':ext==='ogg'?'video/ogg':ext==='mov'?'video/quicktime':'video/mp4';
        mediaHtml = `<video class="msg-media-video" controls preload="metadata" playsinline>
          <source src="${esc(msg.file_url)}" type="${mime}" />
        </video>`;
      } else {
        mediaHtml = `<a href="${esc(msg.file_url)}" target="_blank" download="${esc(msg.file_name||'file')}" class="msg-file-chip">
          <i class="fa-solid fa-file-arrow-down"></i>
          <span>${esc(msg.file_name||'Download file')}</span>
        </a>`;
      }
    }

    const quoteHtml = msg.reply_to_content
      ? `<div class="msg-reply-quote">
           <span class="msg-reply-quote-name">${esc(msg.reply_to_name||'Someone')}</span>
           <span class="msg-reply-quote-text">${esc(msg.reply_to_content)}</span>
         </div>`
      : '';

    const deleteBtn = isMine
      ? `<button class="msg-action-btn msg-action-delete" title="Delete message"><i class="fa-solid fa-trash-can"></i></button>`
      : '';

    const replyContent = msg.content || (msg.file_name || 'Attachment');
    const senderLabel  = isMine ? 'You' : otherName;

    row.innerHTML = `
      ${avatarHtml}
      <div class="msg-bubble-wrap">
        ${quoteHtml}
        <div class="msg-bubble">${textHtml}${mediaHtml}</div>
        <div class="msg-reactions" id="rxn-${msg.id}">${buildReactionBar(msg.like_count||0, msg.dislike_count||0)}</div>
        <span class="msg-bubble-time">${esc(msg.timeAgo || 'just now')}</span>
      </div>
      <div class="msg-actions">
        <button class="msg-action-btn msg-action-reply" title="Reply"
                data-content="${esc(String(replyContent).substring(0,80))}"
                data-name="${esc(senderLabel)}">
          <i class="fa-solid fa-reply"></i>
        </button>
        <button class="msg-action-btn msg-action-like ${msg.my_reaction==='like'?'active':''}" title="Like">
          <i class="fa-solid fa-heart"></i>
        </button>
        <button class="msg-action-btn msg-action-dislike ${msg.my_reaction==='dislike'?'active':''}" title="Dislike">
          <i class="fa-solid fa-thumbs-down"></i>
        </button>
        ${deleteBtn}
      </div>`;

    renderedIds.add(parseInt(msg.id));
    area.appendChild(row);
    scrollBottom(true);
  }

  /* ─────────────────────────────────────────────────────── send */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    const file = fileInput.files[0];
    if (!text && !file) return;

    sendBtn.disabled = true;
    sendBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

    try {
      const fd = new FormData();
      if (text) fd.append('content', text);
      if (file) fd.append('file', file);
      if (replyingToId) {
        fd.append('reply_to_id',      replyingToId);
        fd.append('reply_to_content', replyingToContent.substring(0,120));
        fd.append('reply_to_name',    replyingToName);
      }

      const res  = await fetch(`/messages/${CONV_ID}`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: fd,
      });
      const data = await res.json();
      if (data.success && data.message) {
        buildBubble({ ...data.message, isMine: true });
        lastId = data.message.id;
      }
    } catch (err) { console.error(err); }
    finally {
      input.value = ''; input.style.height = 'auto';
      fileInput.value = '';
      preview.style.display = 'none';
      prevImg.src = ''; prevImg.style.cssText = 'display:none;';
      prevChip.style.display = 'none';
      clearReply();
      sendBtn.disabled = false;
      sendBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i>';
    }
  });

  /* ─────────────────────────────────────────────────────── reply */
  function clearReply() {
    replyingToId = null; replyingToContent = ''; replyingToName = '';
    replyStrip.style.display = 'none';
  }
  cancelReply.addEventListener('click', clearReply);

  /* ─────────────────────────────────────────────────────── textarea auto-resize */
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  });
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
  });

  /* ─────────────────────────────────────────────────────── action bar click handler */
  area.addEventListener('click', async (e) => {
    const btn = e.target.closest('.msg-action-btn');
    if (!btn) {
      // Tap elsewhere on mobile dismisses open action bar
      area.querySelectorAll('.msg-bubble-row--active').forEach(r => r.classList.remove('msg-bubble-row--active'));
      return;
    }

    const row    = btn.closest('.msg-bubble-row');
    const msgId  = row?.dataset.id;
    const isMine = row?.dataset.isMine === '1';

    /* ── Reply ── */
    if (btn.classList.contains('msg-action-reply')) {
      replyingToId      = msgId;
      replyingToContent = btn.dataset.content || '';
      replyingToName    = btn.dataset.name    || 'Someone';
      replyToName.textContent = replyingToName;
      replyToText.textContent = replyingToContent.length > 60
        ? replyingToContent.substring(0,60) + '…'
        : replyingToContent;
      replyStrip.style.display = 'flex';
      input.focus();
      return;
    }

    /* ── Like / Dislike ── */
    if (btn.classList.contains('msg-action-like') || btn.classList.contains('msg-action-dislike')) {
      const reaction = btn.classList.contains('msg-action-like') ? 'like' : 'dislike';
      try {
        const r = await fetch(`/messages/${CONV_ID}/messages/${msgId}/react`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ reaction }),
        });
        const d = await r.json();
        if (!d.success) return;

        // Update action button states in this row
        const likeBtn    = row.querySelector('.msg-action-like');
        const dislikeBtn = row.querySelector('.msg-action-dislike');
        likeBtn?.classList.toggle('active', d.myReaction === 'like');
        dislikeBtn?.classList.toggle('active', d.myReaction === 'dislike');

        // Update reaction chips
        const rxnEl = document.getElementById(`rxn-${msgId}`);
        if (rxnEl) rxnEl.innerHTML = buildReactionBar(d.likes, d.dislikes);
      } catch (err) { console.error(err); }
      return;
    }

    /* ── Delete ── */
    if (btn.classList.contains('msg-action-delete')) {
      if (!isMine) return;
      if (!confirm('Delete this message? This cannot be undone.')) return;
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      try {
        const r = await fetch(`/messages/${CONV_ID}/messages/${msgId}`, {
          method: 'DELETE',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
        });
        const d = await r.json();
        if (d.success) {
          row.style.transition = 'opacity .25s, transform .25s';
          row.style.opacity = '0'; row.style.transform = 'scale(.95)';
          setTimeout(() => row.remove(), 260);
        } else {
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-trash-can"></i>';
        }
      } catch (err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-trash-can"></i>';
      }
      return;
    }
  });

  /* ─────────────────────────────────────────────────────── long press (mobile) */
  let pressTimer = null;
  area.addEventListener('touchstart', (e) => {
    const row = e.target.closest('.msg-bubble-row');
    if (!row || e.target.closest('.msg-actions') || e.target.closest('a, button, video')) return;
    pressTimer = setTimeout(() => {
      area.querySelectorAll('.msg-bubble-row--active').forEach(r => r !== row && r.classList.remove('msg-bubble-row--active'));
      row.classList.toggle('msg-bubble-row--active');
      // Haptic feedback if available
      if (navigator.vibrate) navigator.vibrate(40);
    }, 450);
  }, { passive: true });

  const clearPress = () => clearTimeout(pressTimer);
  area.addEventListener('touchend',   clearPress, { passive: true });
  area.addEventListener('touchmove',  clearPress, { passive: true });
  area.addEventListener('touchcancel',clearPress, { passive: true });

  // Dismiss on scroll
  area.addEventListener('scroll', () => {
    area.querySelectorAll('.msg-bubble-row--active').forEach(r => r.classList.remove('msg-bubble-row--active'));
  }, { passive: true });

  /* ─────────────────────────────────────────────────────── poll */
  async function poll() {
    try {
      const r = await fetch(`/messages/${CONV_ID}/poll?after=${lastId}`);
      const data = await r.json();
      if (data.messages && data.messages.length) {
        data.messages
          .filter(m => !renderedIds.has(parseInt(m.id)))
          .forEach(m => buildBubble(m));
        lastId = data.messages[data.messages.length - 1].id;
      }
    } catch(e) {}
  }

  let timer = setInterval(poll, 3000);
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) clearInterval(timer);
    else { poll(); timer = setInterval(poll, 3000); }
  });
  window.addEventListener('beforeunload', () => clearInterval(timer));

  input.focus();
})();
</script>
