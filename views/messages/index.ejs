<div class="msg-shell">

  <!-- Sidebar -->
  <aside class="msg-sidebar">
    <div class="msg-sidebar-head">
      <h1 class="msg-sidebar-title">Messages</h1>
    </div>

    <div class="msg-conv-list">
      <% if (conversations.length === 0) { %>
        <div class="msg-empty-sidebar">
          <i class="fa-solid fa-comment-dots"></i>
          <p>No conversations yet</p>
          <span>Visit a profile and click <strong>Message</strong></span>
        </div>
      <% } %>
      <% conversations.forEach(conv => { %>
        <a href="/messages/<%= conv.id %>" class="msg-conv-item">
          <div class="msg-conv-avatar">
            <% if (conv.other_avatar) { %>
              <img src="<%= conv.other_avatar %>" alt="<%= conv.other_name %>" />
            <% } else { %>
              <div class="msg-conv-initial"><%= conv.other_name.charAt(0).toUpperCase() %></div>
            <% } %>
            <% if (conv.unread > 0) { %><span class="msg-unread-dot"></span><% } %>
          </div>
          <div class="msg-conv-body">
            <div class="msg-conv-top">
              <span class="msg-conv-name <%= conv.unread > 0 ? 'msg-conv-name--bold' : '' %>"><%= conv.other_name %></span>
              <span class="msg-conv-time"><%= conv.timeAgo %></span>
            </div>
            <p class="msg-conv-preview <%= conv.unread > 0 ? 'msg-conv-preview--bold' : '' %>">
              <%= conv.last_msg ? conv.last_msg.substring(0,60) + (conv.last_msg.length > 60 ? '…' : '') : 'Start the conversation' %>
            </p>
          </div>
        </a>
      <% }) %>
    </div>
  </aside>

  <!-- Empty chat panel -->
  <main class="msg-chat-panel msg-chat-empty-panel">
    <div class="msg-chat-empty-state">
      <div class="msg-chat-empty-icon"><i class="fa-solid fa-comments"></i></div>
      <h2>Your Messages</h2>
      <p>Select a conversation to start chatting, or visit a user's profile to send them a message.</p>
      <a href="/users" class="btn btn-primary btn-sm" style="margin-top:1rem">
        <i class="fa-solid fa-users"></i> Find People
      </a>
    </div>
  </main>

</div>
