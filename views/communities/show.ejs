<!-- Community Banner -->
<div class="comm-banner">
  <div class="comm-banner-cover">
    <% if (community.cover_image) { %>
      <img src="<%= community.cover_image %>" alt="<%= community.name %> cover" />
    <% } else { %>
      <div class="comm-banner-cover-default"></div>
    <% } %>
  </div>

  <div class="container">
    <div class="comm-banner-info">
      <!-- Avatar -->
      <div class="comm-banner-avatar">
        <% if (community.avatar) { %>
          <img src="<%= community.avatar %>" alt="<%= community.name %>" />
        <% } else { %>
          <div class="comm-banner-avatar-placeholder"><%= community.name.charAt(0).toUpperCase() %></div>
        <% } %>
      </div>

      <div class="comm-banner-text">
        <div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap">
          <h1 class="comm-banner-title"><%= community.name %></h1>
          <% if (community.is_private) { %>
            <span class="comm-private-badge"><i class="fa-solid fa-lock"></i> Private</span>
          <% } %>
        </div>
        <div class="comm-banner-desc rich-content"><%- community.description %></div>
        <div class="comm-banner-stats">
          <span><i class="fa-solid fa-users"></i> <strong><%= community.member_count %></strong> members</span>
          <span><i class="fa-solid fa-file-lines"></i> <strong><%= community.post_count %></strong> posts</span>
          <span style="color:var(--text-muted);font-size:.8rem">By <%= community.owner_name %></span>
        </div>
      </div>

      <div class="comm-banner-actions">
        <!-- Share button — always visible -->
        <button class="btn btn-outline comm-share-btn" onclick="openShareModal()" title="Share community">
          <i class="fa-solid fa-share-nodes"></i> Share
        </button>

        <% if (!currentUser) { %>
          <a href="/auth/login" class="btn btn-primary">Join Community</a>
        <% } else if (isOwner) { %>
          <a href="/communities/<%= community.slug %>/settings" class="btn btn-outline">
            <i class="fa-solid fa-gear"></i> Settings
          </a>
        <% } else if (membership) { %>
          <form action="/communities/<%= community.slug %>/leave" method="POST" onsubmit="return confirm('Leave this community?')">
            <button class="btn btn-danger-outline">
              <i class="fa-solid fa-right-from-bracket"></i> Leave
            </button>
          </form>
        <% } else { %>
          <form action="/communities/<%= community.slug %>/join" method="POST">
            <button class="btn btn-primary comm-join-btn"><i class="fa-solid fa-plus"></i> Join Community</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Main Layout -->
<div class="container">
  <div class="comm-layout">

    <!-- Left: Posts Feed -->
    <div class="comm-main">

      <!-- Compose Box (members only) -->
      <% if (membership || isOwner) { %>
        <div class="card comm-compose" id="composeCard">
          <div class="comm-compose-trigger" id="composeTrigger">
            <% if (currentUser.avatar) { %>
              <img src="<%= currentUser.avatar %>" alt="" class="avatar-sm" />
            <% } else { %>
              <div class="avatar-placeholder-sm"><%= currentUser.name.charAt(0) %></div>
            <% } %>
            <div class="comm-compose-fake-input">Share something with the community...</div>
          </div>

          <div class="comm-compose-form" id="composeForm" style="display:none">
            <form action="/communities/<%= community.slug %>/posts" method="POST" enctype="multipart/form-data">
              <input type="text" name="title" class="form-input" placeholder="Post title (optional)" style="margin-bottom:.75rem" />
              <textarea name="content" class="form-input" rows="4" placeholder="What's on your mind?" required style="margin-bottom:.75rem"></textarea>
              <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
                <label class="comm-attach-btn">
                  <i class="fa-solid fa-image"></i> Add Image
                  <input type="file" name="image" accept="image/*" style="display:none" />
                </label>
                <div style="margin-left:auto;display:flex;gap:.5rem">
                  <button type="button" id="cancelCompose" class="btn btn-outline btn-sm">Cancel</button>
                  <button type="submit" class="btn btn-primary btn-sm">Publish Post</button>
                </div>
              </div>
              <div id="imagePreviewWrap" style="margin-top:.75rem;display:none">
                <img id="imagePreview" src="" alt="" style="max-height:200px;border-radius:8px;object-fit:cover" />
              </div>
            </form>
          </div>
        </div>
      <% } %>

      <!-- Posts -->
      <% if (posts.length === 0) { %>
        <div class="card" style="padding:3rem;text-align:center;color:var(--text-muted)">
          <i class="fa-solid fa-pen-to-square" style="font-size:2.5rem;margin-bottom:1rem;display:block;opacity:.4"></i>
          <p style="font-size:1.1rem;font-weight:600;margin-bottom:.35rem">No posts yet</p>
          <p style="font-size:.9rem">
            <% if (membership || isOwner) { %>Be the first to post something!
            <% } else { %>Join the community to see and create posts.<% } %>
          </p>
        </div>
      <% } else { %>
        <% posts.forEach(post => { %>
          <div class="card comm-post-card">
            <!-- Author row -->
            <div class="comm-post-author">
              <a href="/users/<%= post.user_id %>">
                <% if (post.author_avatar) { %>
                  <img src="<%= post.author_avatar %>" alt="<%= post.author_name %>" class="avatar-sm" />
                <% } else { %>
                  <div class="avatar-placeholder-sm"><%= (post.author_name || 'U').charAt(0) %></div>
                <% } %>
              </a>
              <div>
                <a href="/users/<%= post.user_id %>" class="comm-post-author-name"><%= post.author_name %></a>
                <span class="comm-post-time"><%= post.timeAgo %></span>
              </div>
              <% if (post.is_pinned) { %>
                <span class="comm-pin-badge"><i class="fa-solid fa-thumbtack"></i> Pinned</span>
              <% } %>
              <% if ((currentUser && post.user_id === currentUser.id) || isOwner) { %>
                <form action="/communities/<%= community.slug %>/posts/<%= post.id %>/delete" method="POST"
                      style="margin-left:auto" onsubmit="return confirm('Delete this post?')">
                  <button class="comm-post-delete-btn" title="Delete post">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              <% } %>
            </div>

            <!-- Content -->
            <a href="/communities/<%= community.slug %>/posts/<%= post.id %>" class="comm-post-link">
              <% if (post.title) { %>
                <h2 class="comm-post-title"><%= post.title %></h2>
              <% } %>
              <p class="comm-post-excerpt"><%= post.excerpt %></p>
              <% if (post.image) { %>
                <img src="<%= post.image %>" alt="" class="comm-post-img" loading="lazy" />
              <% } %>
            </a>

            <!-- Meta -->
            <div class="comm-post-meta">
              <a href="/communities/<%= community.slug %>/posts/<%= post.id %>" class="comm-post-meta-btn">
                <i class="fa-regular fa-comment"></i> <%= post.comment_count %> comment<%= post.comment_count !== 1 ? 's' : '' %>
              </a>
              <a href="/communities/<%= community.slug %>/posts/<%= post.id %>" class="comm-post-meta-btn">
                <i class="fa-solid fa-arrow-up-right-from-square"></i> View
              </a>
            </div>
          </div>
        <% }) %>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div style="display:flex;justify-content:center;gap:.5rem;padding:1rem 0">
            <% if (hasPrev) { %><a href="?page=<%= page-1 %>" class="btn btn-outline btn-sm">← Prev</a><% } %>
            <span style="display:flex;align-items:center;padding:0 .75rem;color:var(--text-muted);font-size:.85rem">Page <%= page %> / <%= totalPages %></span>
            <% if (hasNext) { %><a href="?page=<%= page+1 %>" class="btn btn-outline btn-sm">Next →</a><% } %>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- Right Sidebar -->
    <aside class="comm-sidebar">
      <!-- About -->
      <div class="card comm-sidebar-card">
        <h3 class="comm-sidebar-heading">About</h3>
        <div class="rich-content" style="font-size:.88rem;color:var(--text-muted);line-height:1.6"><%- community.description %></div>
        <div class="comm-sidebar-stats">
          <div class="comm-sidebar-stat">
            <span class="comm-sidebar-stat-num"><%= community.member_count %></span>
            <span class="comm-sidebar-stat-label">Members</span>
          </div>
          <div class="comm-sidebar-stat">
            <span class="comm-sidebar-stat-num"><%= community.post_count %></span>
            <span class="comm-sidebar-stat-label">Posts</span>
          </div>
        </div>
        <% if (!currentUser) { %>
          <a href="/auth/login" class="btn btn-primary btn-sm" style="width:100%;margin-top:.75rem">Join Community</a>
        <% } else if (!membership && !isOwner) { %>
          <form action="/communities/<%= community.slug %>/join" method="POST" style="margin-top:.75rem">
            <button class="btn btn-primary btn-sm" style="width:100%"><i class="fa-solid fa-plus"></i> Join Community</button>
          </form>
          <form action="/communities/<%= community.slug %>/leave" method="POST" style="margin-top:.5rem;display:none" id="sidebarLeaveForm">
            <button class="btn btn-sm" style="width:100%;color:var(--danger);border:1px solid var(--danger);background:transparent">
              <i class="fa-solid fa-right-from-bracket"></i> Leave Community
            </button>
          </form>
        <% } else if (isOwner) { %>
          <a href="/communities/<%= community.slug %>/settings" class="btn btn-outline btn-sm" style="width:100%;margin-top:.75rem">
            <i class="fa-solid fa-gear"></i> Manage Community
          </a>
        <% } else if (membership) { %>
          <form action="/communities/<%= community.slug %>/leave" method="POST" style="margin-top:.75rem" onsubmit="return confirm('Leave this community?')">
            <button class="btn btn-sm" style="width:100%;color:var(--danger);border:1px solid var(--danger);background:transparent">
              <i class="fa-solid fa-right-from-bracket"></i> Leave Community
            </button>
          </form>
        <% } %>

        <!-- Share -->
        <button class="btn btn-outline btn-sm" style="width:100%;margin-top:.75rem" onclick="openShareModal()">
          <i class="fa-solid fa-share-nodes"></i> Share Community
        </button>
      </div>

      <!-- Membership Plans (if any) -->
      <% if (typeof plans !== 'undefined' && plans && plans.length > 0 && !membership && !isOwner) { %>
        <div class="card comm-sidebar-card" style="border:2px solid var(--primary)">
          <h3 class="comm-sidebar-heading" style="color:var(--primary)"><i class="fa-solid fa-layer-group"></i> Membership Plans</h3>
          <% plans.forEach(plan => { %>
            <div style="border:1px solid var(--border);border-radius:10px;padding:.85rem;margin-bottom:.6rem">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.2rem">
                <span style="font-weight:700;font-size:.92rem"><%= plan.name %></span>
                <span style="font-weight:800;color:var(--primary)">
                  <%= plan.billing_type === 'free' ? 'Free' : '$' + parseFloat(plan.price).toFixed(2) %>
                  <span style="font-size:.72rem;color:var(--text-muted);font-weight:400">
                    <% if (plan.billing_type === 'monthly') { %>/mo<% } else if (plan.billing_type === 'yearly') { %>/yr<% } else if (plan.billing_type === 'lifetime') { %> lifetime<% } %>
                  </span>
                </span>
              </div>
              <% if (plan.description) { %><p style="font-size:.78rem;color:var(--text-muted);margin-bottom:.5rem"><%= plan.description %></p><% } %>
              <% if (plan.billing_type === 'free') { %>
                <% if (currentUser) { %>
                  <form action="/communities/<%= community.slug %>/join" method="POST">
                    <button class="btn btn-primary btn-sm" style="width:100%"><i class="fa-solid fa-plus"></i> Join Free</button>
                  </form>
                <% } else { %>
                  <a href="/auth/login" class="btn btn-primary btn-sm" style="width:100%;text-align:center;display:block">Join Free</a>
                <% } %>
              <% } else { %>
                <% if (currentUser) { %>
                  <a href="/checkout/plan/<%= plan.id %>" class="btn btn-primary btn-sm" style="width:100%;text-align:center;display:block">
                    <i class="fa-solid fa-arrow-right"></i> Get Access
                  </a>
                <% } else { %>
                  <a href="/auth/login" class="btn btn-primary btn-sm" style="width:100%;text-align:center;display:block">Sign in to Join</a>
                <% } %>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Community Navigation (Courses, Events, Products) -->
      <div class="card comm-sidebar-card">
        <h3 class="comm-sidebar-heading">Explore</h3>
        <div style="display:flex;flex-direction:column;gap:.3rem">
          <a href="/communities/<%= community.slug %>/courses" style="display:flex;align-items:center;gap:.65rem;padding:.55rem .4rem;border-radius:8px;font-size:.88rem;font-weight:500;color:var(--body);transition:background .1s" onmouseover="this.style.background='var(--bg-light)'" onmouseout="this.style.background=''">
            <i class="fa-solid fa-graduation-cap" style="color:var(--primary);width:16px;text-align:center"></i> Courses
          </a>
          <a href="/communities/<%= community.slug %>/events" style="display:flex;align-items:center;gap:.65rem;padding:.55rem .4rem;border-radius:8px;font-size:.88rem;font-weight:500;color:var(--body);transition:background .1s" onmouseover="this.style.background='var(--bg-light)'" onmouseout="this.style.background=''">
            <i class="fa-solid fa-calendar-days" style="color:var(--warning);width:16px;text-align:center"></i> Events
          </a>
          <a href="/communities/<%= community.slug %>/products" style="display:flex;align-items:center;gap:.65rem;padding:.55rem .4rem;border-radius:8px;font-size:.88rem;font-weight:500;color:var(--body);transition:background .1s" onmouseover="this.style.background='var(--bg-light)'" onmouseout="this.style.background=''">
            <i class="fa-solid fa-box-open" style="color:var(--success);width:16px;text-align:center"></i> Products
          </a>
        </div>
      </div>

      <!-- Members -->
      <div class="card comm-sidebar-card">
        <h3 class="comm-sidebar-heading">Members <span style="color:var(--text-muted);font-weight:400;font-size:.85rem">(<%= community.member_count %>)</span></h3>
        <div class="comm-members-grid">
          <% members.forEach(m => { %>
            <a href="/users/<%= m.id %>" title="<%= m.name %> (<%= m.role %>)" class="comm-member-item">
              <% if (m.avatar) { %>
                <img src="<%= m.avatar %>" alt="<%= m.name %>" class="avatar-sm" />
              <% } else { %>
                <div class="avatar-placeholder-sm"><%= (m.name || 'U').charAt(0) %></div>
              <% } %>
              <% if (m.role === 'owner') { %>
                <span class="comm-member-crown"><i class="fa-solid fa-crown"></i></span>
              <% } %>
            </a>
          <% }) %>
        </div>
        <% if (community.member_count > 16) { %>
          <p style="font-size:.8rem;color:var(--text-muted);margin-top:.75rem;text-align:center">
            +<%= community.member_count - 16 %> more members
          </p>
        <% } %>
      </div>

      <!-- Back link -->
      <a href="/communities" style="display:flex;align-items:center;gap:.4rem;color:var(--text-muted);font-size:.85rem;padding:.5rem 0">
        <i class="fa-solid fa-arrow-left"></i> All Communities
      </a>
    </aside>
  </div>
</div>

<!-- ── Share Modal ────────────────────────────────────────────────────── -->
<div class="share-modal-overlay" id="shareOverlay" style="display:none" onclick="if(event.target===this)closeShareModal()">
  <div class="share-modal-box">
    <div class="share-modal-head">
      <h3><i class="fa-solid fa-share-nodes"></i> Share Community</h3>
      <button class="share-modal-close" onclick="closeShareModal()"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <p class="share-modal-label">Community link</p>
    <div class="share-copy-row">
      <input type="text" id="shareLinkInput" class="share-link-input" readonly
             value="<%= (typeof appUrl !== 'undefined' ? appUrl : '') %>/communities/<%= community.slug %>" />
      <button class="btn btn-primary btn-sm" id="copyLinkBtn" onclick="copyLink()">
        <i class="fa-solid fa-copy"></i> Copy
      </button>
    </div>

    <p class="share-modal-label" style="margin-top:1.25rem">Share on</p>
    <div class="share-socials">
      <a class="share-social-btn share-twitter"
         href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent('Join ' + community.name + ' on Diskas!') %>&url=<%= encodeURIComponent((typeof appUrl !== 'undefined' ? appUrl : '') + '/communities/' + community.slug) %>"
         target="_blank" rel="noopener">
        <i class="fa-brands fa-x-twitter"></i> X / Twitter
      </a>
      <a class="share-social-btn share-whatsapp"
         href="https://wa.me/?text=<%= encodeURIComponent('Join ' + community.name + ' on Diskas! ' + (typeof appUrl !== 'undefined' ? appUrl : '') + '/communities/' + community.slug) %>"
         target="_blank" rel="noopener">
        <i class="fa-brands fa-whatsapp"></i> WhatsApp
      </a>
      <a class="share-social-btn share-facebook"
         href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent((typeof appUrl !== 'undefined' ? appUrl : '') + '/communities/' + community.slug) %>"
         target="_blank" rel="noopener">
        <i class="fa-brands fa-facebook-f"></i> Facebook
      </a>
      <a class="share-social-btn share-telegram"
         href="https://t.me/share/url?url=<%= encodeURIComponent((typeof appUrl !== 'undefined' ? appUrl : '') + '/communities/' + community.slug) %>&text=<%= encodeURIComponent('Join ' + community.name + ' on Diskas!') %>"
         target="_blank" rel="noopener">
        <i class="fa-brands fa-telegram"></i> Telegram
      </a>
    </div>
  </div>
</div>

<script>
  /* ── Share modal ── */
  function openShareModal() {
    // Ensure the link is the real current URL if APP_URL placeholder is empty
    const inp = document.getElementById('shareLinkInput');
    if (!inp.value || !inp.value.startsWith('http')) {
      inp.value = window.location.origin + '/communities/<%= community.slug %>';
    }
    document.getElementById('shareOverlay').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeShareModal() {
    document.getElementById('shareOverlay').style.display = 'none';
    document.body.style.overflow = '';
  }
  function copyLink() {
    const inp = document.getElementById('shareLinkInput');
    inp.select(); inp.setSelectionRange(0, 9999);
    navigator.clipboard.writeText(inp.value).then(() => {
      const btn = document.getElementById('copyLinkBtn');
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
      setTimeout(() => { btn.innerHTML = '<i class="fa-solid fa-copy"></i> Copy'; }, 2000);
    });
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeShareModal(); });

  const trigger  = document.getElementById('composeTrigger');
  const form     = document.getElementById('composeForm');
  const cancelBtn = document.getElementById('cancelCompose');

  if (trigger) {
    trigger.addEventListener('click', () => {
      trigger.style.display = 'none';
      form.style.display = 'block';
      form.querySelector('textarea').focus();
    });
  }
  if (cancelBtn) {
    cancelBtn.addEventListener('click', () => {
      form.style.display = 'none';
      trigger.style.display = 'flex';
    });
  }

  // Image preview
  const imageInput = document.querySelector('input[name="image"]');
  if (imageInput) {
    imageInput.addEventListener('change', function() {
      const file = this.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = e => {
        const wrap = document.getElementById('imagePreviewWrap');
        const img  = document.getElementById('imagePreview');
        img.src = e.target.result;
        wrap.style.display = 'block';
      };
      reader.readAsDataURL(file);
    });
  }
</script>
